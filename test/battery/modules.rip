# Test: Modules (5 node types)
# Tests "import", "export", "export-default", "export-all", "export-from" node types

import { test, code, fail, type } from '../support/testing.js'

# ==============================================================================
# Import: "import"
# ==============================================================================

# Basic import
code "import default", 'import React from "react"', "import React from 'react';"
code "import named", 'import { useState } from "react"', "import { useState } from 'react';"
code "import namespace", 'import * as Utils from "./utils"', "import * as Utils from './utils';"

# Auto .js extension for local paths
code "import auto .js", 'import foo from "./foo"', "import foo from './foo';"
code "import preserve ext", 'import foo from "./foo.mjs"', "import foo from './foo.mjs';"

# JSON import assertions
code "import json", 'import data from "./config.json"', "import data from './config.json';"

# Multiple imports in one file (import hoisting and path fixing)
code "multiple imports", '''
  import React from "react"
  import { useState } from "react"
  import * as Utils from "./utils"

  x = 42
  console.log x
  ''', '''
  import React from 'react';
  import { useState } from 'react';
  import * as Utils from './utils';
  let x = 42;
  console.log(x);
  '''

# Mixed imports (default + named/namespace)
code "import default and named", 'import React, { useState } from "react"', "import React, { useState } from 'react';"
code "import default and namespace", 'import React, * as ReactDOM from "react-dom"', "import React, * as ReactDOM from 'react-dom';"

# Import aliases
code "import alias", 'import { useState as useS } from "react"', "import { useState as useS } from 'react';"
code "import multiple aliases", 'import { useState as useS, useEffect as useE } from "react"', "import { useState as useS, useEffect as useE } from 'react';"

# ==============================================================================
# Export: "export"
# ==============================================================================

# Export variable
code "export var", "export x = 42", "export const x = 42;"

# Export function
code "export function", "export def add(a, b)\n  a + b", "export function add(a, b) {\n  return (a + b);\n};"

# Named exports
code "export named", "export { x, y }", "export { x, y };"

# Export alias — assigning an existing identifier to a new exported name
code "export alias identifier", '''
  foo = -> 42
  export bar = foo
  ''', '''
  let foo = function() {
    return 42;
  };
  export const bar = foo;
  '''

code "export alias variable", '''
  x = 10
  export y = x
  ''', '''
  let x = 10;
  export const y = x;
  '''

# ==============================================================================
# Export Default: "export-default"
# ==============================================================================

# Export default value
code "export default value", "export default 42", "export default 42;"

# Export default class
code "export default class", "export default class Animal", "export default class Animal {};"

# ==============================================================================
# Export All: "export-all"
# ==============================================================================

# Export all from module
code "export all", 'export * from "./utils"', "export * from './utils';"
code "export all json", 'export * from "./data.json"', "export * from './data.json';"

# ==============================================================================
# Export From: "export-from"
# ==============================================================================

# Export named from module
code "export from", 'export { add, multiply } from "./math"', "export { add, multiply } from './math';"

# ==============================================================================
# Meta Properties (ES6)
# ==============================================================================

# import.meta (ES6 module meta property)
code "import.meta.url", "x = import.meta.url", "let x = import.meta.url;"

# ==============================================================================
# Dynamic Import
# ==============================================================================

code "dynamic import in if expression", '''
  x = if cond
    (await import(url)).default
  else
    null
  ''', "let x = cond ? (await import(url)).default : null;"

code "dynamic import property access", "x = (await import(url)).default", "let x = (await import(url)).default;"

# ==============================================================================
# Statement ordering — exports must not be reordered past non-exports
# ==============================================================================

code "export then reference preserves source order", '''
  export x = 42
  y = x + 1
  ''', '''
  export const x = 42;
  let y = x + 1;
  '''

code 'export class then static assignment preserves order', '''
  export class Foo
    bar: -> 42
  Foo.DEFAULT = 'hello'
  ''', '''
  export class Foo {
    bar() {
      return 42;
    }
  }
  Foo.DEFAULT = 'hello';
'''

code "mixed exports and non-exports preserve source order", '''
    export a = 1
    b = a + 1
    export c = b + 1
  ''', '''
  export const a = 1;
  let b = a + 1;
  export const c = b + 1;
  '''

# ==============================================================================
# Specifier text escapes into the emitted single-quoted form
# ==============================================================================

code "a single quote in a specifier escapes", 'import thing from "./it\'s.js"',
  "import thing from './it\\'s.js';"
