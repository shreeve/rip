# Test: Map literals — `*{ k: v, … }` builds a Map. Identifier keys
# read as strings (the object-key convention); string, number,
# boolean, null, undefined, and regex keys pass through as
# themselves. A spaced `* {` keeps multiplication.

import { test, code, fail, type } from '../support/testing.js'

code 'empty map', '*{}', 'new Map()'

code 'identifier keys', '*{ a: 1, b: 2 }', 'new Map([["a", 1], ["b", 2]])'

code 'string keys', '*{ "hello": 1, "world": 2 }', 'new Map([["hello", 1], ["world", 2]])'

code 'number keys', '*{ 1: \'one\', 2: \'two\' }', 'new Map([[1, \'one\'], [2, \'two\']])'

code 'boolean keys', '*{ true: \'yes\', false: \'no\' }', 'new Map([[true, \'yes\'], [false, \'no\']])'

code 'null key', '*{ null: \'nothing\' }', 'new Map([[null, \'nothing\']])'

code 'undefined key', '*{ undefined: \'nope\' }', 'new Map([[undefined, \'nope\']])'

code 'array values', '*{ a: [1, 2, 3] }', 'new Map([["a", [1, 2, 3]]])'

code 'nested object values', '*{ a: { x: 1 } }', 'new Map([["a", {x: 1}]])'

test 'map is instanceof Map', '*{ a: 1 } instanceof Map', true

test 'map size', '*{ a: 1, b: 2 }.size', 2

test 'empty map size', '*{}.size', 0

test 'get identifier key', '*{ a: 42 }.get("a")', 42

test 'get string key', '*{ "hello": 99 }.get("hello")', 99

test 'get number key', '*{ 1: \'one\' }.get(1)', 'one'

test 'get boolean key', '*{ true: \'yes\' }.get(true)', 'yes'

test 'get null key', '*{ null: \'nil\' }.get(null)', 'nil'

test 'multiline map', '''
  m = *{
    a: 1
    b: 2
    c: 3
  }
  m.size
''', 3

test 'map with computed values', '''
  x = 10
  m = *{ a: x * 2, b: x + 5 }
  m.get("a") + m.get("b")
''', 35

test 'spaced star keeps multiplication', 'x = 3 * {a: 1}\ntypeof x', 'number'
fail 'shorthand has no Map reading', 'a = 1\nm = *{ a }', 'explicit `key: value` pairs'
