# Test: Logical operators inside implicit calls
# Logical operators (or, and, ||, &&, ??) CONTINUE the paren-less call
# argument, exactly like + and the other binary operators, matching
# CoffeeScript: `f a or b` is `f(a or b)`, not `f(a) or b`. To apply a
# logical operator to the call RESULT, parenthesize the call: `(f a) or b`.
#
# `and`/`or` are pure high-precedence aliases of `&&`/`||` — never the
# Ruby low-precedence word-operators — and `??` binds the same way at the
# call boundary. The word forms and symbol forms are interchangeable.

import { test, code, fail } from '../support/testing.js'

# ==============================================================================
# or (||) continues the implicit-call argument
# ==============================================================================

# `fn 'hello' or 'default'` is `fn('hello' or 'default')`; 'hello' is
# truthy so `or` short-circuits and the call still sees 'hello'.
test "or truthy operand stays in the arg", "fn = (x) -> x\nfn 'hello' or 'default'", "hello"

# A falsy operand lets `or` reach the default — inside the argument.
test "or falsy operand falls to default in the arg", "fn = (x) -> x\nfn '' or 'default'", "default"

# The operator binds the LAST argument, leaving earlier args intact.
test "or binds only the trailing arg", "fn = (a, b) -> a + b\nfn 'a', 'b' or 'default'", "ab"

# ==============================================================================
# and (&&) continues the implicit-call argument
# ==============================================================================

test "and truthy operand yields the second in the arg", "fn = (x) -> x\nfn 'hello' and 'yes'", "yes"
test "and falsy operand yields the first in the arg", "fn = (x) -> x\nfn '' and 'yes'", ""
test "and binds only the trailing arg", "fn = (a, b) -> a + b\nfn 'a', 'b' and 'result'", "aresult"

# ==============================================================================
# nullish (??) continues the implicit-call argument — mirrors || / &&
# ==============================================================================

test "?? present operand stays in the arg", "fn = (x) -> x\nfn 'hello' ?? 'default'", "hello"
test "?? nullish operand falls to default in the arg", "fn = (x) -> x\nfn null ?? 'default'", "default"

# ?? does NOT fall through on falsy-but-present values (unlike ||)
test "?? keeps empty string from the operand", "fn = (x) -> x\nfn '' ?? 'default'", ""
test "?? keeps zero from the operand", "fn = (x) -> x\nfn 0 ?? 99", 0

# ?? parses the same as || / && at the call boundary: into the argument.
code "?? continues the argument like or", '''
  fn = (x) -> x
  x = fn null ?? 'd'
  ''', '''
  let x;

  let fn = function(x) {
    return x;
  };
  x = fn(null ?? "d");
  '''

# The operator binds the last arg while more args follow.
test "?? in the trailing arg with none after", "fn = (a, b) -> (a ?? 'y') + ':' + b\nfn null ?? 'y', 'z'", "y:z"

# ==============================================================================
# Explicit parens apply the operator to the CALL RESULT
# ==============================================================================

# To fall back on the call's return value, parenthesize the call.
test "parens make or apply to the result", "fn = (x) -> null\n(fn 'x') or 'default'", "default"
test "parens make ?? apply to the result", "fn = (x) -> null\n(fn 'x') ?? 'default'", "default"

# Parens the other way group the operator inside a single argument.
test "parens preserve or inside an arg", "fn = (x) -> x\nfn (true || false)", true
test "parens preserve and inside an arg", "fn = (x) -> x\nfn (true && false)", false

# ==============================================================================
# Chains need parens to fall back on each call's result
# ==============================================================================

# Without parens the outer call swallows the whole chain as its argument:
# `fn 'a' or fn 'b' or 'c'` is `fn('a' or fn('b' or 'c'))` → fn('a') → null.
test "unparenthesized chain feeds the outer call", "fn = (x) -> null\nfn 'a' or fn 'b' or 'c'", null

# Parenthesizing each call restores the fallback chain.
test "parenthesized chain falls through to the last", "fn = (x) -> null\n(fn 'a') or (fn 'b') or 'c'", "c"

# ==============================================================================
# or/and INSIDE implicit objects (unchanged — the value binds the operator)
# ==============================================================================

test "or in object value", "foo = null\nx = { a: foo or 'default' }\nx.a", "default"
test "or in object with truthy", "foo = 'yes'\nx = { a: foo or 'default' }\nx.a", "yes"
test "and in object value truthy", "foo = 'yes'\nx = { a: foo and 'result' }\nx.a", "result"
test "and in object value falsy", "foo = null\nx = { a: foo and 'result' }\nx.a", null
test "multiple props with or", "foo = null\nx = { a: foo or 'A', b: 'B' }\nx.a + x.b", "AB"
test "multiple props with and", "foo = 'yes'\nx = { a: foo and 'A', b: 'B' }\nx.a + x.b", "AB"
test "nested object with or", "foo = null\nx = { outer: { inner: foo or 'default' } }\nx.outer.inner", "default"
test "?? in object value", "foo = null\nx =\n  a: foo ?? 'default'\n  b: 'other'\nx.a + x.b", "defaultother"

# Multi-line implicit object with or (the operator binds the pair's value)

code "multiline object with or", '''
      foo = null
      x =
        a: foo or 'default'
        b: 'other'
      x.a + x.b
  ''', '''
  let foo = null;
  let x = {a: (foo || "default"), b: "other"};
  x.a + x.b;
  '''

test "multiline object with or runtime", "foo = null\nx = { a: foo or 'default', b: 'other' }\nx.a + x.b", "defaultother"

# Real-world pattern: Response headers with defaults (an explicit call,
# so `or` applies to its result inside the object value).
test "headers with or defaults", """
  req = { headers: { get: (k) -> null } }
  headers =
    'Access-Control-Allow-Origin': req.headers.get('origin') or '*'
    'Content-Type': 'text/plain'
  headers['Access-Control-Allow-Origin']
""", "*"

# ==============================================================================
# Logical operators in earlier args, with more args after
# ==============================================================================

test "or in first arg with more", "fn = (a, b) -> a + ':' + b\nfn 'x' or 'y', 'z'", "x:z"
test "or in first arg falsy with more", "fn = (a, b) -> a + ':' + b\nfn null or 'y', 'z'", "y:z"
test "Response with or in body", "Response = (b, o) -> { body: b, status: o.status }\nResponse 'ok' or 'error', { status: 200 }", { body: "ok", status: 200 }
test "Response with or in body falsy", "Response = (b, o) -> { body: b, status: o.status }\nResponse null or 'error', { status: 500 }", { body: "error", status: 500 }
test "and in first arg with more", "fn = (a, b) -> b\nfn true and 'x', 'y'", "y"
test "mixed or comma pattern", "fn = (a, b, c) -> a + b + c\nfn 'a' or 'A', 'b' or 'B', 'c' or 'C'", "abc"

# ==============================================================================
# Postfix if/unless with implicit function calls
# ==============================================================================

test "return unless falsy", "fn = (sql) ->\n  return 'error' unless sql\n  'success'\nfn null", "error"
test "return unless truthy", "fn = (sql) ->\n  return 'error' unless sql\n  'success'\nfn 'data'", "success"
test "return nested calls unless falsy", "fn = (sql) ->\n  return outer inner 'error' unless sql\n  'success'\nouter = (x) -> x\ninner = (x) -> x\nfn null", "error"
test "return nested calls unless truthy", "fn = (sql) ->\n  return outer inner 'error' unless sql\n  'success'\nouter = (x) -> x\ninner = (x) -> x\nfn 'data'", "success"
test "return if truthy", "fn = (flag) ->\n  return 'early' if flag\n  'normal'\nfn true", "early"
test "return if falsy", "fn = (flag) ->\n  return 'early' if flag\n  'normal'\nfn false", "normal"

# code generation tests

code "return unless generates if statement", """
  f = ->
    return binaryResponse serializeErrorResult 'Error' unless sql
""", """
let f = function() {
  if (!sql) {
    return binaryResponse(serializeErrorResult("Error"));
  }
};
"""

code "return if generates if statement", """
  f = ->
    return handleError 'Not found' if notFound
""", """
let f = function() {
  if (notFound) {
    return handleError("Not found");
  }
};
"""

# ==============================================================================
# Parenthesized sequences (multiple statements)
# ==============================================================================

test "paren sequence returns last", "x = (1; 2; 3)\nx", 3
test "paren sequence with side effect", "i = 0\nx = (i++; i++; i)\nx", 2
test "break in parens", "i = 0\nwhile i < 10\n  if i is 5 then (i++; break)\n  i++\ni", 6
test "continue in parens", "sum = 0\nfor i in [1..5]\n  if i is 3 then (sum += 100; continue)\n  sum += i\nsum", 112

# ==============================================================================
# Ternary nesting — parenthesized branches pair their own colons
# ==============================================================================

test "a parenthesized ternary in the then-branch", '''
  a = 1
  b = 0
  a ? (b ? 2 : 3) : 4
''', 3

test "a ternary chained in the else-branch", '''
  a = 0
  c = 2
  a ? 1 : c ? 3 : 4
''', 3

test "ternary branches may build objects", '''
  t = true
  v = t ? {a: 1} : {b: 2}
  v.a
''', 1

test "a ternary condition keeps its parens", '''
  a = true
  b = false
  c = true
  (a ? b : c) ? 1 : 2
''', 2

code "ternary-condition grouping", "x = (a ? b : c) ? 1 : 2", "let x = (a ? b : c) ? 1 : 2;"

# A `return` guard is a statement, so it cannot ride inside a call
# argument: `read 'body' ?? return 'empty'` now feeds the call, which
# puts the guard in value position — the emitter rejects it. Bind the
# call's result first (`(read 'body') ?? return 'empty'`) instead.
fail "?? return inside an implicit call is a value-position guard", '''
  read = (k) -> null
  fn = ->
    sql = read 'body' ?? return 'empty'
    'got: ' + sql
  fn()
  '''

# Parenthesizing the call restores the guard: the result is nullish, so
# the guard fires and the function returns 'empty'.
test "?? return on a parenthesized call result", '''
  read = (k) -> null
  fn = ->
    sql = (read 'body') ?? return 'empty'
    'got: ' + sql
  fn()
  ''', 'empty'
