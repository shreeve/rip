''', true

test 'Link renders anchor with defaults', '''
  emailPkg = import!("#{process.cwd()}/packages/ui/email/email.rip")
  { toHTML } = emailPkg
  { Link } = emailPkg
  E = component
    render
      Link href: "https://example.com"
        "click"
  result = toHTML(E)
  result.includes('href="https://example.com"') and result.includes('target="_blank"') and result.includes('click')
''', true

test 'Image renders img with safe defaults', '''
