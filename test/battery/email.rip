# Public email authoring surface.

import { test, code, fail, type } from '../support/testing.js'

test 'Email renders html tag with lang and dir', '''
  email = import!("#{process.cwd()}/packages/ui/email/email.rip")
  { toHTML, Email } = email
  E = component
    render
      Email
  result = toHTML(E)
  result.includes('lang="en"') and result.includes('dir="ltr"') and result.includes('<html')
''', true

test 'Head renders meta tags', '''
  email = import!("#{process.cwd()}/packages/ui/email/email.rip")
  { toHTML, Email, Head } = email
  E = component
    render
      Email
        Head
  result = toHTML(E)
  result.includes('charset=UTF-8') and result.includes('x-apple-disable-message-reformatting')
''', true

test 'Body renders table wrapper', '''
  email = import!("#{process.cwd()}/packages/ui/email/email.rip")
  { toHTML, Email, Body } = email
  E = component
    render
      Email
        Body
          p "content"
  result = toHTML(E)
  result.includes('role="presentation"') and result.includes('<p>content</p>')
''', true

test 'Preview renders hidden div with padding', '''
  email = import!("#{process.cwd()}/packages/ui/email/email.rip")
  { toHTML, Preview } = email
  E = component
    render
      Preview text: "Hello preview"
  result = toHTML(E)
  result.includes('display:none') and result.includes('Hello preview')
''', true

test 'Container renders centered table', '''
