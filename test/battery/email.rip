test 'toHTML returns string with doctype', '''
  emailRender = import!("#{process.cwd()}/packages/ui/email/render.rip")
  { toHTML } = emailRender
  TestEmail = component
    render
      html
        body
          p "hello"
  result = toHTML(TestEmail)
  result.includes('<!DOCTYPE') and result.includes('<p>hello</p>')
''', true

test 'toText returns plain text string', '''
  emailRender = import!("#{process.cwd()}/packages/ui/email/render.rip")
