''', true

test 'toEmail returns html and text', '''
  emailRender = import!("#{process.cwd()}/packages/ui/email/render.rip")
  { toEmail } = emailRender
  TestEmail = component
    render
      div
        h1 "Title"
        p "Body"
  { html, text } = toEmail(TestEmail)
  html.includes('<h1>Title</h1>') and text.includes('Title') and text.includes('Body')
''', true

