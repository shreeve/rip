test 'Button renders anchor with MSO conditionals', '''
  emailPkg = import!("#{process.cwd()}/packages/ui/email/email.rip")
  { toHTML } = emailPkg
  { Button } = emailPkg
  E = component
    render
      Button href: "https://example.com", style: "padding:12px 20px;background:#111;color:#fff"
        "Click me"
  result = toHTML(E)
  result.includes('href="https://example.com"') and result.includes('Click me') and result.includes('mso-font-width')
''', true

test 'Markdown renders paragraphs', '''
  emailPkg = import!("#{process.cwd()}/packages/ui/email/email.rip")
  { toHTML } = emailPkg
  { Markdown } = emailPkg
  E = component
    render
      Markdown text: "Hello world"
  toHTML(E).includes('<p>Hello world</p>')
''', true

test 'Markdown renders bold and italic', '''
  emailPkg = import!("#{process.cwd()}/packages/ui/email/email.rip")
  { toHTML } = emailPkg
  { Markdown } = emailPkg
  E = component
    render
      Markdown text: "This is **bold** and *italic*"
  result = toHTML(E)
  result.includes('<strong>bold</strong>') and result.includes('<em>italic</em>')
''', true

test 'Markdown renders headings', '''
  emailPkg = import!("#{process.cwd()}/packages/ui/email/email.rip")
  { toHTML } = emailPkg
  { Markdown } = emailPkg
  E = component
    render
      Markdown text: "# Title"
  toHTML(E).includes('<h1>Title</h1>')
''', true

test 'Markdown renders links', '''
  emailPkg = import!("#{process.cwd()}/packages/ui/email/email.rip")
  { toHTML } = emailPkg
  { Markdown } = emailPkg
  E = component
    render
      Markdown text: "Visit [Example](https://example.com)"
  toHTML(E).includes('<a href="https://example.com"')
''', true

test 'Markdown renders unordered lists', '''
  emailPkg = import!("#{process.cwd()}/packages/ui/email/email.rip")
  { toHTML } = emailPkg
  { Markdown } = emailPkg
  E = component
    render
      Markdown text: "- one\\n- two\\n- three"
  result = toHTML(E)
  result.includes('<ul>') and result.includes('<li>one</li>')
''', true

test 'CodeBlock renders pre with code', '''
  emailPkg = import!("#{process.cwd()}/packages/ui/email/email.rip")
  { toHTML } = emailPkg
  { CodeBlock } = emailPkg
  E = component
    render
      CodeBlock code: "x = 42"
  result = toHTML(E)
  result.includes('<pre') and result.includes('x = 42')
''', true

test 'CodeBlock escapes HTML in code', '''
  emailPkg = import!("#{process.cwd()}/packages/ui/email/email.rip")
  { toHTML } = emailPkg
  { CodeBlock } = emailPkg
  E = component
    render
      CodeBlock code: "<div>hi</div>"
  result = toHTML(E)
  result.includes('&lt;div&gt;')
''', true

test 'CodeInline renders code with Orange.fr workaround', '''
  emailPkg = import!("#{process.cwd()}/packages/ui/email/email.rip")
  { toHTML } = emailPkg
  { CodeInline } = emailPkg
  E = component
    render
      CodeInline
        "hello"
  result = toHTML(E)
  result.includes('class="cino"') and result.includes('class="cio"') and result.split('hello').length is 3
''', true

test 'Tailwind injects generated CSS for raw HTML tag classes', '''
  emailPkg = import!("#{process.cwd()}/packages/ui/email/email.rip")
  { toHTML } = emailPkg
  { Email, Head, Tailwind } = emailPkg
  E = component
    render
      Email
        Head
        Tailwind
          p class: "text-gray-400 bg-gray-100 px-4 py-2 rounded-lg"
            "styled"
  result = toHTML(E)
  result.includes('color:oklch(70.7% 0.022 261.325)') and result.includes('background-color:oklch(96.7% 0.003 264.542)') and result.includes('padding-inline:calc(0.25rem*4)') and result.includes('padding-block:calc(0.25rem*2)') and result.includes('border-radius:0.5rem')
''', true

test 'Tailwind injects generated CSS for PascalCase component classes', '''
  emailPkg = import!("#{process.cwd()}/packages/ui/email/email.rip")
  { toHTML } = emailPkg
  { Email, Head, Tailwind, Text, Button } = emailPkg
  E = component
    render
      Email
        Head
        Tailwind
          Text class: "text-center text-gray-600"
            "hello"
          Button class: "rounded-full bg-black text-white", href: "https://example.com", style: "padding:12px 20px"
            "go"
  result = toHTML(E)
  result.includes('text-align:center') and result.includes('color:oklch(44.6% 0.03 256.802)') and result.includes('background-color:#000') and result.includes('color:#fff') and result.includes('border-radius:calc(infinity*1px)')
''', true

test 'Tailwind keeps unsupported classes', '''
  emailPkg = import!("#{process.cwd()}/packages/ui/email/email.rip")
  { toHTML } = emailPkg
  { Email, Head, Tailwind } = emailPkg
  E = component
    render
      Email
        Head
        Tailwind
          div class: "sm:text-lg custom-class"
            "x"
  result = toHTML(E)
  result.includes('class="sm:text-lg custom-class"') and result.includes('@media') and result.includes('text-lg')
''', true

test 'full email renders correctly', '''
  emailPkg = import!("#{process.cwd()}/packages/ui/email/email.rip")
  { toHTML } = emailPkg
  { Email, Head, Body, Preview, Container, Heading, Text, Link, Divider } = emailPkg
  WelcomeEmail = component
    @name =! "World"
    render
      Email
        Head
        Preview text: "Welcome aboard"
        Body
          Container
            Heading "Welcome, #{@name}!"
            Text "Thanks for signing up."
            Link href: "https://example.com"
              "Get started"
            Divider
            Text "See you soon."
  result = toHTML(WelcomeEmail, name: "Alice")
  result.includes('<!DOCTYPE') and result.includes('Welcome, Alice!') and result.includes('charset=UTF-8') and result.includes('max-width:37.5em') and result.includes('Get started') and result.includes('border-top:1px solid')
''', true

test 'full email plain text', '''
  emailPkg = import!("#{process.cwd()}/packages/ui/email/email.rip")
  { toText } = emailPkg
  { Email, Head, Body, Container, Heading, Text, Link, Divider } = emailPkg
  WelcomeEmail = component
    @name =! "World"
    render
      Email
        Head
        Body
          Container
            Heading "Welcome, #{@name}!"
            Text "Thanks for signing up."
            Link href: "https://example.com"
              "Get started"
  result = toText(WelcomeEmail, name: "Bob")
  result.includes('Welcome, Bob!') and result.includes('Get started (https://example.com)')
''', true

test 'toEmail with conditional', '''
  emailPkg = import!("#{process.cwd()}/packages/ui/email/email.rip")
  { toEmail } = emailPkg
  TestEmail = component
    @show =! true
    render
      div
        if @show
          p "visible"
  { html } = toEmail(TestEmail, show: true)
  html.includes('<p>visible</p>')
''', true

test 'toEmail with nested native tags', '''
  emailPkg = import!("#{process.cwd()}/packages/ui/email/email.rip")
  { toEmail } = emailPkg
  TestEmail = component
    render
      table role: "presentation", border: "0", cellpadding: "0", cellspacing: "0"
        tbody
          tr
            td
              p "content"
  { html } = toEmail(TestEmail)
  html.includes('<table') and html.includes('<td><p>content</p></td>')
''', true

test 'toEmail plain text output', '''
  emailPkg = import!("#{process.cwd()}/packages/ui/email/email.rip")
  { toEmail } = emailPkg
  TestEmail = component
    render
      div
        h1 "Title"
        p "Body text"
        a href: "https://example.com", "Click"
  { text } = toEmail(TestEmail)
  text.includes('Title') and text.includes('Body text') and text.includes('Click (https://example.com)')
''', true
