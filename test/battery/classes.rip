# Test: Classes (2 node types)
# Tests "class" and "super" node types

import { test, code, fail, type } from '../support/testing.js'

# ==============================================================================
# Class Definitions: "class"
# ==============================================================================

# Class with methods
test "class methods", "class Math\n  add: (a, b) -> a + b\n  multiply: (a, b) -> a * b\nm = new Math(); m.add(2, 3)", 5

# Static methods
test "static method", "class Utils\n  @square: (x) -> x * x\nUtils.square(5)", 25

# Class with constructor logic
test "constructor logic", "class Counter\n  constructor: ->\n    @count = 0\n  increment: -> @count += 1\nc = new Counter(); c.increment(); c.count", 1

# ==============================================================================
# Super Calls: "super"
# ==============================================================================

# Super method call
test "super method call", "class Animal\n  speak: -> 'sound'\nclass Dog extends Animal\n  speak: -> super.speak() + '!'\nd = new Dog(); d.speak()", "sound!"

# Super with spread arguments (Rip ES6 prefix syntax)

test "super with spread args", '''
  class Parent
    method: (...args) -> args.join('-')

  class Child extends Parent
    method: -> super(...arguments)

  c = new Child()
  c.method(1, 2, 3)
''', '1-2-3'

# ==============================================================================
# More Class Features
# ==============================================================================

# Class expressions

test 'class expression', '''
  Animal = class
    speak: -> 'sound'
  new Animal().speak()
  ''', 'sound'

# Empty class

test 'empty class', '''
  class Empty
  new Empty().constructor.name
  ''', 'Empty'

# Method chaining

test 'method chaining', '''
  class Builder
    setValue: (v) -> @value = v; this
    getValue: -> @value
  new Builder().setValue(42).getValue()
  ''', 42

# Bound methods

test 'bound method', '''
  class Counter
    constructor: -> @count = 0
    increment: => @count++
  c = new Counter()
  fn = c.increment
  fn()
  c.count
  ''', 1

# instanceof

test 'instanceof check', '''
  class Animal
  a = new Animal()
  a instanceof Animal
  ''', true

# Override method

test 'override method', '''
  class Animal
    speak: -> 'sound'
  class Dog extends Animal
    speak: -> 'bark'
  new Dog().speak()
  ''', 'bark'

# Constructor explicit return

test 'constructor explicit return', '''
  class A
    constructor: ->
      return {custom: 'object'}
  new A().custom
  ''', 'object'

# Async method

test 'async method', '''
  class Async
    getData: -> await Promise.resolve(42)
  do ->
    await new Async().getData()
  ''', 42

# Four-level inheritance

test 'four-level inheritance', '''
  class A
    val: -> 'a'
  class B extends A
  class C extends B
  class D extends C
  new D().val()
  ''', 'a'

# ==============================================================================
# Ruby-style Constructor: XXX.new()
# ==============================================================================

# Code generation
code "ruby-style new", "Counter.new()", "new Counter();"
code "ruby-style new args", "Counter.new(1, 2)", "new Counter(1, 2);"
code "ruby-style new expression", "getClass().new(x)", "new (getClass())(x);"

# ==============================================================================
# Meta Properties
# ==============================================================================

# ==============================================================================
# Class with additional statements (object body + nested class/extra stmts)
# @param, bound methods, and async must work even with extra statements present
# ==============================================================================

# ==============================================================================
# Class name restriction
# ==============================================================================
# `class App.Sub` and `class arr[0]` used to parse but produce broken JS
# (`class .,App,Sub`) because the codegen interpolated the array-shaped name
# into a `class ${name}` template. The grammar now restricts class names to
# Identifier or ThisProperty (the latter enabling nested static classes).

fail "class with member-access name does not parse",
  'class App.Sub'

fail "class with index name does not parse", '''
  arr = []
  class arr[0]
  '''

# ==============================================================================
# new.target — the meta-property distinguishes construction from a plain call
# ==============================================================================

test "new.target in constructor", '''
  class A
    constructor: ->
      @viaNew = new.target isnt undefined
  new A().viaNew
''', true

code "new.target passes through", "class A\n  constructor: ->\n    @t = new.target", "class A {\n  constructor() {\n    this.t = new.target;\n  }\n};"

# ==============================================================================
# Promoted Parameters — constructor: (@name) -> assigns this.name; inside a
# leading super(...) call @name reads the parameter (this is not yet available)
# ==============================================================================

test 'basic class', '''
  class Animal
    constructor: (@name) ->
    speak: -> @name
  a = new Animal('Dog'); a.speak()
''', 'Dog'

test 'class inheritance', '''
  class Animal
    constructor: (@name) ->
  class Dog extends Animal
    bark: -> 'woof'
  d = new Dog('Spot'); d.name
''', 'Spot'

code 'simple class', '''
  class Animal
    constructor: (@name) ->
''', 'class Animal { constructor(name) { this.name = name; } }'

test 'super in constructor', '''
  class Animal
    constructor: (@name) ->
  class Dog extends Animal
    constructor: (name, @breed) ->
      super(name)
  d = new Dog('Spot', 'Terrier'); d.name
''', 'Spot'

test 'multiple @ parameters', '''
  class Person
    constructor: (@first, @last) ->
  p = new Person('John', 'Doe')
  [p.first, p.last]
''', ['John', 'Doe']

test 'promoted parameter with default', '''
  class P
    constructor: (@x = 5) ->
  [new P().x, new P(9).x]
  ''', [5, 9]

test 'promoted beside plain parameters', '''
  class M
    constructor: (@a, b, @c) ->
      @sum = @a + b + @c
  new M(1, 2, 3).sum
  ''', 6

test 'subclass super with promoted parameter', '''
  class Animal
    constructor: (@name) ->
  class Dog extends Animal
    constructor: (@name) -> super(@name)
  new Dog('Spot').name
  ''', 'Spot'

fail 'promoted parameter rejects outside constructors', 'f = (@x) -> 1', 'promotes only in a constructor'
fail 'promoted parameter rejects in plain methods', 'class A\n  m: (@x) -> 1', 'promotes only in a constructor'

test 'super with @param', '''
  class Animal
    constructor: (@name) ->
  class Dog extends Animal
    constructor: (@name) -> super @name, "woof"
  d = Dog.new "Rex"
  d.name
''', 'Rex'

test '@param with default', '''
  class Counter
    constructor: (@count = 0) ->
  c = Counter.new 10
  c.count
''', 10

test '@param default no args', '''
  class Counter
    constructor: (@count = 0) ->
  c = Counter.new()
  c.count
''', 0

test 'ruby-style new chained', '''
  class Builder
    constructor: (@val) ->
    get: -> @val
  Builder.new(42).get()
''', 42

# ==============================================================================
# Static inner classes — class @Name inside a class body is
# static Name = class [extends P] { … }; the top-level form rejects
# ==============================================================================

test '@param works with extra statements', '''
  class Animal
    constructor: (@name) ->
    speak: -> @name
    class @Baby
      cry: -> "waa"
  a = new Animal('Dog')
  [a.name, a.speak(), Animal.Baby?]
''', ['Dog', 'Dog', true]

test 'subclass @param works with extra statements', '''
  class Base
    constructor: (@id) ->
  class Sub extends Base
    constructor: (id, @label) ->
      super(id)
    class @Helper
      help: -> true
  s = new Sub(1, 'x')
  [s.id, s.label]
''', [1, 'x']

test 'bound method works with extra statements', '''
  class Handler
    constructor: ->
      @count = 0
    onClick: => @count += 1
    class @Util
      noop: ->
  h = new Handler()
  fn = h.onClick
  fn()
  h.count
''', 1

test 'async method works with extra statements', '''
  class Svc
    fetch: -> await Promise.resolve(42)
    class @Inner
      noop: ->
  do ->
    s = new Svc()
    await s.fetch()
''', 42

test 'static inner class extends', '''
  class Animal
    constructor: (@name) ->
  class Ext
    class @Kid extends Animal
      who: -> @name
  new Ext.Kid('kid').who()
  ''', 'kid'

fail 'class @Name rejects at the top level', 'class @Top\n  x: -> 1', 'STATIC member class'
