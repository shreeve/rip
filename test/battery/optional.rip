# Test: Optional Chaining, Existence Check, and Nullish Coalescing
# Tests postfix ? existence, ES6 optional chaining (?.), and ?? operators

import { test, code, fail, type } from '../support/testing.js'

# ==============================================================================
# Existence Check: "?" (postfix)
# ==============================================================================

# Pattern: expr? → (expr != null)
test "existence check value", "x = 42\nx?", true
test "existence check null", "x = null\nx?", false
test "existence check undefined", "x = undefined\nx?", false

# Existence in conditional
test "if exists", "x = 42; if x? then 'exists' else 'missing'", "exists"
test "if not exists", "x = null; if x? then 'exists' else 'missing'", "missing"

# Code generation
code "existence check", "x?", "x != null;"

# Existence after subscript access: arr[i]?
test "existence subscript", "arr = [1, 2, 3]; arr[0]?", true
test "existence subscript undefined", "arr = [1, 2, 3]; arr[99]?", false
test "existence subscript null element", "arr = [null]; arr[0]?", false
test "existence subscript expression", "arr = [10, 20]; arr[1 - 1]?", true

code "existence subscript gen", "arr[0]?", "arr[0] != null;"

# Existence after function call: fn()?
test "existence call", "fn = -> 42\nfn()?", true
test "existence call null", "fn = -> null\nfn()?", false
test "existence call undefined", "fn = -> undefined\nfn()?", false

code "existence call gen", "fn()?", "fn() != null;"

# Existence after property access (already works, but verify compound)
test "existence deep subscript", "obj = {a: [1, 2]}; obj.a[0]?", true
test "existence deep subscript null", "obj = {a: [null]}; obj.a[0]?", false

# ==============================================================================
# DOT-BASED ?. - ES6 Optional Chaining (Native Passthrough)
# ==============================================================================

# Optional property: "?."
# Pattern: obj?.prop → obj?.prop (ES6 native)
test "optional prop exists", "obj = {name: 'test'}\nobj?.name", "test"
test "optional prop null", "obj = null\nobj?.name", undefined
test "optional prop undefined", "obj = undefined\nobj?.prop", undefined
test "optional prop chain", "obj = {nested: {value: 42}}\nobj?.nested?.value", 42
test "optional prop chain breaks", "obj = {nested: null}\nobj?.nested?.value", undefined

# Optional index (ES6): ES6 native optional chaining
# Pattern: arr?.[index] → arr?.[index] (ES6 native)
test "es6 optional index exists", "arr = [1, 2, 3]\narr?.[1]", 2
test "es6 optional index null", "arr = null\narr?.[0]", undefined
test "es6 optional index chain", "obj = {arr: [1, 2]}\nobj?.arr?.[0]", 1

# Optional index without dot: arr?[index] → arr?.[index]
test "optional index no dot", "arr = [1, 2, 3]\narr?[1]", 2
test "optional index no dot null", "arr = null\narr?[0]", undefined
test "optional index no dot chain", "obj = {arr: [1, 2]}\nobj?.arr?[0]", 1

code "optional index no dot gen", "arr?[0]", "arr?.[0]"

# Optional call (ES6): ES6 native optional chaining
# Pattern: fn?.(arg) → fn?.(arg) (ES6 native)
test "es6 optional call exists", "fn = (x) -> x * 2\nfn?.(5)", 10
test "es6 optional call null", "fn = null\nfn?.(5)", undefined
test "es6 optional call chain", "obj = {fn: (x) -> x}\nobj?.fn?.(42)", 42

# Optional call without dot: fn?(arg) → fn?.(arg)
test "optional call no dot", "fn = (x) -> x * 2\nfn?(5)", 10
test "optional call no dot null", "fn = null\nfn?(5)", undefined
test "optional call no dot chain", "obj = {fn: (x) -> x}\nobj?.fn?(42)", 42

code "optional call no dot gen", "fn?(42)", "fn?.(42)"

# ==============================================================================
# Optional Chaining in Expressions
# ==============================================================================

test "optional with default", "obj = {val: 5}\nobj?.val ?? 10", 5
test "optional null with default", "obj = null\nobj?.val ?? 10", 10

# Optional in assignments
test "optional assign", "obj = {val: 42}\nx = obj?.val\nx", 42

# ==============================================================================
# CODE GENERATION TESTS
# ==============================================================================

# ES6 optional chaining (?.) - Passthrough to native
code "optional property gen", "obj?.prop", "obj?.prop"
code "es6 optional index gen", "arr?.[0]", "arr?.[0]"
code "es6 optional call gen", "fn?.(42)", "fn?.(42)"

# ==============================================================================
# Nullish Coalescing (??)
# ==============================================================================

# These tests are Rip-specific, showing how to use ?? (ES2020)

# Splat with nullish coalescing

test "splat existential with default", '''
  c = null
  [...(c?.b ?? [])]
''', []

test "splat with value", '''
  c = {b: [1, 2, 3]}
  [...(c?.b ?? [])]
''', [1, 2, 3]

test "conditional with nullish", '''
  a = {b: [3]}
  f = false
  result = (a if f)?.b ?? []
  result
''', []

test "trailing if with nullish default", '''
  a = [3]
  c = false
  result = (a if c) ?? []
  result
''', []

# ==============================================================================
# Optional-chain assignment evaluates its receiver exactly once
# ==============================================================================

test "the guard and the write see the same object", '''
  objects = [{x: 0}, {x: 0}]
  i = -1
  get = -> objects[++i]
  get()?.x = 7
  [objects[0].x, objects[1].x, i]
''', [7, 0, 0]

test "a nullish receiver skips the write after one evaluation", '''
  n = 0
  get = ->
    n += 1
    null
  get()?.x = 7
  n
''', 1

code "a member receiver captures once for the guard", "o.a?.x = 5", "if ((_ref = o.a) != null) _ref.x = 5;"
code "a bound plain-name receiver keeps the plain guard", "o = null\no?.x = 5", "let o = null;\nif (o != null) o.x = 5;"

# ==============================================================================
# Optional assignment — single evaluation, native order, control preservation.
# The optional receiver evaluates exactly once: the null check and the write
# see the SAME object. Computed keys, target reads, and the RHS evaluate only
# when the receiver is non-nullish, and exactly once.
# ==============================================================================

test 'optional assign reads a getter receiver once', '''
  n = 0
  a = {x: 0}
  b = {x: 0}
  o = {}
  Object.defineProperty o, 'p', get: ->
    n += 1
    if n is 1 then a else b
  o.p?.x = 7
  [a.x, b.x, n]
  ''', [7, 0, 1]

test 'optional native compound reads its receiver once', '''
  n = 0
  target = {x: 10}
  o = {}
  Object.defineProperty o, 'p', get: ->
    n += 1
    target
  o.p?.x += 5
  [target.x, n]
  ''', [15, 1]

test 'optional index assign evaluates its computed key once', '''
  n = 0
  key = -> (n += 1; 0)
  o = {a: [9]}
  o?.a[key()] //= 2
  [o.a[0], n]
  ''', [4, 1]

test 'optional nested computed keys evaluate once each', '''
  ki = 0
  kj = 0
  i = -> (ki += 1; 0)
  j = -> (kj += 1; 1)
  o = {a: [[3, 9]]}
  o?.a[i()][j()] //= 3
  [o.a[0][1], ki, kj]
  ''', [3, 1, 1]

test 'optional complex receiver and computed key evaluate once', '''
  rn = 0
  kn = 0
  recv = -> (rn += 1; {a: [8]})
  key = -> (kn += 1; 0)
  recv()?.a[key()] //= 2
  [rn, kn]
  ''', [1, 1]

test 'optional compound skips key and value when receiver is nullish', '''
  keyN = 0
  rhsN = 0
  key = -> (keyN += 1; 0)
  rhs = -> (rhsN += 1; 2)
  o = null
  o?.a[key()] //= rhs()
  [keyN, rhsN]
  ''', [0, 0]

test 'optional assign value position yields the assigned value', '''
  o = {p: {x: 0}}
  r = (o.p?.x = 7)
  [r, o.p.x]
  ''', [7, 7]

test 'optional assign value position yields undefined on nullish', '''
  o = {p: null}
  r = (o.p?.x = 7)
  r is undefined
  ''', true

test 'optional assign with impure receiver preserves yield', '''
  get = -> {x: 0}
  f = ->
    v = yield 1
    get()?.x = yield 2
    'done'
  g = f()
  [g.next().value, g.next(10).value, g.next(20).value]
  ''', [1, 2, 'done']

test 'optional assign with impure receiver preserves await', '''
  o = {p: {x: 0}}
  set = -> o.p
  set()?.x = await Promise.resolve(7)
  o.p.x
  ''', 7

test 'optional assign temps dodge user bindings', '''
  _ref = 'mine'
  _o = 'also mine'
  _k = 'still mine'
  n = 0
  get = -> (n += 1; {x: 1})
  get()?.x = 5
  [_ref, _o, _k, n]
  ''', ['mine', 'also mine', 'still mine', 1]

test 'unresolved identifier may be a global accessor - reads once', '''
  n = 0
  desc = {configurable: true}
  desc.get = ->
    n += 1
    {x: 0}
  Object.defineProperty globalThis, '__hardenProbe', desc
  __hardenProbe?.x = 5
  count = n
  Reflect.deleteProperty globalThis, '__hardenProbe'
  count
  ''', 1
