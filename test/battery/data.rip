# Test: The __DATA__ marker — everything after a line that is exactly
# __DATA__ is the program's DATA constant: raw text, never parsed,
# bound below any leading imports.

import { test, code, fail, type } from '../support/testing.js'

test 'data marker length', '''
  DATA.length
  __DATA__
  test
''', 5

test 'data marker empty', '''
  DATA
  __DATA__
''', ''

test 'data marker multiline', '''
  lines = DATA.split("\\n").filter (l) -> l
  lines.length
  __DATA__
  line1
  line2
  line3
''', 3

test 'data marker first line', '''
  DATA.split("\\n")[0]
  __DATA__
  first
  second
''', 'first'

test 'data marker last line', '''
  lines = DATA.trim().split("\\n")
  lines[lines.length - 1]
  __DATA__
  first
  second
  last
''', 'last'

test 'data marker config', '''
  config = {}
  for line in DATA.split("\\n") when line.trim()
    [key, val] = line.split("=")
    config[key] = val
  config.port
  __DATA__
  host=localhost
  port=8080
  debug=true
''', '8080'

test 'data marker csv', '''
  rows = DATA.trim().split("\\n").map (line) ->
    line.split(",")
  rows[0][0]
  __DATA__
  Alice,alice@example.com
  Bob,bob@example.com
''', 'Alice'

test 'data marker special chars', '''
  DATA.includes("@")
  __DATA__
  test@example.com
''', true

test 'data marker quotes', '''
  DATA.includes("'")
  __DATA__
  It's working!
''', true

test 'data marker whitespace', '''
  DATA[0]
  __DATA__
    indented
''', ' '

test 'data marker users', '''
  users = DATA.trim().split("\\n").map (line) ->
    [name, email] = line.split(",")
    {name, email}
  users[1].name
  __DATA__
  Alice,alice@example.com
  Bob,bob@example.com
  Charlie,charlie@example.com
''', 'Bob'

test 'data marker json', '''
  obj = JSON.parse(DATA)
  obj.name
  __DATA__
  {"name": "Alice", "age": 30}
''', 'Alice'

test 'data marker env parsing', '''
  env = {}
  for line in DATA.split("\\n") when line and not line.startsWith("#")
    parts = line.split("=")
    if parts.length is 2
      [key, val] = parts
      env[key.trim()] = val.trim()
  env.PORT
  __DATA__
  # Config
  HOST=localhost
  PORT=3000
''', '3000'

test 'data marker payload keeps its newline', '''
  x = DATA
  x.length
  __DATA__
  hello world
''', 12
