# Test: Operators (24 node types)
# Systematically tests all operator node types from grammar

import { test, code, fail, type } from '../support/testing.js'

# ==============================================================================
# Arithmetic Operators
# ==============================================================================

# Addition: "+"
test "addition integers", "5 + 3", 8
test "addition decimals", "2.5 + 1.5", 4.0
test "addition negative", "-5 + 10", 5
code "addition parens", "a + b", "a + b;"

# Subtraction: "-" (binary and unary)
test "subtraction integers", "10 - 4", 6
test "subtraction negative result", "3 - 5", -2
test "unary minus", "-5", -5
code "subtraction parens", "a - b", "a - b;"

# Multiplication: "*"
test "multiplication", "4 * 3", 12
test "multiplication decimal", "2.5 * 2", 5.0
code "multiplication parens", "a * b", "a * b;"

# Division: "/"
test "division", "10 / 2", 5
test "division decimal", "7 / 2", 3.5
code "division parens", "a / b", "a / b;"

# Modulo: "%"
test "modulo", "10 % 3", 1
test "modulo zero", "10 % 5", 0
code "modulo parens", "a % b", "a % b;"

# Exponentiation: "**"
test "exponentiation", "2 ** 3", 8
test "exponentiation decimal", "4 ** 0.5", 2
code "exponentiation parens", "a ** b", "a ** b;"

# ==============================================================================
# Comparison Operators
# ==============================================================================

# Equality: "==" (compiles to strict ===)
test "equality true", "5 == 5", true
test "equality false", "5 == 3", false
test "is keyword", "5 is 5", true
test "is keyword false", "5 is 3", false
code "equality compiles to strict", "a == b", "a === b;"
code "is compiles to strict", "a is b", "a === b;"
# Inequality: "!=" (compiles to strict !==)
test "inequality true", "5 != 3", true
test "inequality false", "5 != 5", false
test "isnt keyword", "5 isnt 3", true
test "isnt keyword false", "5 isnt 5", false
code "inequality compiles to strict", "a != b", "a !== b;"
code "isnt compiles to strict", "a isnt b", "a !== b;"
# Less than: "<"
test "less than true", "3 < 5", true
test "less than false", "5 < 3", false
code "less than parens", "a < b", "a < b;"

# Greater than: ">"
test "greater than true", "5 > 3", true
test "greater than false", "3 > 5", false
code "greater than parens", "a > b", "a > b;"

# Less than or equal: "<="
test "less than or equal true", "3 <= 5", true
test "less than or equal equal", "5 <= 5", true
code "less than or equal parens", "a <= b", "a <= b;"

# Greater than or equal: ">="
test "greater than or equal true", "5 >= 3", true
test "greater than or equal equal", "5 >= 5", true
code "greater than or equal parens", "a >= b", "a >= b;"

# ==============================================================================
# Logical Operators
# ==============================================================================

# Logical NOT: "!"
test "logical not true", "!false", true
test "logical not false", "!true", false
code "logical not simple", "!a", "!a"
code "logical not complex", "!(a && b)", "!(a && b);"

# Logical AND: "&&"
test "logical and both true", "true && true", true
test "logical and first false", "false && true", false
test "logical and second false", "true && false", false
code "logical and parens", "a && b", "a && b;"

# Logical OR: "||"
test "logical or both false", "false || false", false
test "logical or first true", "true || false", true
test "logical or second true", "false || true", true
code "logical or parens", "a || b", "a || b;"

# Nullish coalescing: "??"
test "nullish with null", "null ?? 10", 10
test "nullish with undefined", "undefined ?? 20", 20
test "nullish with zero", "0 ?? 30", 0
test "nullish with false", "false ?? 40", false
code "nullish coalescing parens", "a ?? b", "a ?? b;"

# ?? shares the || precedence level (left-assoc); && binds tighter
code "nullish then or groups left", "x = a ?? b || c", "let x = (a ?? b) || c;"
code "or then nullish groups left", "x = a || b ?? c", "let x = (a || b) ?? c;"
code "and binds tighter than nullish", "x = a ?? b && c", "let x = a ?? (b && c);"
test "nullish or chain runtime", "(null ?? false) || 'y'", "y"

# Postfix presence check: "?!" (Houdini — truthy or undefined)
test "presence with true", "true?!", true
test "presence with value", "5?!", true
test "presence with string", "'hello'?!", true
test "presence with false", "false?!", undefined
test "presence with zero", "0?!", undefined
test "presence with null", "null?!", undefined
test "presence with undefined", "undefined?!", undefined
test "presence with empty string", "''?!", undefined
code "presence operator parens", "a?!", "(a ? true : undefined)"

# ==============================================================================
# Bitwise Operators
# ==============================================================================

# Bitwise AND: "&"
test "bitwise and", "5 & 3", 1
code "bitwise and parens", "a & b", "a & b;"

# Bitwise OR: "|"
test "bitwise or", "5 | 3", 7
code "bitwise or parens", "a | b", "a | b;"

# Bitwise XOR: "^"
test "bitwise xor", "5 ^ 3", 6
code "bitwise xor parens", "a ^ b", "a ^ b;"

# Bitwise NOT: "~"
test "bitwise not", "~5", -6
code "bitwise not parens", "~a", "~a;"

# ==============================================================================
# Increment/Decrement: "++" / "--"
# ==============================================================================

# Prefix increment: "++"
test "prefix increment", "x = 5\n++x", 6

# Postfix increment: "++"
test "postfix increment", "x = 5\nx++\nx", 6

# Prefix decrement: "--"
test "prefix decrement", "x = 5\n--x", 4

# Postfix decrement: "--"
test "postfix decrement", "x = 5\nx--\nx", 4

# ==============================================================================
# In operator with string literals (critical for bootstrap!)
# ==============================================================================

# String literal in object (use in operator)
test "in operator object", "obj = {a: 1}\n'a' in obj", true
test "in operator object missing", "obj = {b: 1}\n'a' in obj", false

# String literal in string (should use .includes())
# Critical: 'x' in str should check if x is substring, not index!
test "string in string present", "str = 'hello world'\n'world' in str", true
test "string in string missing", "str = 'hello'\n'world' in str", false
test "newline in string", "str = 'line1\\nline2'\n'\\n' in str", true

# Code generation test - runtime check for string/array vs object
code "string literal in variable uses runtime check", "'\\n' in action", "Array.isArray(action) || typeof action === 'string' ? action.includes(\"\\n\") : (\"\\n\" in action);"
code "property in identifier also uses runtime check", "'key' in obj", "Array.isArray(obj) || typeof obj === 'string' ? obj.includes(\"key\") : (\"key\" in obj);"

# ==============================================================================
# Array Membership Tests (Issue #60)
# The 'in' operator should check VALUES in arrays, not INDICES
# ==============================================================================

# Variable in array variable (primary bug case)
test "variable in array variable", "list = ['apple', 'banana']\nval = 'apple'\nval in list", true
test "variable not in array variable", "list = ['apple', 'banana']\nval = 'orange'\nval in list", false

# String literal in array literal
test "string literal in array literal", "'apple' in ['apple', 'banana']", true
test "string not in array literal", "'orange' in ['apple', 'banana']", false

# Variable in array literal
test "variable in array literal", "val = 'apple'\nval in ['apple', 'banana']", true
test "variable not in array literal", "val = 'orange'\nval in ['apple', 'banana']", false

# Number in array (should check VALUE, not index!)
test "number value in array", "val = 42\nval in [10, 42, 99]", true
test "number not in array", "val = 5\nval in [10, 42, 99]", false

# Critical edge case: number 1 as VALUE vs index 1
test "number 1 as value in array", "1 in [5, 1, 9]", true
test "number 1 not as value", "1 in [5, 9]", false

# Empty array
test "value in empty array", "'x' in []", false

# Code generation - all non-object cases should use runtime check
code "variable in variable uses runtime check", "val in list", "Array.isArray(list) || typeof list === 'string' ? list.includes(val) : (val in list);"
# A CONSTRUCTED container (a literal list, a call) evaluates exactly
# once — membership dispatches through the helper call. A plain-name
# container keeps the inline dispatch (the rows above).
code "literal in literal dispatches through the helper", "'x' in ['a', 'b']", "((k, c) => Array.isArray(c) || typeof c === 'string' ? c.includes(k) : k in c)(\"x\", [\"a\", \"b\"]);"
code "variable in literal dispatches through the helper", "val in ['a', 'b']", "((k, c) => Array.isArray(c) || typeof c === 'string' ? c.includes(k) : k in c)(val, [\"a\", \"b\"]);"

# Object literal should still use JavaScript 'in'
code "property in object literal", "'key' in {key: 1}", "\"key\" in {key: 1};"

# ==============================================================================
# Ternary Operator: "? :"
# ==============================================================================

# Basic ternary
test "ternary true branch", "true ? 'yes' : 'no'", 'yes'
test "ternary false branch", "false ? 'yes' : 'no'", 'no'
test "ternary with comparison", "5 > 3 ? 'big' : 'small'", 'big'
test "ternary with variables", "a = true\nb = 10\nc = 20\na ? b : c", 10

# Ternary with various true-branch expressions (all should work without parens)
test "ternary simple identifier", "x = 5\ntrue ? x : 0", 5
test "ternary property access", "obj = {foo: 42}\ntrue ? obj.foo : 0", 42
test "ternary function call", "fn = -> 99\ntrue ? fn() : 0", 99
test "ternary arithmetic", "true ? 2 + 3 : 0", 5
# Code generation tests
code "ternary basic", "a ? b : c", "(a ? b : c)"
code "ternary with property access", "a ? b.foo : c", "(a ? b.foo : c)"
code "ternary with function call", "a ? b() : c", "(a ? b() : c)"
code "ternary with expression", "a ? b + 1 : c", "(a ? (b + 1) : c)"

# Subscript access is legal in a ternary true-branch, bare or parenthesized
test "ternary subscript with parens", "arr = [1, 2, 3]\ntrue ? (arr[0]) : 0", 1
test "ternary subscript bare", "arr = [1, 2, 3]\ntrue ? arr[0] : 0", 1
code "ternary subscript with parens", "a ? (b[0]) : c", "(a ? b[0] : c)"

# ==============================================================================
# String Repeat — "str" * n (literal-only: a dynamic left operand keeps JS `*`)
# ==============================================================================

# The literal strict spellings normalize to `==`/`!=` (all four mean
# strict equality — there is no loose-equality surface)
test "strict equality triple equals", "1 === 1", true
test "strict equality false", "1 === '1'", false
test "strict inequality triple", "1 !== '1'", true
test "strict inequality false", "1 !== 1", false
code "triple equals compiles to strict", "a === b", "a === b;"
code "triple not-equals compiles to strict", "a !== b", "a !== b;"

code "string repeat compiles to repeat", '"-" * 40', '"-".repeat(40);'
test "string repeat repeats", '"ab" * 3', "ababab"
test "string repeat composes with concat", '"a" * 2 + "b"', "aab"
test "string repeat takes an expression count", '"a" * (1 + 2)', "aaa"
code "dynamic left operand stays multiply", 's * 3', 's * 3;'

# ==============================================================================
# Chained Comparisons — a < b < c
# ==============================================================================

test "chained less than", "x = 5; 1 < x < 10", true
test "chained less than false low", "x = 0; 1 < x < 10", false
test "chained less than false high", "x = 15; 1 < x < 10", false
test "chained less equal", "x = 5; 1 <= x <= 10", true
test "chained less equal boundary", "x = 1; 1 <= x <= 10", true
test "chained greater than", "x = 5; 10 > x > 1", true
test "chained mixed", "x = 5; 0 <= x < 10", true
code "chained compiles to conjunction", "1 < x < 10", "(1 < x) && (x < 10);"

# Equality ops chain like relationals; explicit parens opt out
test "chained equality true", "a = 5; b = 5; c = 5; a == b == c", true
test "chained equality false", "a = 5; b = 5; c = 6; a == b == c", false
test "chained inequality", "1 != 2 != 3", true
test "chained mixed equality and relational", "x = 5; 5 == x < 10", true
test "four element chain", "x = 5; 1 < x < 10 < 20", true
test "parenthesized comparison does not chain", "(3 == 3) == true", true
test "parenthesized relational does not chain", "(1 < 2) < 10", true

# ==============================================================================
# Negative Indexing
# ==============================================================================

test "negative index last element", '''
  arr = [10, 20, 30]
  arr[-1]
  ''', 30

test "negative index second to last", '''
  arr = [10, 20, 30]
  arr[-2]
  ''', 20

test "negative index on string", '''
  str = "hello"
  str[-1]
  ''', "o"

code "negative index compiles to .at()", "arr[-1]", "arr.at(-1)"
code "negative index -2 compiles to .at()", "arr[-2]", "arr.at(-2)"

# ==============================================================================
# Prototype Operator — ::
# ==============================================================================

# ==============================================================================
# Method Assignment — .= (the target re-binds to a method call on itself)
# ==============================================================================

code "method assign compiles", 's = " hi "\ns .= trim()', 'let s = " hi ";\n\ns = s.trim();'
test "method assign trim", 's = "  hi  "\ns .= trim()\ns', "hi"
test "method assign filter with implicit it", "arr = [1, 2, 3, 4, 5]\narr .= filter -> it > 3\narr", [4, 5]
test "method assign chained calls", 'str = " A "\nstr .= trim().toLowerCase()\nstr', "a"
test "method assign on property chain", 'obj = {name: " x "}\nobj.name .= trim()\nobj.name', "x"
test "method assign impure base evaluates once", '''
  n = 0
  o = {name: " y "}
  g = -> (n += 1; o)
  g().name .= trim()
  [o.name, n]
''', ["y", 1]
code "method assign impure base binds once", 'g().name .= trim()', "const _ref = g();\n\n_ref.name = _ref.name.trim();"
fail "method assign needs a call chain", 's .= 5', "must be a call chain"
fail "method assign rejects in value position", 'y = (s .= trim())', "is a statement"

# ==============================================================================
# Merge Assignment — *>obj = { ... } (merge in place, init when nullish)
# ==============================================================================

code "merge assign compiles to Object.assign", 'obj = {a: 1}\n*>obj = {b: 2}', 'let obj = {a: 1};\n\nobj = Object.assign(obj ??= {}, {b: 2});'
test "merge assign basic", 'obj = {a: 1}\n*>obj = {b: 2}\nobj', {a: 1, b: 2}
test "merge assign preserves existing", 'obj = {a: 1, b: 1}\n*>obj = {b: 2}\nobj', {a: 1, b: 2}
test "merge assign auto-init", '*>cfg = {x: 1}\ncfg', {x: 1}
test "merge assign member target", 'o = {inner: {a: 1}}\n*>o.inner = {b: 2}\no.inner', {a: 1, b: 2}
fail "merge assign rejects in value position", 'y = (*>obj = {a: 1})', "is a statement"

# ==============================================================================
# Unary bases of ** must be parenthesized (bare form is a JS SyntaxError)
# ==============================================================================

code "typeof base of power parenthesized", "typeof x ** 2", "(typeof x) ** 2;"
code "not base of power parenthesized", "not x ** 2", "(!x) ** 2;"
test "not base of power evaluates", "not 2 ** 2", 0
test "power right assoc unchanged", "2 ** 3 ** 2", 512
test "unary minus binds outside power", "-2 ** 2", -4

# Multi-line nullish chains are one logical line.
test "nullish chain continues across lines", "a = null; b = undefined; c = 3\nv =\n  a ??\n  b ??\n  c\nv", 3

# ==============================================================================
# Membership evaluates each operand exactly once
# ==============================================================================

test "a side-effecting container evaluates once", '''
  calls = 0
  xs = ->
    calls += 1
    ["x"]
  ok = "x" in xs()
  [calls, ok]
''', [1, true]

# ==============================================================================
# Synthesized compounds evaluate a member/index base exactly once
# ==============================================================================

test "floor-divide assign reads its base once", '''
  o = {n: 7}
  calls = 0
  get = ->
    calls += 1
    o
  get().n //= 2
  [o.n, calls]
''', [3, 1]

test "modulo assign evaluates an index key once", '''
  a = [9]
  i = 0
  key = ->
    i += 1
    0
  a[key()] %%= 4
  [a[0], i]
''', [1, 1]

test 'string repeat longer', '''
  "ha" * 4
  ''', "hahahaha"

test 'string repeat single char', '''
  "=" * 5
  ''', "====="

test 'prototype access', '''
    String::starts = String::startsWith
    "hello".starts "he"
  ''', true

test 'method assign chained', '''
    str = "  Hello World  "
    str .= trim()
    str .= toLowerCase()
    str
  ''', "hello world"

test 'method assign map', '''
    items = [1, 2, 3]
    items .= map -> it * 10
    items
  ''', [10, 20, 30]

test 'merge assign inline', '''
    opts = {}
    *>opts = {a: 1, b: 2}
    opts.a + opts.b
  ''', 3

test 'not base of power', '''
  not false ** 2
  ''', 1

code 'prototype compiles to .prototype.', 'String::trim', 'String.prototype.trim'

code 'method assign chain compiles', 'a.b .= trim()', 'const _ref = a;\n_ref.b = _ref.b.trim();'
code 'method assign with a bound base keeps its bytes', 'a = {b: " x "}\na.b .= trim()', 'let a = {b: " x "};\na.b = a.b.trim();'

# ==============================================================================
# Synthesized compounds (//=, %%=) preserve native compound order:
# base, key, target read, RHS, write — each operand exactly once.
# ==============================================================================

test 'floor-div assign reads target before RHS', '''
  log = []
  handler = {}
  handler.get = (o, k) -> (log.push('get'); o[k])
  handler.set = (o, k, v) -> (log.push('set'); o[k] = v; true)
  target = {x: 9}
  obj = new Proxy target, handler
  rhs = -> (log.push('rhs'); 2)
  obj.x //= rhs()
  [target.x, log]
  ''', [4, ['get', 'rhs', 'set']]

test 'modulo assign reads target before RHS', '''
  log = []
  handler = {}
  handler.get = (o, k) -> (log.push('get'); o[k])
  handler.set = (o, k, v) -> (log.push('set'); o[k] = v; true)
  target = {x: 9}
  obj = new Proxy target, handler
  rhs = -> (log.push('rhs'); 7)
  obj.x %%= rhs()
  [target.x, log]
  ''', [2, ['get', 'rhs', 'set']]

test 'floor-div assign evaluates an impure base once', '''
  n = 0
  get = -> (n += 1; {x: 9})
  get().x //= 2
  n
  ''', 1

test 'class field reference captures are private to each recursive construction', '''
  reads = 0
  firstValue = null
  secondValue = null
  first = {}
  second = {}
  Object.defineProperty first, 'x',
    configurable: true
    get: ->
      reads += 1
      Box.new() if reads is 1
      8
    set: (v) -> firstValue = v
  Object.defineProperty second, 'x',
    configurable: true
    get: -> 8
    set: (v) -> secondValue = v
  calls = 0
  get = ->
    calls += 1
    if calls is 1 then first else second
  class Box
    value = get().x //= 2
  Box.new()
  [firstValue, secondValue, calls]
  ''', [4, 4, 2]

test 'floor-div assign evaluates a computed key once in order', '''
  log = []
  o = {}
  o[3] = 9
  key = -> (log.push('key'); 3)
  rhs = -> (log.push('rhs'); 2)
  o[key()] //= rhs()
  [o[3], log]
  ''', [4, ['key', 'rhs']]

test 'floor-div assign value position yields the written value', '''
  o = {x: 9}
  r = (o.x //= 2)
  [r, o.x]
  ''', [4, 4]

test 'floor-div assign preserves yield in the value', '''
  f = ->
    o = {x: 9}
    o.x //= yield 3
    o.x
  g = f()
  first = g.next().value
  [first, g.next(3).value]
  ''', [3, 3]

test 'floor-div assign preserves await in the value', '''
  o = {x: 9}
  o.x //= await Promise.resolve(2)
  o.x
  ''', 4

test 'floor-div assign composes with the dammit operator', '''
  o = {x: 9}
  o.x //= Promise.resolve!(2)
  o.x
  ''', 4

test 'synth compound temps dodge user bindings', '''
  _o = 'mine'
  _k = 'mine too'
  _t = 'and mine'
  obj = {x: 9}
  obj.x //= 2
  [_o, _k, _t, obj.x]
  ''', ['mine', 'mine too', 'and mine', 4]
