''', 5

test 'onError catches error from effect in _init', '''
  caught = null
  A = component
    onError = (err) -> caught = err.message
    ~> raise "boom"
  a = A.new()
  caught
''', 'boom'

test 'onError receives source component', '''
  source = null
  A = component
    onError = (err, comp) -> source = comp
    ~> raise "test"
  a = A.new()
  source is a
''', true

test 'error without onError throws normally', '''
  threw = false
  A = component
    ~> raise "unhandled"
  try
    a = A.new()
  catch e
    threw = e.message
  threw
''', 'unhandled'

test 'onError on parent catches child error', '''
  caught = null
  Parent = component
    onError = (err, comp) -> caught = err.message
    ~> noop()
  Child = component
    ~> raise "child boom"
  p = Parent.new()
  __pushComponent(p)
  c = Child.new()
  __popComponent(null)
  caught
''', 'child boom'

# ==============================================================================
# Dual-namespace tag resolution
# ==============================================================================
# `a`, `script`, `style`, and `title` exist in BOTH the HTML and SVG
# namespaces. Outside an SVG subtree they are HTML; an enclosing SVG
# element flips them. Misresolving `a` silently creates an SVGAElement
# whose href/click behavior is not an anchor's.

code 'top-level `a` is an HTML anchor, not an SVG element', '''
  A = component
    render
      a href: "/home"
        "go"
  ''', '''
  let A = class extends __Component {
    _init(props) {
    }
    _create() {
      this._el0 = document.createElement('a');
      this._el0.setAttribute('data-part', 'A');
      this._el0.setAttribute('href', "/home");
      this._t0 = document.createTextNode("go");
      this._el0.appendChild(this._t0);
      return this._el0;
    }
  };
  '''

code 'inside an svg subtree, `a` takes the SVG namespace', '''
  B = component
    render
      svg
        a href: "/x"
  ''', '''
  let B = class extends __Component {
    _init(props) {
    }
    _create() {
      this._el0 = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
      this._el0.setAttribute('data-part', 'B');
      this._el1 = document.createElementNS('http://www.w3.org/2000/svg', 'a');
      this._el1.setAttribute('href', "/x");
      this._el0.appendChild(this._el1);
      return this._el0;
    }
  };
  '''

# ==============================================================================
# Emission pins — the render scaffold, byte for byte
# ==============================================================================
# Every component root stamps data-part with the component's name; these
# pins carry the full _create()/_setup() shape for the core constructs.

code 'single element', '''
  export A = component
    render
      div
  ''', '''
  export const A = class extends __Component {
    _init(props) {
    }
    _create() {
      this._el0 = document.createElement('div');
      this._el0.setAttribute('data-part', 'A');
      return this._el0;
    }
  };
  '''

code 'element with text child', '''
  export A = component
    render
      span "hello"
  ''', '''
  export const A = class extends __Component {
    _init(props) {
    }
    _create() {
      this._el0 = document.createElement('span');
      this._el0.setAttribute('data-part', 'A');
      this._t0 = document.createTextNode("hello");
      this._el0.appendChild(this._t0);
      return this._el0;
    }
  };
  '''

code 'nested elements', '''
  export A = component
    render
      div
        span "inner"
  ''', '''
  export const A = class extends __Component {
    _init(props) {
    }
    _create() {
      this._el0 = document.createElement('div');
      this._el0.setAttribute('data-part', 'A');
      this._el1 = document.createElement('span');
      this._t0 = document.createTextNode("inner");
      this._el1.appendChild(this._t0);
      this._el0.appendChild(this._el1);
      return this._el0;
    }
  };
  '''

code 'element with id', '''
  export A = component
    render
      div#main
  ''', '''
  export const A = class extends __Component {
    _init(props) {
    }
    _create() {
      this._el0 = document.createElement('div');
      this._el0.id = 'main';
      this._el0.setAttribute('data-part', 'A');
      return this._el0;
    }
  };
  '''

code 'element with static class', '''
  export A = component
    render
      div.card
  ''', '''
  export const A = class extends __Component {
    _init(props) {
    }
    _create() {
      this._el0 = document.createElement('div');
      this._el0.setAttribute('data-part', 'A');
      this._el0.className = 'card';
      return this._el0;
    }
  };
  '''

code 'element with multiple classes', '''
  export A = component
    render
      div.card.active
  ''', '''
  export const A = class extends __Component {
    _init(props) {
    }
    _create() {
      this._el0 = document.createElement('div');
      this._el0.setAttribute('data-part', 'A');
      this._el0.className = 'card active';
      return this._el0;
    }
  };
  '''

code 'static attribute', '''
  export A = component
    render
      input type: "text", placeholder: "name"
  ''', '''
  export const A = class extends __Component {
    _init(props) {
    }
    _create() {
      this._el0 = document.createElement('input');
      this._el0.setAttribute('data-part', 'A');
      this._el0.setAttribute('type', "text");
      this._el0.setAttribute('placeholder', "name");
      return this._el0;
    }
  };
  '''

code 'boolean attribute', '''
  export A = component
    render
      input disabled: true
  ''', '''
  export const A = class extends __Component {
    _init(props) {
    }
    _create() {
      this._el0 = document.createElement('input');
      this._el0.setAttribute('data-part', 'A');
      if (true) this._el0.setAttribute('disabled', '');
      return this._el0;
    }
  };
  '''

code 'reactive attribute', '''
  export A = component
    href ~= "/home"
    render
      a href: href
  ''', '''
  export const A = class extends __Component {
    _init(props) {
      this.href = __computed(() => "/home");
    }
    _create() {
      this._el0 = document.createElement('a');
      this._el0.setAttribute('data-part', 'A');
      return this._el0;
    }
    _setup() {
      __effect(() => { this._el0.setAttribute('href', this.href.value); });
    }
  };
  '''

code 'reactive boolean attribute', '''
  export A = component
    loading := true
    render
      button disabled: loading
  ''', '''
  export const A = class extends __Component {
    _init(props) {
      this.loading = __state(true);
    }
