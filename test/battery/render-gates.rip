import { test, code, fail, type } from '../support/testing.js'

code 'gate: hoists static __gates and binds via __gateBind', '''
  export A = component
    user <~ @app.data.user
    render
      div user.name
''', '''
  export const A = class extends __Component {
    static __gates = ['user'];
    _init(props) {
      this.user = __gateBind(this, 0);
    }
    _create() {
      this._el0 = document.createElement('div');
      this._el0.setAttribute('data-part', 'A');
      this._t0 = document.createTextNode('');
      this._el0.appendChild(this._t0);
      return this._el0;
    }
    _setup() {
      __effect(() => { this._t0.data = this.user.value.name; });
    }
  };
'''

code 'gate: keyed source hoists (path, key fn) pair', '''
  export A = component
    order <~ @app.data.order(params.id)
    render null
''', '''
  export const A = class extends __Component {
    static __gates = [{ path: 'order', key: (params, query) => params.id }];
    _init(props) {
      this.order = __gateBind(this, 0);
    }
    _create() {
      return null;
    }
  };
'''

code 'gate: @params key form normalizes to bare params', '''
  export A = component
    order <~ @app.data.order(@params.id)
    render null
''', '''
  export const A = class extends __Component {
    static __gates = [{ path: 'order', key: (params, query) => params.id }];
    _init(props) {
      this.order = __gateBind(this, 0);
    }
    _create() {
      return null;
    }
  };
'''

code 'gate: subpath binds the nested path string', '''
  export A = component
    theme <~ @app.data.settings.theme
    render null
''', '''
  export const A = class extends __Component {
    static __gates = ['settings.theme'];
    _init(props) {
      this.theme = __gateBind(this, 0);
    }
    _create() {
      return null;
    }
  };
'''

code 'gate: binds before state so initializers consume the value', '''
  export A = component
    user <~ @app.data.user
    form := { ...user }
    render null
''', '''
  export const A = class extends __Component {
    static __gates = ['user'];
    _init(props) {
      this.user = __gateBind(this, 0);
      this.form = __state({...this.user.value});
    }
    _create() {
      return null;
    }
  };
'''

test 'gate: direct construction rejects without renderer metadata', '''
  A = component
    user <~ @app.data.user
    render null
  try
    A.new()
  catch e
    e.message.includes 'cannot be constructed directly'
''', true

test 'gate: embedded child with gates throws at construction', '''
  globalThis.__ripApp = { data: { user: { name: 'Ada' } } }
  Child = component
    user <~ @app.data.user
    render null
  Parent = component
    render null
  parent = Parent.new()
  err = null
  prev = __pushComponent parent
  try
    Child.new()
  catch e
    err = e.message
  __popComponent prev
  globalThis.__ripApp = undefined
  err?.includes('render gates') ?? false
''', true

fail 'gate: <~ outside a component body is a compile error', '''
  user <~ @app.data.user
''', "render gate ('<~') can only be used as a direct component body line"

fail 'gate: non-literal path is a compile error', '''
  C = component
    user <~ someVar.user
    render null
''', "'<~' requires a literal @app.data.<path>"

fail 'gate: key referencing a local is a compile error', '''
  C = component
    order <~ @app.data.order(someLocal)
    render null
''', 'key may only be a literal or a params/query path'

type 'gate: annotated value is a non-null readonly computed container', '''
  export UserCard = component
    user: { name: string } <~ @app.data.user
    render null
''', '''
  export interface UserCard {
    user: { readonly value: { name: string }; read(): { name: string } };
    children?: any;
    mount(target?: any): UserCard;
    unmount(options?: { removeDOM?: boolean }): void;
    emit(name: string, detail?: any): void;
  }
  export declare let UserCard: {
    readonly prototype: UserCard;
  };
'''
