test "gate: embedded child with gates throws at construction", "globalThis.__ripApp = { data: { user: { name: 'Ada' } } }\nChild = component\n  user <~ @app.data.user\n  render null\nParent = component\n  render null\np = Parent.new()\nerr = null\nprev = globalThis.__ripComponent.__pushComponent(p)\ntry\n  Child.new()\ncatch e\n  err = e.message\nglobalThis.__ripComponent.__popComponent(prev)\nglobalThis.__ripApp = undefined\nerr?.includes('render gates') ?? false", true
