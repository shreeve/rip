     _t0 = document.createTextNode(String(`${v}${i}`));
     _el2.appendChild(_t0);
     this._first = _el2;
   },
   m(target, anchor) {
     if (target) target.insertBefore(_el2, anchor);
   },
   p(ctx, v, i, item, j) {
   },
   d(detaching) {
