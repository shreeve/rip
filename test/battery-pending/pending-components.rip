  A = component
    val =! getContext("missing")
  a = A.new()
  a.val
''', null

test 'lis: empty array', '''
  X = component
    noop()
  __lis([])
''', []

test 'lis: single element', '''
  X = component
    noop()
  __lis([0])
''', [0]

test 'lis: already sorted', '''
  X = component
    noop()
  __lis([0, 1, 2, 3])
''', [0, 1, 2, 3]

test 'lis: reversed', '''
  X = component
    noop()
  __lis([3, 2, 1, 0]).length
''', 1

test 'lis: with new items (-1)', '''
  X = component
    noop()
  __lis([0, -1, 1, -1, 2])
''', [0, 2, 4]

test 'lis: swap first and last', '''
  X = component
    noop()
  result = __lis([3, 1, 2, 0])
  result.length
''', 2

test 'lis: interleaved', '''
  X = component
    noop()
  __lis([1, 0, 3, 2])
''', [1, 3]

