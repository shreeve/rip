   }
    };
  }

  function create_block_0(ctx, item, j) {
    let _anchor1;
    let disposers = [];
    let _factoryChildren = [];
    return {
   c() {
     _anchor1 = document.createComment('for');
     this._first = _anchor1;
   },
   m(target, anchor) {
     if (target) target.insertBefore(_anchor1, anchor);
   },
   p(ctx, item, j) {
     disposers.forEach(d => d());
     disposers = [];
     // Loop: create_block_1
   {
     const __s = { blocks: [], keys: [] };
     disposers.push(__effect(() => {
       __reconcile(_anchor1, __s, item.options, ctx, create_block_1, null, item, j);
     }, {skipRegister: true}));
     disposers.push(() => { for (const __b of __s.blocks) { try { __b.d(true); } catch {} } __s.blocks = []; __s.keys = []; __s.items = []; });
   }
   },
   d(detaching) {
     for (const __c of _factoryChildren) { try { __c.unmount?.({removeDOM: detaching}); } catch (__e) { console.error('[Rip] factory child unmount error:', __e); } }
     _factoryChildren = [];
     disposers.forEach(d => d());
     if (detaching) __detach(_anchor1);
   }
    };
  }

  return class extends __Component {
    _init(props) {
   this.items = __state([{options: [1, 2]}]);
    }
    _create() {
   this._anchor0 = document.createComment('for');
   return this._anchor0;
    }
    _setup() {
   // Loop: create_block_0
   {
     const __s = { blocks: [], keys: [] };
     __effect(() => {
       __reconcile(this._anchor0, __s, this.items.value, this, create_block_0, null);
     });
     { const __cur = globalThis.__ripComponent?.__getCurrentComponent?.(); if (__cur) (__cur._disposers ??= []).push(() => { for (const __b of __s.blocks) { try { __b.d(true); } catch {} } __s.blocks = []; __s.keys = []; __s.items = []; }); }
