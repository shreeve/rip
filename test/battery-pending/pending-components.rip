test "lis: empty array", "X = component\n  noop()\n__lis([])", []
test "lis: single element", "X = component\n  noop()\n__lis([0])", [0]
test "lis: already sorted", "X = component\n  noop()\n__lis([0, 1, 2, 3])", [0, 1, 2, 3]
test "lis: reversed", "X = component\n  noop()\n__lis([3, 2, 1, 0]).length", 1
test "lis: with new items (-1)", "X = component\n  noop()\n__lis([0, -1, 1, -1, 2])", [0, 2, 4]
test "lis: swap first and last", "X = component\n  noop()\nresult = __lis([3, 1, 2, 0])\nresult.length", 2
test "lis: interleaved", "X = component\n  noop()\n__lis([1, 0, 3, 2])", [1, 3]
test "loop component state access", "A = component\n  items := [1, 2, 3]\na = A.new()\na.items.value", [1, 2, 3]
test "loop component state mutation", "A = component\n  items := [1, 2, 3]\na = A.new()\na.items.value = [4, 5]\na.items.value", [4, 5]
test "loop component computed from items", "A = component\n  items := [1, 2, 3]\n  count ~= items.length\na = A.new()\na.count.value", 3
test "loop component computed reacts to items change", "A = component\n  items := [1, 2, 3]\n  count ~= items.length\na = A.new()\na.items.value = [1, 2, 3, 4, 5]\na.count.value", 5
test "onError catches error from effect in _init", "caught = null\nA = component\n  onError = (err) -> caught = err.message\n  ~> raise \"boom\"\na = A.new()\ncaught", "boom"
test "onError receives source component", "source = null\nA = component\n  onError = (err, comp) -> source = comp\n  ~> raise \"test\"\na = A.new()\nsource is a", true
test "error without onError throws normally", "threw = false\nA = component\n  ~> raise \"unhandled\"\ntry\n  a = A.new()\ncatch e\n  threw = e.message\nthrew", "unhandled"
