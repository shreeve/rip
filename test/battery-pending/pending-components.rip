test 'nested loops with auto outer + explicit inner `i` execute correctly', '''
    A = component
      items := [{opts: [10, 20]}, {opts: [30]}]
      render
        for item in items
          for v, i in item.opts
            span "#{v}@#{i}"
    inst = A.new(items: [{opts: ["a", "b"]}, {opts: ["c"]}])
    inst._init({})
    typeof inst._create
''', 'function'

test 'three-deep nested loops with i/j/k mix never collide', '''
    A = component
      items := [{groups: [{values: [1]}]}]
      render
        for item in items
          for group in item.groups
            for v, i in group.values
              span "#{v}@#{i}"
    inst = A.new(items: [{groups: [{values: [1, 2]}]}])
    inst._init({})
    typeof inst._create
''', 'function'

test 'loop body that depends on auto-allocated index `i` (row striping)', '''
    A = component
      rows := ["a", "b", "c"]
      render
        for row, i in rows
          div class: (if i % 2 is 0 then "even" else "odd"), row
    inst = A.new(rows: ["x", "y", "z"])
    inst._init({})
    typeof inst._create
''', 'function'

