code "bare shorthand scopes the listener to the element it sits on, not the root", "export A = component\n  onClick: -> p \"clicked\"\n  render\n    div\n      button @click, \"inner\"", "export const A = class extends __Component {\n  _init(props) {}\n  onClick() { return p(\"clicked\"); }\n  _create() {\n    this._el0 = document.createElement('div');\n    this._el1 = document.createElement('button');\n    this._el1.addEventListener('click', (e) => __batch(() => (this.onClick)(e)));\n    this._t0 = document.createTextNode(\"inner\");\n    this._el1.appendChild(this._t0);\n    this._el0.appendChild(this._el1);\n    return this._el0;\n  }\n}"
code "explicit @event: handler binds to the element", "export A = component\n  toggle: -> p \"explicit\"\n  render\n    button @click: toggle", "export const A = class extends __Component {\n  _init(props) {}\n  toggle() { return p(\"explicit\"); }\n  _create() {\n    this._el0 = document.createElement('button');\n    this._el0.addEventListener('click', (e) => __batch(() => this.toggle(e)));\n    return this._el0;\n  }\n}"
code "defining onClick alone attaches no listener (no name-based magic)", "export A = component\n  onClick: -> p \"clicked\"\n  render\n    button \"Click me\"", "export const A = class extends __Component {\n  _init(props) {}\n  onClick() { return p(\"clicked\"); }\n  _create() {\n    this._el0 = document.createElement('button');\n    this._t0 = document.createTextNode(\"Click me\");\n    this._el0.appendChild(this._t0);\n    return this._el0;\n  }\n}"
code "onError is a lifecycle hook, never a DOM listener", "export A = component\n  onError: (e) -> p e.message\n  render\n    div \"safe\"", "export const A = class extends __Component {\n  _init(props) {}\n  onError(e) { return p(e.message); }\n  _create() {\n    this._el0 = document.createElement('div');\n    this._t0 = document.createTextNode(\"safe\");\n    this._el0.appendChild(this._t0);\n    return this._el0;\n  }\n}"
code "value: @event is a member read, not an event binding", "export A = component\n  render\n    input value: @click", "export const A = class extends __Component {\n  _init(props) {}\n  _create() {\n    this._el0 = document.createElement('input');\n    this._el0.setAttribute('value', this.click);\n    return this._el0;\n  }\n}"
code "static element ref writes the state cell + registers compare-and-clear", "export A = component\n  canvas := null\n  render\n    canvas ref: canvas", "export const A = class extends __Component {\n  _init(props) {\n    this.canvas = __state(null);\n  }\n  _create() {\n    this._el0 = document.createElement('canvas');\n    this.canvas.value = this._el0;\n    (this._refCleanups ??= []).push(() => __detachRef(this.canvas, this._el0));\n    return this._el0;\n  }\n}"
fail "ref to a readonly (=!) is rejected", "  export A = component\n    el =! null\n    render\n      div ref: el", "must be a state cell"
fail "ref to a plain (=) member is rejected", "  export A = component\n    el = null\n    render\n      div ref: el", "must be a state cell"
code "private `=` member is plain, `:=` is reactive state", "export A = component\n  label = \"hi\"\n  count := 0\n  render\n    button \"\#{label}\#{count}\"", "export const A = class extends __Component {\n  _init(props) {\n    this.label = \"hi\";\n    this.count = __state(0);\n  }\n  _create() {\n    this._el0 = document.createElement('button');\n    this._t0 = document.createTextNode('');\n    this._el0.appendChild(this._t0);\n    return this._el0;\n  }\n  _setup() {\n    __effect(() => { this._t0.data = `\${this.label}\${this.count.value}`; });\n  }\n}"
fail "plain `=` member read in render + reassigned is a silent-freeze error", "  export A = component\n    open = false\n    toggle: -> open = not open\n    render\n      button \"\#{open}\"", "non-reactive field"
code "plain `=` member read + reassigned only in an effect is NOT a silent-freeze", "export A = component\n  count = 0\n  ~>\n    count = count + 1\n    p count\n  render\n    div \"hi\"", "export const A = class extends __Component {\n  _init(props) {\n    this.count = 0;\n    __effect(() => {\n  this.count = this.count + 1;\n  return p(this.count);\n});\n  }\n  _create() {\n    this._el0 = document.createElement('div');\n    this._t0 = document.createTextNode(\"hi\");\n    this._el0.appendChild(this._t0);\n    return this._el0;\n  }\n}"
fail "reassigning a =! member is a compile error", "  export A = component\n    c =! 5\n    bump: -> @c = 6\n    render\n      div \"\#{c}\"", "const member 'c'"
fail "compound-assigning a =! member is a compile error", "  export A = component\n    n =! 0\n    inc: -> n += 1\n    render\n      div \"\#{n}\"", "const member 'n'"
test "content mutation of a =! array member is allowed", "A = component\n  items =! []\n  add: -> @items.push(\"x\")\na = A.new()\na.add()\na.add()\na.items.length", 2
test "property mutation of a =! object member is allowed", "A = component\n  cfg =! {}\n  set: -> @cfg.ready = true\na = A.new()\na.set()\na.cfg.ready", true
fail "a top-level method param named like a =! member does not shadow it", "  export A = component\n    c =! 5\n    use: (c) -> c = c + 1\n    render\n      div \"\#{c}\"", "const member 'c'"
test "a nested-arrow param shadowing a =! member is assignable", "A = component\n  c =! 5\n  use: ->\n    f = (c) ->\n      c = c + 1\n      c\n    f(10)\na = A.new()\na.use()", 11
test "static ref: connected element at mount, nulled on unmount", "  mkDoc = ->\n    mk = (tag) ->\n      n = { tag, childNodes: [], parentNode: null, nodeType: (if tag is '#comment' then 8 else 1), _connected: false }\n      n.appendChild = (c) ->\n        c.parentNode.removeChild(c) if c.parentNode\n        c.parentNode = n\n        n.childNodes.push c\n        c\n      n.insertBefore = (c, ref) ->\n        c.parentNode.removeChild(c) if c.parentNode\n        c.parentNode = n\n        i = if ref? then n.childNodes.indexOf(ref) else -1\n        if i >= 0 then n.childNodes.splice(i, 0, c) else n.childNodes.push c\n        c\n      n.removeChild = (c) ->\n        i = n.childNodes.indexOf c\n        n.childNodes.splice(i, 1) if i >= 0\n        c.parentNode = null\n        c\n      n.remove = -> n.parentNode.removeChild(n) if n.parentNode\n      n.setAttribute = (k, v) -> n.attrs = (n.attrs or {}); n.attrs[k] = v\n      n.removeAttribute = (k) -> delete n.attrs[k] if n.attrs\n      n.toggleAttribute = (k, on_) -> n.setAttribute(k, '')\n      Object.defineProperty n, 'nextSibling',\n        get: ->\n          p = n.parentNode\n          return null unless p\n          i = p.childNodes.indexOf n\n          if i >= 0 and i + 1 < p.childNodes.length then p.childNodes[i + 1] else null\n      Object.defineProperty n, 'isConnected',\n        get: ->\n          x = n\n          while x\n            return true if x._connected\n            x = x.parentNode\n          false\n      n\n    { createElement: mk, createComment: (-> mk('#comment')), createTextNode: (-> mk('#text')) }\n  globalThis.document = mkDoc()\n\n  result = {}\n  C = component\n    el := null\n    mounted: ->\n      result.set = @el?\n      result.connected = @el?.isConnected\n    render\n      input ref: el\n  root = document.createElement('root')\n  root._connected = true\n  inst = C.new()\n  inst.mount(root)\n  atMount = \"\#{result.set}/\#{result.connected}\"\n  inst.unmount()\n  \"\#{atMount}/\#{inst.el.value == null}\"", "true/true/true"
test "forwarded ref: child element fills parent-owned cell, nulled on child unmount", "  mkDoc = ->\n    mk = (tag) ->\n      n = { tag, childNodes: [], parentNode: null, nodeType: (if tag is '#comment' then 8 else 1), _connected: false }\n      n.appendChild = (c) ->\n        c.parentNode.removeChild(c) if c.parentNode\n        c.parentNode = n\n        n.childNodes.push c\n        c\n      n.insertBefore = (c, ref) ->\n        c.parentNode.removeChild(c) if c.parentNode\n        c.parentNode = n\n        i = if ref? then n.childNodes.indexOf(ref) else -1\n        if i >= 0 then n.childNodes.splice(i, 0, c) else n.childNodes.push c\n        c\n      n.removeChild = (c) ->\n        i = n.childNodes.indexOf c\n        n.childNodes.splice(i, 1) if i >= 0\n        c.parentNode = null\n        c\n      n.remove = -> n.parentNode.removeChild(n) if n.parentNode\n      n.setAttribute = (k, v) -> n.attrs = (n.attrs or {}); n.attrs[k] = v\n      n.removeAttribute = (k) -> delete n.attrs[k] if n.attrs\n      n.toggleAttribute = (k, on_) -> n.setAttribute(k, '')\n      Object.defineProperty n, 'nextSibling',\n        get: ->\n          p = n.parentNode\n          return null unless p\n          i = p.childNodes.indexOf n\n          if i >= 0 and i + 1 < p.childNodes.length then p.childNodes[i + 1] else null\n      Object.defineProperty n, 'isConnected',\n        get: ->\n          x = n\n          while x\n            return true if x._connected\n            x = x.parentNode\n          false\n      n\n    { createElement: mk, createComment: (-> mk('#comment')), createTextNode: (-> mk('#text')) }\n  globalThis.document = mkDoc()\n\n  Child = component\n    @slot := null\n    render\n      input ref: slot\n  Parent = component\n    cell := null\n    render\n      Child\n        slot <=> cell\n  root = document.createElement('root')\n  root._connected = true\n  inst = Parent.new()\n  inst.mount(root)\n  filled = inst.cell.value?.isConnected\n  inst.unmount()\n  \"\#{filled}/\#{inst.cell.value == null}\"", "true/true"
test "dynamic ref (if): cell filled when shown, nulled when hidden", "  mkDoc = ->\n    mk = (tag) ->\n      n = { tag, childNodes: [], parentNode: null, nodeType: (if tag is '#comment' then 8 else 1), _connected: false }\n      n.appendChild = (c) ->\n        c.parentNode.removeChild(c) if c.parentNode\n        c.parentNode = n\n        n.childNodes.push c\n        c\n      n.insertBefore = (c, ref) ->\n        c.parentNode.removeChild(c) if c.parentNode\n        c.parentNode = n\n        i = if ref? then n.childNodes.indexOf(ref) else -1\n        if i >= 0 then n.childNodes.splice(i, 0, c) else n.childNodes.push c\n        c\n      n.removeChild = (c) ->\n        i = n.childNodes.indexOf c\n        n.childNodes.splice(i, 1) if i >= 0\n        c.parentNode = null\n        c\n      n.remove = -> n.parentNode.removeChild(n) if n.parentNode\n      n.setAttribute = (k, v) -> n.attrs = (n.attrs or {}); n.attrs[k] = v\n      n.removeAttribute = (k) -> delete n.attrs[k] if n.attrs\n      n.toggleAttribute = (k, on_) -> n.setAttribute(k, '')\n      Object.defineProperty n, 'nextSibling',\n        get: ->\n          p = n.parentNode\n          return null unless p\n          i = p.childNodes.indexOf n\n          if i >= 0 and i + 1 < p.childNodes.length then p.childNodes[i + 1] else null\n      Object.defineProperty n, 'isConnected',\n        get: ->\n          x = n\n          while x\n            return true if x._connected\n            x = x.parentNode\n          false\n      n\n    { createElement: mk, createComment: (-> mk('#comment')), createTextNode: (-> mk('#text')) }\n  globalThis.document = mkDoc()\n\n  C = component\n    open := false\n    panel := null\n    render\n      div\n        if open\n          section ref: panel\n  root = document.createElement('root')\n  root._connected = true\n  inst = C.new()\n  inst.mount(root)\n  before = inst.panel.value == null\n  inst.open.value = true\n  shown = inst.panel.value?.isConnected\n  inst.open.value = false\n  after = inst.panel.value == null\n  \"\#{before}/\#{shown}/\#{after}\"", "true/true/true"
test "component state access", "A = component\n  x := 5\na = A.new()\na.x.value", 5
test "component state mutation", "A = component\n  x := 10\na = A.new()\na.x.value = 20\na.x.value", 20
test "component computed", "A = component\n  x := 3\n  doubled ~= x * 2\na = A.new()\na.doubled.value", 6
test "component computed reacts to state change", "A = component\n  x := 3\n  doubled ~= x * 2\na = A.new()\na.x.value = 10\na.doubled.value", 20
test "component method", "A = component\n  x := 0\n  inc = -> @x += 1\na = A.new()\na.inc()\na.x.value", 1
test "component readonly prop with default", "A = component\n  @label =! \"default\"\na = A.new()\na.label", "default"
test "component readonly prop from constructor", "A = component\n  @label =! \"default\"\na = A.new({ label: \"custom\" })\na.label", "custom"
test "component public state from constructor", "A = component\n  @count := 0\na = A.new({ count: 42 })\na.count.value", 42
test "extends collects unknown props into _rest", "A = component extends input\n  @label := \"\"\n  render\n    input\na = A.new({ label: \"x\", autofocus: true, maxlength: 10 })\n[a._rest.autofocus, a._rest.maxlength, a._rest.label?]", [true, 10, false]
test "extends rest props can be updated", "A = component extends input\n  render\n    input\na = A.new({ autofocus: true })\na._setRestProp(\"maxlength\", 25)\na._rest.maxlength", 25
test "extends exposes @rest as reactive signal", "A = component extends button\n  render\n    button\na = A.new({ disabled: true, \"data-id\": \"x1\" })\n[typeof a.rest, a.rest.value.disabled, a.rest.value[\"data-id\"]]", ["object", true, "x1"]
test "extends class-merge pattern via @rest in computed", "A = component extends button\n  @variant?: 'primary' | 'secondary' := 'primary'\n  classes ~=\n    parts = []\n    parts.push 'secondary' if @variant is 'secondary'\n    parts.push @rest.class\n    parts\n  render\n    button\n      class: classes\na = A.new({ variant: 'secondary', class: 'mt-4' })\nbefore = a.classes.value.slice()\na._setRestProp('class', ['mb-2', 'mt-4'])\n[before, a.classes.value]", [["secondary", "mt-4"], ["secondary", ["mb-2", "mt-4"]]]
test "optional typed prop without default omitted by caller is undefined at runtime", "  A = component\n    @label?: string\n    render\n      span\n  a = A.new()\n  a._init({})\n  a.label.value", null
test "optional typed prop without default accepts a value", "  A = component\n    @label?: string\n    render\n      span\n  a = A.new(label: \"hi\")\n  a._init(label: \"hi\")\n  a.label.value", "hi"
test "optional typed prop with default falls back when omitted", "  A = component\n    @label?: string := \"fallback\"\n    render\n      span\n  a = A.new()\n  a._init({})\n  a.label.value", "fallback"
test "typed prop with default but no ? still applies the default at runtime", "  A = component\n    @label: string := \"fallback\"\n    render\n      span\n  a = A.new()\n  a._init({})\n  a.label.value", "fallback"
test "component effect runs on state change", "A = component\n  x := 0\n  log =! []\n  ~> @log.push(x + 0)\na = A.new()\na.x.value = 1\na.x.value = 2\na.log", [0, 1, 2]
test "component effect stops on unmount", "A = component\n  x := 0\n  log =! []\n  ~> @log.push(x + 0)\na = A.new()\na.x.value = 1\na.unmount?(removeDOM: false)\na.x.value = 2\na.x.value = 3\na.log", [0, 1]
test "component effect cleanup runs before re-run and on unmount", "A = component\n  x := 0\n  log =! []\n  ~>\n    val = x + 0\n    @log.push(\"setup-\#{val}\")\n    -> @log.push(\"cleanup-\#{val}\")\na = A.new()\na.x.value = 1\na.x.value = 2\na.unmount?(removeDOM: false)\na.log", ["setup-0", "cleanup-0", "setup-1", "cleanup-1", "setup-2", "cleanup-2"]
test "component owns its own effect disposers", "A = component\n  x := 0\n  log =! []\n  ~> @log.push(x + 0)\na = A.new()\na._disposers?.length > 0", true
test "Component.unmount is idempotent", "count = 0\nA = component\n  unmounted = -> count += 1\na = A.new()\na.unmount?(removeDOM: false)\na.unmount?(removeDOM: false)\na.unmount?(removeDOM: false)\ncount", 1
test "effect signal aborts on unmount", "events = []\nA = component\n  ~>\n    signal = getEffectSignal()\n    signal?.addEventListener 'abort', -> events.push 'aborted'\na = A.new()\na.unmount?(removeDOM: false)\nevents", ["aborted"]
test "effect signal aborts on re-run", "aborts = 0\nA = component\n  x := 0\n  ~>\n    v = x + 0\n    signal = getEffectSignal()\n    signal?.addEventListener 'abort', -> aborts += 1\na = A.new()\na.x.value = 1\na.x.value = 2\naborts", 2
test "init failure with handled onError sets _initFailed flag", "caught = null\nBad = component\n  onError = (err) -> caught = err.message\n  _init = -> raise \"boom\"\nbad = Bad.new()\n# onError caught the error (existing semantics) AND _initFailed marks\n# the instance for parent emit-sites to substitute a placeholder.\ncaught is \"boom\" and bad._initFailed is true", true
test "init failure without onError throws from constructor", "Bad = component\n  _init = -> raise \"boom\"\ncaught = null\ntry\n  bad = Bad.new()\ncatch e\n  caught = e.message\ncaught", "boom"
test "async effect: stale resolution does not overwrite current cleanup", "cleanups = []\nA = component\n  x := 0\n  ~>\n    v = x + 0\n    -> cleanups.push(\"cleanup-\#{v}\")\na = A.new()\na.x.value = 1\na.x.value = 2\n# Each run should install its cleanup, prior run's cleanup runs on\n# supersession. Order: setup-0; x=1 fires cleanup-0 then setup-1;\n# x=2 fires cleanup-1 then setup-2. Cleanups so far: ['cleanup-0',\n# 'cleanup-1']. unmount fires cleanup-2.\na.unmount?(removeDOM: false)\ncleanups", ["cleanup-0", "cleanup-1", "cleanup-2"]
test "__pushComponent does not create _parent self-cycle", "A = component\n  val =! \"x\"\na = A.new()\n__pushComponent(a)         # a is now current\n__pushComponent(a)         # re-push while already current\n__popComponent(null)\n__popComponent(null)\na._parent isnt a           # critical invariant", true
test "getContext terminates on cycled parent chain", "A = component\n  val =! \"x\"\na = A.new()\na._parent = a              # poison the chain\n__pushComponent(a)\nresult = getContext(\"missing\")\n__popComponent(null)\nresult is undefined        # returned, did not hang", true
test "__pushComponent preserves _parent across re-pushes", "A = component\n  val =! \"outer\"\nB = component\n  val =! \"inner\"\nouter = A.new()\ninner = B.new()\n__pushComponent(outer)     # outer becomes current\n__pushComponent(inner)     # inner._parent = outer\n__popComponent(outer)\n__popComponent(null)\n__pushComponent(inner)     # re-push inner with no current — must NOT clobber to null\n__popComponent(null)\ninner._parent is outer", true
test "context propagates from outer to inner across re-push", "Outer = component\n  init = -> setContext(\"greeting\", \"hi\")\nInner = component\n  val = null\n  _init = -> @val = getContext(\"greeting\")\nouter = Outer.new()\n__pushComponent(outer)\nouter.init()\ninner = Inner.new()        # constructor runs _init under outer scope\n__popComponent(null)\n__pushComponent(inner)     # later self-push must preserve _parent\nagain = getContext(\"greeting\")\n__popComponent(null)\ninner.val is \"hi\" and again is \"hi\"", true
test "component computed with postfix ternary", "A = component\n  flag := false\n  result ~= \"yes\" if flag else \"no\"\na = A.new()\nbefore = a.result.value\na.flag.value = true\nafter = a.result.value\nbefore + \",\" + after", "no,yes"
code "two-way binding value (text input)", "export A = component\n  name := \"\"\n  render\n    input value <=> name", "export const A = class extends __Component {\n  _init(props) {\n    this.name = __state(\"\");\n  }\n  _create() {\n    this._el0 = document.createElement('input');\n    this._el0.addEventListener('input', (e) => { this.name.value = e.target.value; });\n    return this._el0;\n  }\n  _setup() {\n    __effect(() => { this._el0.value = this.name.value; });\n  }\n}"
code "two-way binding checked (checkbox)", "export A = component\n  active := false\n  render\n    input type: \"checkbox\", checked <=> active", "export const A = class extends __Component {\n  _init(props) {\n    this.active = __state(false);\n  }\n  _create() {\n    this._el0 = document.createElement('input');\n    this._el0.setAttribute('type', \"checkbox\");\n    this._el0.addEventListener('change', (e) => { this.active.value = e.target.checked; });\n    return this._el0;\n  }\n  _setup() {\n    __effect(() => { this._el0.checked = this.active.value; });\n  }\n}"
code "two-way binding valueAsNumber (number input)", "export A = component\n  age := 25\n  render\n    input type: \"number\", value <=> age", "export const A = class extends __Component {\n  _init(props) {\n    this.age = __state(25);\n  }\n  _create() {\n    this._el0 = document.createElement('input');\n    this._el0.setAttribute('type', \"number\");\n    this._el0.addEventListener('input', (e) => { this.age.value = e.target.valueAsNumber; });\n    return this._el0;\n  }\n  _setup() {\n    __effect(() => { this._el0.value = this.age.value; });\n  }\n}"
code "value: reactive is one-way push (use <=> for two-way)", "export A = component\n  name := \"\"\n  render\n    input type: \"text\", value: name", "export const A = class extends __Component {\n  _init(props) {\n    this.name = __state(\"\");\n  }\n  _create() {\n    this._el0 = document.createElement('input');\n    this._el0.setAttribute('type', \"text\");\n    return this._el0;\n  }\n  _setup() {\n    __effect(() => { this._el0.value = this.name.value; });\n  }\n}"
code "dynamic classes with .()", "export A = component\n  isActive := true\n  render\n    div.(\"card\", isActive && \"active\")", "export const A = class extends __Component {\n  _init(props) {\n    this.isActive = __state(true);\n  }\n  _create() {\n    this._el0 = document.createElement('div');\n    return this._el0;\n  }\n  _setup() {\n    __effect(() => { this._el0.className = __clsx(\"card\", (this.isActive.value && \"active\")); });\n  }\n}"
code "combined static + dynamic classes: .card.('flex-1')", "export A = component\n  render\n    .card.(\"flex-1 p-4\")\n      . \"hello\"", "export const A = class extends __Component {\n  _init(props) {\n  }\n  _create() {\n    this._el0 = document.createElement('div');\n    this._el1 = document.createElement('div');\n    this._t0 = document.createTextNode(\"hello\");\n    this._el1.appendChild(this._t0);\n    this._el0.appendChild(this._el1);\n    return this._el0;\n  }\n  _setup() {\n    __effect(() => { this._el0.className = __clsx(\"card\", \"flex-1 p-4\"); });\n  }\n}"
