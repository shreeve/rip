import { test, code, fail, type } from '../support/testing.js'

test 'loop n times', '''
  count = 0
  loop 3
    count++
  count
''', 3

test 'loop n inline', '''
  arr = []
  loop 5
    arr.push arr.length
  arr
''', [0, 1, 2, 3, 4]

test 'loop n with it as counter', '''
  arr = []
  loop 5
    arr.push it
  arr
''', [0, 1, 2, 3, 4]

code 'loop n compiles to for', '''
  loop 3
    console.log 'hi'
''', '''
  for (let it = 0; it < 3; it++) {
    console.log('hi');
  };
'''

test 'loop n as value collects results', '''
  x = loop 3
    "hi"
  x
''', ['hi', 'hi', 'hi']
