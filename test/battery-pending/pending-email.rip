# Pending rows for the email package — packages/ui/email (DOM shim,
# HTML serializer, client-compat layer, email components). The package
# is deferred; these rows come along when it lands. Each row imports
# the modules it exercises, so every row FAILS today (no such package)
# and the lane asserts exactly that; when the package arrives, a row
# that passes must MOVE into test/battery/ in the same change.

import { test, code, fail, type } from '../support/testing.js'

test 'full email renders correctly', '''
  emailRender = import!("#{process.cwd()}/packages/ui/email/render.rip")
  emailPkg = import!("#{process.cwd()}/packages/ui/email/components.rip")
    { toHTML } = emailRender
    { Email, Head, Body, Preview, Container, Heading, Text, Link, Divider } = emailPkg
    WelcomeEmail = component
      @name =! "World"
      render
        Email
          Head
          Preview text: "Welcome aboard"
          Body
            Container
              Heading "Welcome, #{@name}!"
              Text "Thanks for signing up."
              Link href: "https://example.com"
                "Get started"
              Divider
              Text "See you soon."
    result = toHTML(WelcomeEmail, name: "Alice")
    result.includes('<!DOCTYPE') and result.includes('Welcome, Alice!') and result.includes('charset=UTF-8') and result.includes('max-width:37.5em') and result.includes('Get started') and result.includes('border-top:1px solid')
''', true

test 'full email plain text', '''
  emailRender = import!("#{process.cwd()}/packages/ui/email/render.rip")
  emailPkg = import!("#{process.cwd()}/packages/ui/email/components.rip")
    { toText } = emailRender
    { Email, Head, Body, Container, Heading, Text, Link, Divider } = emailPkg
    WelcomeEmail = component
      @name =! "World"
      render
        Email
          Head
          Body
            Container
              Heading "Welcome, #{@name}!"
              Text "Thanks for signing up."
              Link href: "https://example.com"
                "Get started"
    result = toText(WelcomeEmail, name: "Bob")
    result.includes('Welcome, Bob!') and result.includes('Get started (https://example.com)')
''', true

test 'toEmail with conditional', '''
  emailRender = import!("#{process.cwd()}/packages/ui/email/render.rip")
    { toEmail } = emailRender
    TestEmail = component
      @show =! true
      render
        div
          if @show
            p "visible"
    { html } = toEmail(TestEmail, show: true)
    html.includes('<p>visible</p>')
''', true

test 'toEmail with nested native tags', '''
  emailRender = import!("#{process.cwd()}/packages/ui/email/render.rip")
    { toEmail } = emailRender
    TestEmail = component
      render
        table role: "presentation", border: "0", cellpadding: "0", cellspacing: "0"
          tbody
            tr
              td
                p "content"
    { html } = toEmail(TestEmail)
    html.includes('<table') and html.includes('<td><p>content</p></td>')
''', true

test 'toEmail plain text output', '''
  emailRender = import!("#{process.cwd()}/packages/ui/email/render.rip")
    { toEmail } = emailRender
    TestEmail = component
      render
        div
          h1 "Title"
          p "Body text"
          a href: "https://example.com", "Click"
    { text } = toEmail(TestEmail)
    text.includes('Title') and text.includes('Body text') and text.includes('Click (https://example.com)')
''', true
