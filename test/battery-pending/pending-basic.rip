# Pending rows for basic — behaviors the battery does not cover yet.
# Every row here FAILS today; when a feature revives one, MOVE the row
# into test/battery/ in the same change (the lane asserts still-failing).

import { test, code, fail, type } from '../support/testing.js'

test "interpolated string key", "k = \"x\"\no = {\"\#{k}\": 42}\no.x", 42
test "interpolated string key access", "n = \"name\"\no = {\"\#{n}\": \"Alice\"}\no.name", "Alice"
test "dotted key simple", "o = { a.b: 1 }; o[\"a.b\"]", 1
test "dotted key triple", "o = { one.two.three: 44 }; o[\"one.two.three\"]", 44
test "dotted key mixed", "o = { one.two.three: 44, five: 66 }; o[\"one.two.three\"] + o.five", 110
code "dotted key codegen", "{ a.b: 1 }", "({'a.b': 1})"
code "dotted key triple codegen", "{ one.two.three: 44 }", "({'one.two.three': 44})"
test "dotted key implicit object", "a =\n  x.y:\n    z: 1\na[\"x.y\"].z", 1
test "dotted key implicit siblings", "a =\n  x.y: 1\n  w.z: 2\na[\"x.y\"] + a[\"w.z\"]", 3
test "hyphen key simple", "o = { data-src: 1 }; o[\"data-src\"]", 1
test "hyphen key triple", "o = { a-b-c: 7 }; o[\"a-b-c\"]", 7
test "hyphen key implicit siblings", "a =\n  data-src: 1\n  data-foo-bar: 2\na[\"data-src\"] + a[\"data-foo-bar\"]", 3
test "hyphen key mixed with normal", "o = { data-x: 1, static: 2, foo-bar-baz: 4 }; o[\"data-x\"] + o.static + o[\"foo-bar-baz\"]", 7
code "hyphen key codegen", "{ data-src: 1 }", "({'data-src': 1})"
test "mixed key dot-hyphen", "o = { beta-site.amazon.com: 100 }; o[\"beta-site.amazon.com\"]", 100
test "mixed key hyphen-dot", "o = { api.v1-beta.example.com: 200 }; o[\"api.v1-beta.example.com\"]", 200
code "mixed key codegen", "{ beta-site.amazon.com: 1 }", "({'beta-site.amazon.com': 1})"
test "compound key in class-body property", "  class Setting\n    data-src: \"default\"\n    api.host: \"localhost\"\n  s = new Setting()\n  [s[\"data-src\"], s[\"api.host\"]]", ["default", "localhost"]
test "compound key tolerates block comment between parts", "  o = { foo-###x###bar: 7 }\n  o[\"foo-bar\"]", 7
