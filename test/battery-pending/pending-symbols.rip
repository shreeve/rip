# Pending rows for symbols — behaviors the battery does not cover yet.
# Every row here FAILS today; when a feature revives one, MOVE the row
# into test/battery/ in the same change (the lane asserts still-failing).

import { test, code, fail, type } from '../support/testing.js'

code "symbol literal", ":redo", "Symbol.for(\"redo\")"
code "symbol literal skip", ":skip", "Symbol.for(\"skip\")"
code "symbol literal with underscore", ":foo_bar", "Symbol.for(\"foo_bar\")"
code "symbol literal with digits", ":item2", "Symbol.for(\"item2\")"
code "symbol literal dollar", ":$special", "Symbol.for(\"$special\")"
test "symbol typeof", "typeof :redo", "symbol"
test "symbol identity", ":redo is :redo", true
test "symbol inequality", ":redo isnt :skip", true
test "symbol description", ":hello.description", "hello"
test "symbol assignment", "x = :done; typeof x", "symbol"
test "symbol readonly", "x =! :frozen; x is :frozen", true
test "symbol in array", "arr = [:a, :b, :c]; arr.length", 3
test "symbol array identity", "arr = [:x]; arr[0] is :x", true
test "symbol as object value", "obj = {status: :active}; obj.status is :active", true
test "symbol in object literal", "obj = {a: :one, b: :two}; obj.a is :one and obj.b is :two", true
test "symbol as argument", "fn = (x) -> x is :yes\nfn(:yes)", true
test "symbol multiple args", "fn = (a, b) -> a is :x and b is :y\nfn(:x, :y)", true
test "symbol equality", ":abc is :abc", true
test "symbol with switch", "x = :red\nswitch x\n  when :red then \"stop\"\n  when :green then \"go\"\n  else \"unknown\"", "stop"
test "ternary with spaces", "true ? :yes : :no"
test "object with symbol value", "{key: :val}.key is :val", true
test "symbols are interned across expressions", "a = :hello\nb = :hello\na is b", true
test "symbol matches Symbol.for", ":test is Symbol.for(\"test\")", true
