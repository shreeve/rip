# Pending rows for control — behaviors the battery does not cover yet.
# Every row here FAILS today; when a feature revives one, MOVE the row
# into test/battery/ in the same change (the lane asserts still-failing).

import { test, code, fail, type } from '../support/testing.js'

code "or throw assignment generates if", "  data = fetchData() or throw new Error 'No data'", "let data;\n\nif (!(data = fetchData())) throw new Error('No data');"
code "and throw assignment generates if", "  error = validate() and throw error", "let error;\n\nif ((error = validate())) throw error;"
code "standalone and throw generates if", "  isError and throw new Error 'Failed'", "if (isError) throw new Error('Failed');"
code "?? throw assignment generates if with nullish check", "  data = getValue() ?? throw new Error 'Missing'", "let data;\n\nif ((data = getValue()) == null) throw new Error('Missing');"
code "standalone ?? throw generates if with nullish check", "  getValue() ?? throw new Error 'Not found'", "if ((getValue()) == null) throw new Error('Not found');"
fail "nested ternary in then branch", "x = true ? (false ? \"a\" : \"b\") : \"c\"", null
code "or-throw in sibling exports hoists variable in each function", "export first = (data) ->\n  store = getData() or throw new Error 'no context'\n  store.value\n\nexport second = ->\n  store = getData()\n  store", "export const first = (function(data) {\n  let store;\n  if (!(store = getData())) throw new Error('no context');\n  return store.value;\n});\nexport const second = (function() {\n  let store;\n  store = getData();\n  return store;\n});"
test "bare try expression returns value on success", "  x = try 42\n  x", 42
test "bare try expression returns undefined on throw", "  x = try (throw new Error('boom'))\n  x", null
test "bare try statement swallows error", "  try (throw new Error('boom'))\n  'ok'", "ok"
code "bare try statement generates catch {}", "try foo()", "try {\n  foo();\n} catch {}"
