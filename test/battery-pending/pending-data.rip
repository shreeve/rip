# Pending rows for data — behaviors the battery does not cover yet.
# Every row here FAILS today; when a feature revives one, MOVE the row
# into test/battery/ in the same change (the lane asserts still-failing).

import { test, code, fail, type } from '../support/testing.js'

test 'data marker simple', '''
  x = DATA
  x
  __DATA__
  hello world
''', '''
  hello world

'''

test 'data marker length', '''
  DATA.length
  __DATA__
  test
''', 5

test 'data marker empty', '''
  DATA
  __DATA__
''', ''

test 'data marker multiline', '''
  lines = DATA.split("\\n").filter (l) -> l
  lines.length
  __DATA__
  line1
  line2
  line3
''', 3

test 'data marker first line', '''
  DATA.split("\\n")[0]
  __DATA__
  first
  second
''', 'first'

test 'data marker last line', '''
  lines = DATA.trim().split("\\n")
  lines[lines.length - 1]
  __DATA__
  first
  second
  last
''', 'last'

test 'data marker config', '''
  config = {}
  for line in DATA.split("\\n") when line.trim()
    [key, val] = line.split("=")
    config[key] = val
  config.port
  __DATA__
  host=localhost
  port=8080
  debug=true
''', '8080'

test 'data marker csv', '''
  rows = DATA.trim().split("\\n").map (line) ->
    line.split(",")
  rows[0][0]
  __DATA__
  Alice,alice@example.com
  Bob,bob@example.com
''', 'Alice'

test 'data marker template', '''
  template = DATA
  template.replace("{{name}}", "Alice")
  __DATA__
  Hello, {{name}}!
''', '''
  Hello, Alice!

'''

code 'data marker compiler', '''
  x = 42
  console.log DATA
  __DATA__
  test data
''', '''
    let x;

    var DATA;
    _setDataSection();

    x = 42;
    console.log(DATA);

    function _setDataSection() {
      DATA = "test data\\n";
    }
'''

code 'data marker hoisting', '''
  console.log DATA
  __DATA__
  hoisted!
''', '''
    var DATA;
    _setDataSection();

    console.log(DATA);

    function _setDataSection() {
      DATA = "hoisted!\\n";
    }
'''

test 'data marker only', '''
  DATA
  __DATA__
  just data
''', '''
  just data

'''

test 'data marker special chars', '''
  DATA.includes("@")
  __DATA__
  test@example.com
''', true

test 'data marker quotes', '''
  DATA.includes("'")
  __DATA__
  It's working!
''', true

test 'data marker whitespace', '''
  DATA[0]
  __DATA__
    indented
''', ' '

test 'data marker users', '''
  users = DATA.trim().split("\\n").map (line) ->
    [name, email] = line.split(",")
    {name, email}
  users[1].name
  __DATA__
  Alice,alice@example.com
  Bob,bob@example.com
  Charlie,charlie@example.com
''', 'Bob'

test 'data marker json', '''
  obj = JSON.parse(DATA)
  obj.name
  __DATA__
  {"name": "Alice", "age": 30}
''', 'Alice'

test 'data marker env parsing', '''
  env = {}
  for line in DATA.split("\\n") when line and not line.startsWith("#")
    parts = line.split("=")
    if parts.length is 2
      [key, val] = parts
      env[key.trim()] = val.trim()
  env.PORT
  __DATA__
  # Config
  HOST=localhost
  PORT=3000
''', '3000'
