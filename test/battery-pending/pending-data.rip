'''

code 'data marker compiler', '''
  x = 42
  console.log DATA
  __DATA__
  test data
''', '''
    let x;

    var DATA;
    _setDataSection();

    x = 42;
    console.log(DATA);

    function _setDataSection() {
      DATA = "test data\\n";
    }
'''

code 'data marker hoisting', '''
  console.log DATA
  __DATA__
  hoisted!
''', '''
    var DATA;
    _setDataSection();

    console.log(DATA);

    function _setDataSection() {
      DATA = "hoisted!\\n";
    }
'''

test 'data marker only', '''
  DATA
  __DATA__
  just data
''', '''
  just data

'''
