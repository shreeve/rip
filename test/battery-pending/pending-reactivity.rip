# Pending rows for reactivity — behaviors the battery does not cover yet.
# Every row here FAILS today; when a feature revives one, MOVE the row
# into test/battery/ in the same change (the lane asserts still-failing).

import { test, code, fail, type } from '../support/testing.js'

test 'component with state', '''
  A = component
    x := 5
  a = A.new()
  a.x.value
''', 5

test 'component state mutation', '''
  A = component
    x := 10
  a = A.new()
  a.x.value = 20
  a.x.value
''', 20

test 'component signal read', '''
  A = component
    x := 5
  a = A.new()
  a.x.read()
''', 5

test 'component readonly prop via constructor', '''
  A = component
    @label =! "default"
  a = A.new({ label: "custom" })
  a.label
''', 'custom'

test 'readonly prop receives value not signal', '''
  A = component
    @label =! "hello"
  a = A.new label: "world"
  a.label
''', 'world'

test 'computed with postfix ternary false branch', '''
  A = component
    flag := false
    result ~= "yes" if flag else "no"
  a = A.new()
  a.result.value
''', 'no'

test 'computed with postfix ternary true branch', '''
  A = component
    flag := true
    result ~= "yes" if flag else "no"
  a = A.new()
  a.result.value
''', 'yes'

test 'computed with postfix ternary reacts to state change', '''
  A = component
    flag := false
    result ~= "yes" if flag else "no"
  a = A.new()
  before = a.result.value
  a.flag.value = true
  after = a.result.value
  before + "," + after
''', 'no,yes'

test 'computed with postfix ternary using nullable object', '''
  A = component
    user := null
    dest ~= "/bookings" if user else "/auth"
  a = A.new()
  before = a.dest.value
  a.user.value = { name: "Steve" }
  after = a.dest.value
  before + "," + after
''', '/auth,/bookings'

code 'computed postfix ternary compiles to JS ternary', '''
  export Foo = component
    user := null
    href ~= "/b" if user else "/a"
    render
      div "hello"
''', '''
  export const Foo = class extends __Component {
    _init(props) {
      this.user = __state(null);
      this.href = __computed(() => (this.user.value ? "/b" : "/a"));
    }
    _create() {
      this._el0 = document.createElement('div');
      this._t0 = document.createTextNode("hello");
      this._el0.appendChild(this._t0);
      return this._el0;
    }
  }
'''

code 'render block with identifier property value compiles to reactive setAttribute', '''
  export Bar = component
    user := null
    href ~= "/b" if user else "/a"
    render
      a href: href
        "click"
''', '''
  export const Bar = class extends __Component {
    _init(props) {
      this.user = __state(null);
      this.href = __computed(() => (this.user.value ? "/b" : "/a"));
    }
    _create() {
      this._el0 = document.createElement('a');
      this._t0 = document.createTextNode("click");
      this._el0.appendChild(this._t0);
      return this._el0;
    }
    _setup() {
      __effect(() => { this._el0.setAttribute('href', this.href.value); });
    }
  }
'''
