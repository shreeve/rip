# Pending rows for schema — behaviors the battery does not cover yet.
# Every row here FAILS today; when a feature revives one, MOVE the row
# into test/battery/ in the same change (the lane asserts still-failing).

import { test, code, fail, type } from '../support/testing.js'

code "schema as variable still works", "export schema = 42\nschema + 1", "export const schema = 42;\n(schema + 1);"
code "inline: trailing semicolon before newline", "X = schema :shape; name!;\ny = 1", "let X, y;\nX = __schema({kind: \"shape\", name: \"X\", entries: [{tag: \"field\", name: \"name\", modifiers: [\"!\"], typeName: \"string\", array: false}]});\ny = 1;"
test "default-string: required+unique without explicit type", "U = schema :shape\n  code! @unique\nU.ok({code: \"abc\"})", true
fail "open-ended: bare '..' is rejected", "X = schema\n  name! ..", null
code "required @unique + ..N implies min=1", "X = schema\n  token! ..60, @unique", "let X;\nX = __schema({kind: \"input\", name: \"X\", entries: [{tag: \"field\", name: \"token\", modifiers: [\"!\"], typeName: \"string\", array: false, unique: true, constraints: {min: 1, max: 60}}]});"
test "diamond mixin inclusion dedupes", "  Base = schema :mixin\n    id! uuid\n  Left = schema :mixin\n    left! string\n    @mixin Base\n  Right = schema :mixin\n    right! string\n    @mixin Base\n  User = schema :model\n    name! string\n    @mixin Left\n    @mixin Right\n  [...User._normalize().fields.keys()]", ["name", "id", "left", "right"]
test "algebra preserves sourceModel through chain", "  User = schema :model\n    name! string\n    email! email\n  A = User.pick(\"name\")\n  B = A.partial()\n  [A._sourceModel is User, B._sourceModel is User]", [true, true]
code "fold: pick emits a self-contained shape literal", "User = schema :model\n  name! string\n  @timestamps\nV = User.pick(\"id\", \"name\")", "let User, V;\nUser = __schema({kind: \"model\", name: \"User\", entries: [{tag: \"field\", name: \"name\", modifiers: [\"!\"], typeName: \"string\", array: false}, {tag: \"directive\", name: \"timestamps\"}]});\nV = __schema({kind: \"shape\", name: \"V\", entries: [{tag: \"field\", name: \"id\", modifiers: [\"!\"], typeName: \"integer\", array: false}, {tag: \"field\", name: \"name\", modifiers: [\"!\"], typeName: \"string\", array: false}]});"
test ".includes(:orders) batches one IN query and fills the memo", "  adapter =\n    calls: []\n    canned: {}\n    query: (sql, params) ->\n      @calls.push {sql, params}\n      if @canned[sql] then @canned[sql] else (@canned.__default ?? {columns: [], data: [], rows: 0})\n  __schemaSetAdapter adapter\n  __SchemaRegistry.reset()\n  User = schema :model\n    name! string\n    @has_many Order\n  Order = schema :model\n    total! integer\n    @belongs_to User\n  adapter.canned['SELECT * FROM \"users\"'] =\n    {columns: [{name: \"id\"}, {name: \"name\"}], data: [[1, \"A\"], [2, \"B\"]], rows: 2}\n  adapter.canned['SELECT * FROM \"orders\" WHERE \"user_id\" IN (?, ?)'] =\n    {columns: [{name: \"id\"}, {name: \"total\"}, {name: \"user_id\"}], data: [[7, 100, 1], [8, 50, 1], [9, 25, 2]], rows: 3}\n  users = User.includes(:orders).all!\n  queries = adapter.calls.length\n  a = users[0].orders!\n  b = users[1].orders!\n  [queries, adapter.calls.length, a.length, b.length, a[0].total]", [2, 2, 2, 1, 100]
test ".includes(:user) on belongs_to batches via findMany; instances shared", "  adapter =\n    calls: []\n    canned: {}\n    query: (sql, params) ->\n      @calls.push {sql, params}\n      if @canned[sql] then @canned[sql] else (@canned.__default ?? {columns: [], data: [], rows: 0})\n  __schemaSetAdapter adapter\n  __SchemaRegistry.reset()\n  User = schema :model\n    name! string\n    @has_many Order\n  Order = schema :model\n    total! integer\n    @belongs_to User\n  adapter.canned['SELECT * FROM \"orders\"'] =\n    {columns: [{name: \"id\"}, {name: \"total\"}, {name: \"user_id\"}], data: [[7, 100, 1], [8, 50, 1]], rows: 2}\n  adapter.canned['SELECT * FROM \"users\" WHERE \"id\" IN (?)'] =\n    {columns: [{name: \"id\"}, {name: \"name\"}], data: [[1, \"A\"]], rows: 1}\n  orders = Order.includes(:user).all!\n  u1 = orders[0].user!\n  u2 = orders[1].user!\n  [adapter.calls.length, u1.name, u1 is u2]", [2, "A", true]
test "nested includes: {orders: :user} preloads two levels", "  adapter =\n    calls: []\n    canned: {}\n    query: (sql, params) ->\n      @calls.push {sql, params}\n      if @canned[sql] then @canned[sql] else (@canned.__default ?? {columns: [], data: [], rows: 0})\n  __schemaSetAdapter adapter\n  __SchemaRegistry.reset()\n  User = schema :model\n    name! string\n    @has_many Order\n  Order = schema :model\n    total! integer\n    @belongs_to User\n  adapter.canned['SELECT * FROM \"users\"'] =\n    {columns: [{name: \"id\"}, {name: \"name\"}], data: [[1, \"A\"], [2, \"B\"]], rows: 2}\n  adapter.canned['SELECT * FROM \"orders\" WHERE \"user_id\" IN (?, ?)'] =\n    {columns: [{name: \"id\"}, {name: \"total\"}, {name: \"user_id\"}], data: [[7, 100, 1], [8, 50, 2]], rows: 2}\n  adapter.canned['SELECT * FROM \"users\" WHERE \"id\" IN (?, ?)'] =\n    {columns: [{name: \"id\"}, {name: \"name\"}], data: [[1, \"A\"], [2, \"B\"]], rows: 2}\n  users = User.includes(orders: :user).all!\n  total = adapter.calls.length\n  orders = users[0].orders!\n  owner = orders[0].user!\n  [total, adapter.calls.length, owner.name]", [3, 3, "A"]
test ".includes with unknown relation throws a helpful error", "  adapter =\n    calls: []\n    canned: {}\n    query: (sql, params) ->\n      @calls.push {sql, params}\n      if @canned[sql] then @canned[sql] else (@canned.__default ?? {columns: [], data: [], rows: 0})\n  __schemaSetAdapter adapter\n  __SchemaRegistry.reset()\n  User = schema :model\n    name! string\n  adapter.canned.__default = {columns: [{name: \"id\"}, {name: \"name\"}], data: [[1, \"A\"]], rows: 1}\n  err = null\n  try\n    User.includes(:bogus).all!\n  catch e\n    err = e.message\n  [err.includes(\"bogus\"), err.includes(\"no such relation\")]", [true, true]
test ".upsert! emits ON CONFLICT DO UPDATE; branch hooks skipped", "  adapter =\n    calls: []\n    canned: {}\n    query: (sql, params) ->\n      @calls.push {sql, params}\n      if @canned[sql] then @canned[sql] else (@canned.__default ?? {columns: [], data: [], rows: 0})\n  __schemaSetAdapter adapter\n  __SchemaRegistry.reset()\n  trace = []\n  User = schema :model\n    name! string\n    email! email @unique\n    beforeSave:   -> trace.push \"beforeSave\"\n    beforeCreate: -> trace.push \"beforeCreate\"\n    beforeUpdate: -> trace.push \"beforeUpdate\"\n    afterSave:    -> trace.push \"afterSave\"\n  adapter.canned.__default = {columns: [{name: \"id\"}, {name: \"name\"}, {name: \"email\"}], data: [[1, \"Alice\", \"a@b.c\"]], rows: 1}\n  u = User.upsert! {email: \"a@b.c\", name: \"Alice\"}, on: :email\n  sql = adapter.calls[0].sql\n  [sql.includes('ON CONFLICT (\"email\") DO UPDATE SET'), sql.includes('\"name\" = EXCLUDED.\"name\"'), trace, u.id, u._persisted]", [true, true, ["beforeSave", "afterSave"], 1, true]
test "~:name resolves through the registry; output validates and constrains", "  __ripSchema.__schemaRegisterCoercer \"id\", (v) ->\n    m = v.match(/^([1-9]\\d{0,14})$/)\n    if m then parseInt(m[1]) else null\n  __ripSchema.__schemaRegisterCoercer \"ssn\", (v) ->\n    m = v.match(/^(\\d{3})-?(\\d{2})-?(\\d{4})$/)\n    if m then m[1] + m[2] + m[3] else null\n  X = schema\n    chart! ~:id, 1..99999\n    ssn?   ~:ssn\n  a = X.parse {chart: \"42\", ssn: \"123-45-6789\"}\n  r1 = X.safe {chart: \"0\"}\n  r2 = X.safe {chart: \"999999999\"}\n  [a.chart, a.ssn, r1.errors[0].error, r2.errors[0].error]", [42, "123456789", "coerce", "max"]
test "~:name failures use the coercer's name in the issue", "  __ripSchema.__schemaRegisterCoercer \"state2\", (v) ->\n    m = v.match(/^([a-z][a-z])$/i)\n    if m then m[1].toUpperCase() else null\n  X = schema\n    state? ~:state2\n  r = X.safe {state: \"utah\"}\n  [r.errors[0].field, r.errors[0].error, r.errors[0].message]", ["state", "coerce", "state is not a valid state2"]
test "custom ~:name coercers type as any — value-typed constraints still apply", "  __ripSchema.__schemaRegisterCoercer \"evenInt\", (v) ->\n    n = parseInt(v, 10)\n    if Number.isInteger(n) and n % 2 is 0 then n else null\n  X = schema\n    n? ~:evenInt, 0..10\n  a = X.parse {n: \"4\"}\n  r = X.safe {n: \"3\"}\n  r2 = X.safe {n: \"12\"}\n  [a.n, r.errors[0].error, r2.errors[0].error]", [4, "coerce", "max"]
test "methods accept parameters (typed and untyped) at runtime", "  Money = schema :shape\n    amount!   integer\n    currency! string, 3..3\n    add: (other: Money) ->\n      Money.parse {amount: @amount + other.amount, currency: @currency}\n    scaled: (factor, label) ->\n      label + (@amount * factor)\n  a = Money.parse {amount: 100, currency: \"USD\"}\n  b = a.add(Money.parse {amount: 25, currency: \"USD\"})\n  [b.amount, a.scaled(2, \"x\")]", [125, "x200"]
test "transaction! on: pins one adapter; other-adapter calls run outside", "  calls = {a: [], b: []}\n  mk = (tag) ->\n    adapter = {}\n    adapter.query = (sql, params) ->\n      calls[tag].push sql\n      {columns: [{name: \"id\"}, {name: \"name\"}], data: [[1, \"x\"]], rows: 1}\n    adapter.begin = ->\n      calls[tag].push \"BEGIN\"\n      handle = {}\n      handle.query = (sql) ->\n        calls[tag].push \"tx:\" + sql.split(\" \")[0]\n        {columns: [], data: [], rows: 0}\n      handle.commit = -> calls[tag].push \"COMMIT\"\n      handle.rollback = -> calls[tag].push \"ROLLBACK\"\n      handle\n    adapter\n  __schemaSetAdapter mk(\"a\")\n  __SchemaRegistry.reset()\n  analytics = mk(\"b\")\n  User = schema :model\n    name! string\n  Event = schema :model, on: analytics\n    name! string\n  schema.transaction! on: analytics, ->\n    Event.create! name: \"e\"\n    User.create! name: \"u\"\n    null\n  txB = calls.b.filter (s) -> s.startsWith(\"tx:\")\n  txA = calls.a.filter (s) -> s.startsWith(\"tx:\")\n  [txB.length, txA.length, calls.b.includes(\"COMMIT\"), calls.a.includes(\"BEGIN\")]", [1, 0, true, false]
test "@unique survives mixin expansion", "  adapter =\n    calls: []\n    canned: {}\n    query: (sql, params) ->\n      @calls.push {sql, params}\n      if @canned[sql] then @canned[sql] else (@canned.__default ?? {columns: [], data: [], rows: 0})\n  __schemaSetAdapter adapter\n  __SchemaRegistry.reset()\n  Keyed = schema :mixin\n    code! string @unique\n  Thing = schema :model\n    @mixin Keyed\n    name! string\n  Thing._tableSpec().indexes.map (i) -> i.name + (i.unique ? \"!\" : \"\")", ["idx_things_code!"]
test "diff: empty database plans CREATE for every model", "  deployed = {tables: []}\n  history  = []\n  calls    = []\n  adapter =\n    introspect: -> deployed\n    query: (sql, params) ->\n      calls.push {sql, params}\n      if sql.startsWith(\"SELECT version\")\n        {columns: [{name: \"version\"}, {name: \"name\"}, {name: \"checksum\"}, {name: \"applied_at\"}], data: history.map((h) -> [h.version, h.name, h.checksum, null]), rows: history.length}\n      else if sql.startsWith(\"INSERT INTO _rip_migrations\")\n        history.push {version: params[0], name: params[1], checksum: params[2]}\n        {columns: [], data: [], rows: 1}\n      else\n        {columns: [], data: [], rows: 0}\n  __schemaSetAdapter adapter\n  __SchemaRegistry.reset()\n  User = schema :model\n    name! string\n  Order = schema :model\n    total! integer\n    @belongs_to User\n  steps = schema.plan!\n  kinds = steps.map (s) -> s.kind + \":\" + s.class\n  out = [\n    steps.length\n    kinds\n    steps[0].sql.join(\"\\n\").includes(\"CREATE TABLE users\")\n    steps[1].sql.join(\"\\n\").includes(\"user_id INTEGER NOT NULL REFERENCES users(id)\")\n  ]\n  out", [2, ["create-table:safe", "create-table:safe"], true, true]
test "diff: matching database plans nothing (round-trip clean)", "  deployed = {tables: []}\n  history  = []\n  calls    = []\n  adapter =\n    introspect: -> deployed\n    query: (sql, params) ->\n      calls.push {sql, params}\n      if sql.startsWith(\"SELECT version\")\n        {columns: [{name: \"version\"}, {name: \"name\"}, {name: \"checksum\"}, {name: \"applied_at\"}], data: history.map((h) -> [h.version, h.name, h.checksum, null]), rows: history.length}\n      else if sql.startsWith(\"INSERT INTO _rip_migrations\")\n        history.push {version: params[0], name: params[1], checksum: params[2]}\n        {columns: [], data: [], rows: 1}\n      else\n        {columns: [], data: [], rows: 0}\n  __schemaSetAdapter adapter\n  __SchemaRegistry.reset()\n  User = schema :model\n    name!   string, 1..100\n    email!  email @unique\n    @timestamps\n  deployed.tables = [{\n    name: \"users\"\n    sequence: {name: \"users_seq\", start: 1}\n    primaryKey: \"id\"\n    columns: [\n      {name: \"id\", type: \"INTEGER\", notNull: true, unique: false, primary: true, default: \"nextval('users_seq')\"}\n      {name: \"name\", type: \"VARCHAR\", notNull: true, unique: false, default: null}\n      {name: \"email\", type: \"VARCHAR\", notNull: true, unique: true, default: null}\n      {name: \"created_at\", type: \"TIMESTAMP\", notNull: false, unique: false, default: \"CURRENT_TIMESTAMP\"}\n      {name: \"updated_at\", type: \"TIMESTAMP\", notNull: false, unique: false, default: \"now()\"}\n    ]\n    indexes: [{name: \"idx_users_email\", columns: [\"email\"], unique: true}]\n    foreignKeys: []\n    tableWas: null\n  }]\n  steps = schema.plan!\n  steps.length", 0
test "diff: added columns classify by shape (optional / default / required / unique)", "  deployed = {tables: []}\n  history  = []\n  calls    = []\n  adapter =\n    introspect: -> deployed\n    query: (sql, params) ->\n      calls.push {sql, params}\n      if sql.startsWith(\"SELECT version\")\n        {columns: [{name: \"version\"}, {name: \"name\"}, {name: \"checksum\"}, {name: \"applied_at\"}], data: history.map((h) -> [h.version, h.name, h.checksum, null]), rows: history.length}\n      else if sql.startsWith(\"INSERT INTO _rip_migrations\")\n        history.push {version: params[0], name: params[1], checksum: params[2]}\n        {columns: [], data: [], rows: 1}\n      else\n        {columns: [], data: [], rows: 0}\n  __schemaSetAdapter adapter\n  __SchemaRegistry.reset()\n  User = schema :model\n    name!  string\n    bio?   text\n    plan?  string, [\"free\"]\n    code!  string\n    tag!   string @unique\n  deployed.tables = [{\n    name: \"users\", sequence: {name: \"users_seq\", start: 1}, primaryKey: \"id\"\n    columns: [\n      {name: \"id\", type: \"INTEGER\", notNull: true, unique: false, primary: true, default: \"nextval('users_seq')\"}\n      {name: \"name\", type: \"VARCHAR\", notNull: true, unique: false, default: null}\n    ]\n    indexes: [], foreignKeys: [], tableWas: null\n  }]\n  steps = schema.plan!\n  byKind = {}\n  for s in steps\n    byKind[s.sql[0].match(/ADD COLUMN (\\w+)/)?[1] ?? s.kind] = s\n  hasTodo = byKind.code.sql.some (l) -> l.includes(\"TODO: backfill\")\n  hasUniq = byKind.tag.sql.some (l) -> l.includes(\"CREATE UNIQUE INDEX idx_users_tag\")\n  out = [\n    byKind.bio.sql.length\n    byKind.plan.sql[0].includes(\"DEFAULT 'free'\")\n    hasTodo\n    byKind.code.sql[byKind.code.sql.length - 1].includes(\"SET NOT NULL\")\n    hasUniq\n  ]\n  out", [1, true, true, true, true]
test "diff: drops are destructive; type/null changes classify lossy/safe", "  deployed = {tables: []}\n  history  = []\n  calls    = []\n  adapter =\n    introspect: -> deployed\n    query: (sql, params) ->\n      calls.push {sql, params}\n      if sql.startsWith(\"SELECT version\")\n        {columns: [{name: \"version\"}, {name: \"name\"}, {name: \"checksum\"}, {name: \"applied_at\"}], data: history.map((h) -> [h.version, h.name, h.checksum, null]), rows: history.length}\n      else if sql.startsWith(\"INSERT INTO _rip_migrations\")\n        history.push {version: params[0], name: params[1], checksum: params[2]}\n        {columns: [], data: [], rows: 1}\n      else\n        {columns: [], data: [], rows: 0}\n  __schemaSetAdapter adapter\n  __SchemaRegistry.reset()\n  User = schema :model\n    name!  string\n    age?   integer\n  deployed.tables = [{\n    name: \"users\", sequence: {name: \"users_seq\", start: 1}, primaryKey: \"id\"\n    columns: [\n      {name: \"id\", type: \"INTEGER\", notNull: true, unique: false, primary: true, default: \"nextval('users_seq')\"}\n      {name: \"name\", type: \"VARCHAR\", notNull: false, unique: false, default: null}\n      {name: \"age\", type: \"VARCHAR\", notNull: true, unique: false, default: null}\n      {name: \"legacy\", type: \"VARCHAR\", notNull: false, unique: false, default: null}\n    ]\n    indexes: [], foreignKeys: [], tableWas: null\n  }, {\n    name: \"ghosts\", sequence: null, primaryKey: \"id\"\n    columns: [{name: \"id\", type: \"INTEGER\", notNull: true, unique: false, primary: true, default: null}]\n    indexes: [], foreignKeys: [], tableWas: null\n  }]\n  steps = schema.plan!\n  kinds = steps.map((s) -> s.kind + \":\" + s.class).sort()\n  kinds", ["alter-type:lossy", "drop-column:destructive", "drop-not-null:safe", "drop-table:destructive", "set-not-null:lossy"]
test "diff: VARCHAR length hints never produce drift (DuckDB erases them)", "  deployed = {tables: []}\n  history  = []\n  calls    = []\n  adapter =\n    introspect: -> deployed\n    query: (sql, params) ->\n      calls.push {sql, params}\n      if sql.startsWith(\"SELECT version\")\n        {columns: [{name: \"version\"}, {name: \"name\"}, {name: \"checksum\"}, {name: \"applied_at\"}], data: history.map((h) -> [h.version, h.name, h.checksum, null]), rows: history.length}\n      else if sql.startsWith(\"INSERT INTO _rip_migrations\")\n        history.push {version: params[0], name: params[1], checksum: params[2]}\n        {columns: [], data: [], rows: 1}\n      else\n        {columns: [], data: [], rows: 0}\n  __schemaSetAdapter adapter\n  __SchemaRegistry.reset()\n  User = schema :model\n    name! string, 1..100\n  deployed.tables = [{\n    name: \"users\", sequence: {name: \"users_seq\", start: 1}, primaryKey: \"id\"\n    columns: [\n      {name: \"id\", type: \"INTEGER\", notNull: true, unique: false, primary: true, default: \"nextval('users_seq')\"}\n      {name: \"name\", type: \"VARCHAR\", notNull: true, unique: false, default: null}\n    ]\n    indexes: [], foreignKeys: [], tableWas: null\n  }]\n  steps = schema.plan!\n  steps.length", 0
test "rename: {was: ...} emits RENAME COLUMN instead of drop + add", "  deployed = {tables: []}\n  history  = []\n  calls    = []\n  adapter =\n    introspect: -> deployed\n    query: (sql, params) ->\n      calls.push {sql, params}\n      if sql.startsWith(\"SELECT version\")\n        {columns: [{name: \"version\"}, {name: \"name\"}, {name: \"checksum\"}, {name: \"applied_at\"}], data: history.map((h) -> [h.version, h.name, h.checksum, null]), rows: history.length}\n      else if sql.startsWith(\"INSERT INTO _rip_migrations\")\n        history.push {version: params[0], name: params[1], checksum: params[2]}\n        {columns: [], data: [], rows: 1}\n      else\n        {columns: [], data: [], rows: 0}\n  __schemaSetAdapter adapter\n  __SchemaRegistry.reset()\n  User = schema :model\n    givenName! string, {was: \"first_name\"}\n  deployed.tables = [{\n    name: \"users\", sequence: {name: \"users_seq\", start: 1}, primaryKey: \"id\"\n    columns: [\n      {name: \"id\", type: \"INTEGER\", notNull: true, unique: false, primary: true, default: \"nextval('users_seq')\"}\n      {name: \"first_name\", type: \"VARCHAR\", notNull: true, unique: false, default: null}\n    ]\n    indexes: [], foreignKeys: [], tableWas: null\n  }]\n  steps = schema.plan!\n  [steps.length, steps[0].kind, steps[0].sql[0]]", [1, "rename-column", "ALTER TABLE users RENAME COLUMN first_name TO given_name;"]
test "rename: @tableWas emits RENAME TO and then diffs columns", "  deployed = {tables: []}\n  history  = []\n  calls    = []\n  adapter =\n    introspect: -> deployed\n    query: (sql, params) ->\n      calls.push {sql, params}\n      if sql.startsWith(\"SELECT version\")\n        {columns: [{name: \"version\"}, {name: \"name\"}, {name: \"checksum\"}, {name: \"applied_at\"}], data: history.map((h) -> [h.version, h.name, h.checksum, null]), rows: history.length}\n      else if sql.startsWith(\"INSERT INTO _rip_migrations\")\n        history.push {version: params[0], name: params[1], checksum: params[2]}\n        {columns: [], data: [], rows: 1}\n      else\n        {columns: [], data: [], rows: 0}\n  __schemaSetAdapter adapter\n  __SchemaRegistry.reset()\n  Member = schema :model\n    name! string\n    @tableWas users\n  deployed.tables = [{\n    name: \"users\", sequence: {name: \"users_seq\", start: 1}, primaryKey: \"id\"\n    columns: [\n      {name: \"id\", type: \"INTEGER\", notNull: true, unique: false, primary: true, default: \"nextval('users_seq')\"}\n      {name: \"name\", type: \"VARCHAR\", notNull: true, unique: false, default: null}\n    ]\n    indexes: [], foreignKeys: [], tableWas: null\n  }]\n  steps = schema.plan!\n  [steps.length, steps[0].kind, steps[0].sql[0]]", [1, "rename-table", "ALTER TABLE users RENAME TO members;"]
test "diff: ALTERs on FK-referenced tables classify as blocked (DuckDB wall)", "  deployed = {tables: []}\n  history  = []\n  calls    = []\n  adapter =\n    introspect: -> deployed\n    query: (sql, params) ->\n      calls.push {sql, params}\n      if sql.startsWith(\"SELECT version\")\n        {columns: [{name: \"version\"}, {name: \"name\"}, {name: \"checksum\"}, {name: \"applied_at\"}], data: history.map((h) -> [h.version, h.name, h.checksum, null]), rows: history.length}\n      else if sql.startsWith(\"INSERT INTO _rip_migrations\")\n        history.push {version: params[0], name: params[1], checksum: params[2]}\n        {columns: [], data: [], rows: 1}\n      else\n        {columns: [], data: [], rows: 0}\n  __schemaSetAdapter adapter\n  __SchemaRegistry.reset()\n  User = schema :model\n    fullName! string, {was: \"name\"}\n    phone?    string\n  Order = schema :model\n    total! integer\n    @belongs_to User\n  deployed.tables = [{\n    name: \"users\", sequence: {name: \"users_seq\", start: 1}, primaryKey: \"id\"\n    columns: [\n      {name: \"id\", type: \"INTEGER\", notNull: true, unique: false, primary: true, default: \"nextval('users_seq')\"}\n      {name: \"name\", type: \"VARCHAR\", notNull: true, unique: false, default: null}\n    ]\n    indexes: [], foreignKeys: [], tableWas: null\n  }, {\n    name: \"orders\", sequence: {name: \"orders_seq\", start: 1}, primaryKey: \"id\"\n    columns: [\n      {name: \"id\", type: \"INTEGER\", notNull: true, unique: false, primary: true, default: \"nextval('orders_seq')\"}\n      {name: \"total\", type: \"INTEGER\", notNull: true, unique: false, default: null}\n      {name: \"user_id\", type: \"INTEGER\", notNull: true, unique: false, default: null}\n    ]\n    indexes: [], foreignKeys: [{column: \"user_id\", refTable: \"users\", refColumn: \"id\"}], tableWas: null\n  }]\n  steps = schema.plan!\n  rename = steps.find (s) -> s.kind is \"rename-column\"\n  added  = steps.find (s) -> s.kind is \"add-column\"\n  err = null\n  try\n    schema.make! \"x\", {dir: \"/tmp/__rip_mig_blocked\"}\n  catch e\n    err = e.message\n  out = [rename.class, added.class, rename.notes.some((n) -> n.includes(\"Dependency Error\")), err.includes(\"cannot execute\")]\n  out", ["blocked", "safe", true, true]
test "make: refuses gated steps without allow flags; allows with them", "  deployed = {tables: []}\n  history  = []\n  calls    = []\n  adapter =\n    introspect: -> deployed\n    query: (sql, params) ->\n      calls.push {sql, params}\n      if sql.startsWith(\"SELECT version\")\n        {columns: [{name: \"version\"}, {name: \"name\"}, {name: \"checksum\"}, {name: \"applied_at\"}], data: history.map((h) -> [h.version, h.name, h.checksum, null]), rows: history.length}\n      else if sql.startsWith(\"INSERT INTO _rip_migrations\")\n        history.push {version: params[0], name: params[1], checksum: params[2]}\n        {columns: [], data: [], rows: 1}\n      else\n        {columns: [], data: [], rows: 0}\n  __schemaSetAdapter adapter\n  __SchemaRegistry.reset()\n  User = schema :model\n    name! string\n  deployed.tables = [{\n    name: \"users\", sequence: {name: \"users_seq\", start: 1}, primaryKey: \"id\"\n    columns: [\n      {name: \"id\", type: \"INTEGER\", notNull: true, unique: false, primary: true, default: \"nextval('users_seq')\"}\n      {name: \"name\", type: \"VARCHAR\", notNull: true, unique: false, default: null}\n      {name: \"legacy\", type: \"VARCHAR\", notNull: false, unique: false, default: null}\n    ]\n    indexes: [], foreignKeys: [], tableWas: null\n  }]\n  err = null\n  try\n    schema.make! \"drop_legacy\", {dir: \"/tmp/__rip_mig_test_none\"}\n  catch e\n    err = e.message\n  [err.includes(\"gated steps\"), err.includes(\"destructive\")]", [true, true]
test "make + migrate: write file, apply pending, record history, idempotent", "  deployed = {tables: []}\n  history  = []\n  calls    = []\n  adapter =\n    introspect: -> deployed\n    query: (sql, params) ->\n      calls.push {sql, params}\n      if sql.startsWith(\"SELECT version\")\n        {columns: [{name: \"version\"}, {name: \"name\"}, {name: \"checksum\"}, {name: \"applied_at\"}], data: history.map((h) -> [h.version, h.name, h.checksum, null]), rows: history.length}\n      else if sql.startsWith(\"INSERT INTO _rip_migrations\")\n        history.push {version: params[0], name: params[1], checksum: params[2]}\n        {columns: [], data: [], rows: 1}\n      else\n        {columns: [], data: [], rows: 0}\n  __schemaSetAdapter adapter\n  __SchemaRegistry.reset()\n  fs = await import(\"node:fs\")\n  dir = \"/tmp/__rip_mig_test_\" + Date.now()\n  User = schema :model\n    name! string\n  out = schema.make! \"init\", {dir}\n  applied1 = schema.migrate! {dir}\n  ranSQL = calls.filter((c) -> c.sql.includes(\"CREATE TABLE users\") or c.sql.includes(\"CREATE SEQUENCE users_seq\")).length\n  applied2 = schema.migrate! {dir}\n  content = fs.readFileSync(out.file, \"utf8\")\n  fs.rmSync(dir, {recursive: true, force: true})\n  result = [\n    out.file.endsWith(\"0001_init.sql\")\n    content.includes(\"CREATE TABLE users\")\n    applied1.ran\n    ranSQL >= 2\n    history.length\n    applied2.ran.length\n  ]\n  result", [true, true, ["0001_init"], true, 1, 0]
test "migrate: checksum mismatch on applied file aborts; --repair re-records", "  deployed = {tables: []}\n  history  = []\n  calls    = []\n  adapter =\n    introspect: -> deployed\n    query: (sql, params) ->\n      calls.push {sql, params}\n      if sql.startsWith(\"SELECT version\")\n        {columns: [{name: \"version\"}, {name: \"name\"}, {name: \"checksum\"}, {name: \"applied_at\"}], data: history.map((h) -> [h.version, h.name, h.checksum, null]), rows: history.length}\n      else if sql.startsWith(\"INSERT INTO _rip_migrations\")\n        history.push {version: params[0], name: params[1], checksum: params[2]}\n        {columns: [], data: [], rows: 1}\n      else\n        {columns: [], data: [], rows: 0}\n  __schemaSetAdapter adapter\n  __SchemaRegistry.reset()\n  fs = await import(\"node:fs\")\n  dir = \"/tmp/__rip_mig_chk_\" + Date.now()\n  User = schema :model\n    name! string\n  out = schema.make! \"init\", {dir}\n  schema.migrate! {dir}\n  fs.appendFileSync(out.file, \"\\n-- edited after apply\\n\")\n  err = null\n  try\n    schema.migrate! {dir}\n  catch e\n    err = e.message\n  schema.migrate! {dir, repair: true}\n  fs.rmSync(dir, {recursive: true, force: true})\n  repaired = calls.some (c) -> c.sql.startsWith(\"UPDATE _rip_migrations\")\n  [err.includes(\"checksum mismatch\"), repaired]", [true, true]
test "afterRollback fires on rollback; afterCommit does not", "  events = []\n  txCalls = []\n  mainCalls = []\n  resState = {res: {columns: [{name: \"id\"}, {name: \"name\"}], data: [[1, \"A\"]], rows: 1}}\n  adapter =\n    query: (sql, params) ->\n      mainCalls.push sql\n      events.push \"main\"\n      resState.res\n    begin: (opts) ->\n      events.push \"BEGIN\"\n      handle = {}\n      handle.query = (sql, params) ->\n        txCalls.push sql\n        events.push \"stmt\"\n        resState.res\n      handle.commit = -> events.push \"COMMIT\"\n      handle.rollback = -> events.push \"ROLLBACK\"\n      handle\n    capabilities: {tx: true}\n  __schemaSetAdapter adapter\n  __SchemaRegistry.reset()\n  User = schema :model\n    name! string\n    afterCommit:   -> events.push \"afterCommit\"\n    afterRollback: -> events.push \"afterRollback\"\n  try\n    schema.transaction! ->\n      User.create! {name: \"A\"}\n      throw new Error \"x\"\n  events", ["BEGIN", "stmt", "ROLLBACK", "afterRollback"]
test "two parallel transactions use independent handles (no cross-talk)", "  events = []\n  txCalls = []\n  mainCalls = []\n  resState = {res: {columns: [{name: \"id\"}, {name: \"name\"}], data: [[1, \"A\"]], rows: 1}}\n  adapter =\n    query: (sql, params) ->\n      mainCalls.push sql\n      events.push \"main\"\n      resState.res\n    begin: (opts) ->\n      events.push \"BEGIN\"\n      handle = {}\n      handle.query = (sql, params) ->\n        txCalls.push sql\n        events.push \"stmt\"\n        resState.res\n      handle.commit = -> events.push \"COMMIT\"\n      handle.rollback = -> events.push \"ROLLBACK\"\n      handle\n    capabilities: {tx: true}\n  __schemaSetAdapter adapter\n  __SchemaRegistry.reset()\n  User = schema :model\n    name! string\n  handles = []\n  adapter.begin = ->\n    box = {sqls: []}\n    handles.push box\n    handle = {}\n    handle.query = (sql, params) ->\n      box.sqls.push sql\n      resState.res\n    handle.commit = -> null\n    handle.rollback = -> null\n    handle\n  run = (a, b) ->\n    schema.transaction! ->\n      User.create! {name: a}\n      sleep! 5\n      User.create! {name: b}\n      null\n  p1 = run \"A\", \"B\"\n  p2 = run \"C\", \"D\"\n  Promise.all! [p1, p2]\n  [handles.length, handles[0].sqls.length, handles[1].sqls.length, mainCalls.length]", [2, 2, 2, 0]
