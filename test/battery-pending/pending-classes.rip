# Pending rows for classes — behaviors the battery does not cover yet.
# Every row here FAILS today; when a feature revives one, MOVE the row
# into test/battery/ in the same change (the lane asserts still-failing).

import { test, code, fail, type } from '../support/testing.js'

code 'super call', 'super(arg)', 'super(arg)'

code 'super method', 'super.method()', 'super.method()'

test '@param works with extra statements', '''
  class Animal
    constructor: (@name) ->
    speak: -> @name
    class @Baby
      cry: -> "waa"
  a = new Animal('Dog')
  [a.name, a.speak(), Animal.Baby?]
''', ['Dog', 'Dog', true]

test 'subclass @param works with extra statements', '''
  class Base
    constructor: (@id) ->
  class Sub extends Base
    constructor: (id, @label) ->
      super(id)
    class @Helper
      help: -> true
  s = new Sub(1, 'x')
  [s.id, s.label]
''', [1, 'x']

test 'bound method works with extra statements', '''
  class Handler
    constructor: ->
      @count = 0
    onClick: => @count += 1
    class @Util
      noop: ->
  h = new Handler()
  fn = h.onClick
  fn()
  h.count
''', 1

test 'async method works with extra statements', '''
  class Svc
    fetch: -> await Promise.resolve(42)
    class @Inner
      noop: ->
  do ->
    s = new Svc()
    await s.fetch()
''', 42
