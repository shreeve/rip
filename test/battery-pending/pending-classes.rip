# Pending rows for classes — behaviors the battery does not cover yet.
# Every row here FAILS today; when a feature revives one, MOVE the row
# into test/battery/ in the same change (the lane asserts still-failing).

import { test, code, fail, type } from '../support/testing.js'

test 'basic class', '''
  class Animal
    constructor: (@name) ->
    speak: -> @name
  a = new Animal('Dog'); a.speak()
''', 'Dog'

test 'class inheritance', '''
  class Animal
    constructor: (@name) ->
  class Dog extends Animal
    bark: -> 'woof'
  d = new Dog('Spot'); d.name
''', 'Spot'

code 'simple class', '''
  class Animal
    constructor: (@name) ->
''', 'class Animal { constructor(name) { this.name = name; } }'

test 'super in constructor', '''
  class Animal
    constructor: (@name) ->
  class Dog extends Animal
    constructor: (name, @breed) ->
      super(name)
  d = new Dog('Spot', 'Terrier'); d.name
''', 'Spot'

test 'super with @param', '''
  class Animal
    constructor: (@name) ->
  class Dog extends Animal
    constructor: (@name) -> super @name, "woof"
  d = Dog.new "Rex"
  d.name
''', 'Rex'

test '@param with default', '''
  class Counter
    constructor: (@count = 0) ->
  c = Counter.new 10
  c.count
''', 10

test '@param default no args', '''
  class Counter
    constructor: (@count = 0) ->
  c = Counter.new()
  c.count
''', 0

code 'super call', 'super(arg)', 'super(arg)'
code 'super method', 'super.method()', 'super.method()'

test 'multiple @ parameters', '''
  class Person
    constructor: (@first, @last) ->
  p = new Person('John', 'Doe')
  [p.first, p.last]
''', ['John', 'Doe']

test 'ruby-style new chained', '''
  class Builder
    constructor: (@val) ->
    get: -> @val
  Builder.new(42).get()
''', 42

test '@param works with extra statements', '''
  class Animal
    constructor: (@name) ->
    speak: -> @name
    class @Baby
      cry: -> "waa"
  a = new Animal('Dog')
  [a.name, a.speak(), Animal.Baby?]
''', ['Dog', 'Dog', true]

test 'subclass @param works with extra statements', '''
  class Base
    constructor: (@id) ->
  class Sub extends Base
    constructor: (id, @label) ->
      super(id)
    class @Helper
      help: -> true
  s = new Sub(1, 'x')
  [s.id, s.label]
''', [1, 'x']

test 'bound method works with extra statements', '''
  class Handler
    constructor: ->
      @count = 0
    onClick: => @count += 1
    class @Util
      noop: ->
  h = new Handler()
  fn = h.onClick
  fn()
  h.count
''', 1

test 'async method works with extra statements', '''
  class Svc
    fetch: -> await Promise.resolve(42)
    class @Inner
      noop: ->
  do ->
    s = new Svc()
    await s.fetch()
''', 42
