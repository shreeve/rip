m2 = {n: 5}.n
c1 = first([true, null])
c2 = [first, first][0]([7])
v1 = [x ?? y, 2 ** 3]
v2 = {k: x && y, m: [1..2]}
ix = data[i + 1]
sl = data[1..]

if true
  t = [1..3]

# trivia at a block boundary

while flag && data[0]

  # trivia inside a block
  flag = false

q = span(1, 3)

# statement position: array literals are valid bare; object literals are
