# 21-operations.errors.rip — intentional negatives: the Diagnostics Lane
# (bun run type-audit --errors) asserts each one; @ts-nocheck quiets editors only.
# @ts-nocheck

text = 'abc'
count = 42
point = { x: 1 }
pair = (a: number, b: number) -> a + b

wrongLeft = text * 2
wrongRight = 2 * text
wrongUpdate = text++
wrongCompare = text is count
wrongInstance = text instanceof count
wrongCall = count()
wrongOptionalCall = count?.(1)
wrongArity = pair(1)
wrongArgument = pair(1, text)
wrongExist = missingName?
wrongDelete = delete point.x
