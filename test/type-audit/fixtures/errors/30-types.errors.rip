# 30-types.errors.rip — intentional negatives: the Diagnostics Lane
# (bun run type-audit --errors) asserts each one; @ts-nocheck quiets editors only.
# @ts-nocheck

type Code = number
type Chart = { mode: string }
type Crate<T> = { item: T }
interface Route
  path: string
label = 'five'
enum Tier
  free
  paid

wrongAlias: Code = 'zero'
wrongShape: Chart = { mode: 4 }
wrongCrate: Crate<number> = { item: 'pearl' }
wrongRoute: Route = {}
wrongCast = (label as number)
wrongMember = Tier.pro
