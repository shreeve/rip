# Optimized Jison Parser Generator - CoffeeScript Implementation
# Maintains ES5 compatibility, focused on performance and size

# Utility functions
union = (a, b) ->
  s = Object.create null
  for i in [0...a.length]
    s[a[i]] = 1
  for i in [0...b.length]
    unless s[b[i]]
      a.push b[i]
  a

version = require('../package.json').version
Jison = exports.Jison = exports

Jison.print = console.log

# Core classes
class Nonterminal
  constructor: (@symbol) ->
    @productions = []
    @first = []
    @follows = []
    @nullable = false

class Production
  constructor: (@symbol, @handle, @id) ->
    @nullable = false
    @first = []
    @precedence = 0

class Item
  constructor: (@production, dot, f, @predecessor) ->
    @dotPosition = dot or 0
    @follows = f or []
    @id = parseInt(@production.id + 'a' + @dotPosition, 36)
    @markedSymbol = @production.handle[@dotPosition]

  eq: (e) ->
    e.id is @id

class ItemSet
  constructor: ->
    @_items = []
    @length = 0
    @reductions = []
    @goes = {}
    @edges = {}
    @shifts = false
    @inadequate = false
    @hash_ = {}

    if arguments.length
      @_items = Array.prototype.slice.call arguments
      @length = @_items.length
      for i in [@length-1..0]
        @hash_[@_items[i].id] = true

  concat: (set) ->
    a = set._items or set
    for i in [a.length-1..0]
      @hash_[a[i].id] = true
    @_items.push.apply @_items, a
    @length = @_items.length
    this

  push: (item) ->
    @hash_[item.id] = true
    @_items.push item
    @length = @_items.length
    @length

  contains: (item) ->
    @hash_[item.id]

  forEach: (callback) ->
    @_items.forEach callback

  valueOf: ->
    v = @_items.map((a) -> a.id).sort().join('|')
    @valueOf = -> v
    v

# Main generator class
class LALRGenerator
  constructor: (grammar, options) ->
    options = Object.assign {}, grammar.options, options
    @terms = {}
    @operators = {}
    @productions = []
    @conflicts = 0
    @resolutions = []
    @options = options
    @parseParams = grammar.parseParams
    @yy = {}
    @type = "LALR(1)"

    if grammar.actionInclude
      if typeof grammar.actionInclude is 'function'
        grammar.actionInclude = String(grammar.actionInclude)
          .replace(/^\s*function \(\) \{/, '')
          .replace(/\}\s*$/, '')
      @actionInclude = grammar.actionInclude
    @moduleInclude = grammar.moduleInclude or ''

    @processGrammar grammar
    @states = @canonicalCollection()
    @terms_ = {}

    newg = @newg = Object.create LALRGenerator.prototype
    Object.assign newg,
      oldg: this
      trace: @trace
      nterms_: {}
      go_: (r, B) ->
        r = r.split(":")[0]
        B = B.map (b) -> b.slice(b.indexOf(":") + 1)
        @oldg.go r, B
    newg.nonterminals = {}
    newg.productions = []

    @inadequateStates = []
    @onDemandLookahead = options.onDemandLookahead or false

    @buildNewGrammar()
    newg.computeLookaheads()
    @unionLookaheads()
    @table = @parseTable @states
    @defaultActions = @findDefaults @table

  processGrammar: (grammar) ->
    bnf = grammar.bnf
    tokens = grammar.tokens
    nonterminals = @nonterminals = {}
    productions = @productions
    symbols = @symbols = []
    operators = @operators = @processOperators grammar.operators

    if tokens
      tokens = if typeof tokens is 'string' then tokens.trim().split(' ') else tokens.slice(0)

    @buildProductions bnf, productions, nonterminals, symbols, operators

    if tokens and @terminals.length isnt tokens.length
      @trace "Warning: declared tokens differ from tokens found in rules."

    @augmentGrammar grammar

  processOperators: (ops) ->
    return {} unless ops
    operators = {}
    for prec, i in ops
      for k in [1...prec.length]
        operators[prec[k]] =
          precedence: i + 1
          assoc: prec[0]
    operators

  augmentGrammar: (grammar) ->
    if @productions.length is 0
      throw new Error "Grammar error: must have at least one rule."

    @startSymbol = grammar.start or grammar.startSymbol or @productions[0].symbol
    unless @nonterminals[@startSymbol]
      throw new Error "Grammar error: startSymbol must be a non-terminal found in your grammar."

    @EOF = '$end'
    @ERROR = '$error'

    @terminals = []
    @nonterminals[@startSymbol].start = true
    @startProduction = new Production @startSymbol, [@startSymbol], 0

    @productions.unshift @startProduction
    @nonterminals[@startSymbol].productions.unshift @startProduction

    @buildFirst()
    @buildFollow()
    @buildNullable()

  buildProductions: (bnf, productions, nonterminals, symbols, operators) ->
    actions = []
    actionGroups = {}
    prods = []
    symbolId = 1

    for symbol of bnf
      continue unless bnf.hasOwnProperty symbol

      nonterminals[symbol] = new Nonterminal symbol
      symbols.push symbol unless symbol in symbols

      if typeof bnf[symbol] is 'string'
        rules = bnf[symbol].split /\s*\|\s*/g
      else
        rules = bnf[symbol].slice()

      for rule, i in rules
        if typeof rule is 'string'
          rule = rule.trim().split /\s+/
          if rule.length is 1 and rule[0] is ''
            rule = []
        else
          rule = rule.slice()

        production = new Production symbol, rule, productions.length
        productions.push production
        nonterminals[symbol].productions.push production

        for sym in rule
          unless nonterminals[sym]
            @terminals.push sym unless sym in @terminals
            symbols.push sym unless sym in symbols

  buildFirst: ->
    @firstSets()

  buildFollow: ->
    @followSets()

  buildNullable: ->
    @nullableSets()

  computeLookaheads: ->
    @computeLookaheads = ->
    @nullableSets()
    @firstSets()
    @followSets()

  nullableSets: ->
    nonterminals = @nonterminals
    cont = true

    while cont
      cont = false
      @productions.forEach (production) =>
        unless production.nullable
          n = 0
          for t in production.handle
            n++ if @nullable t
          if n is production.handle.length
            production.nullable = cont = true

    for symbol of nonterminals
      unless @nullable symbol
        for production in nonterminals[symbol].productions
          if production.nullable
            nonterminals[symbol].nullable = cont = true
            break

  nullable: (symbol) ->
    return true if symbol is ''
    if symbol instanceof Array
      for t in symbol
        return false unless @nullable t
      return true
    return unless @nonterminals[symbol] then false else @nonterminals[symbol].nullable

  firstSets: ->
    productions = @productions
    nonterminals = @nonterminals
    cont = true

    while cont
      cont = false
      productions.forEach (production) =>
        firsts = @first production.handle
        if firsts.length isnt production.first.length
          production.first = firsts
          cont = true

    for symbol of nonterminals
      firsts = @first symbol
      if firsts.length isnt nonterminals[symbol].first.length
        nonterminals[symbol].first = firsts
        cont = true

  first: (symbol) ->
    return [] if symbol is ''
    if symbol instanceof Array
      firsts = []
      for t in symbol
        if not @nonterminals[t]
          firsts.push t unless t in firsts
        else
          union firsts, @nonterminals[t].first
        break unless @nullable t
      return firsts
    return unless @nonterminals[symbol] then [symbol] else @nonterminals[symbol].first

  followSets: ->
    productions = @productions
    nonterminals = @nonterminals
    cont = true

    while cont
      cont = false
      productions.forEach (production) =>
        for symbol, i in production.handle
          if nonterminals[symbol]
            beta = production.handle.slice(i + 1)
            firsts = @first beta
            if firsts.length isnt nonterminals[symbol].follows.length
              union nonterminals[symbol].follows, firsts
              cont = true
            if @nullable beta
              if production.follows.length isnt nonterminals[symbol].follows.length
                union nonterminals[symbol].follows, production.follows
                cont = true

  closureOperation: (itemSet) ->
    closureSet = new ItemSet()
    set = itemSet
    syms = {}

    loop
      itemQueue = []
      closureSet.concat set

      set.forEach (item) =>
        symbol = item.markedSymbol

        if symbol and @nonterminals[symbol]
          unless syms[symbol]
            @nonterminals[symbol].productions.forEach (production) ->
              newItem = new Item production, 0
              unless closureSet.contains newItem
                itemQueue.push newItem
            syms[symbol] = true
        else if not symbol
          closureSet.reductions.push item
          closureSet.inadequate = closureSet.reductions.length > 1 or closureSet.shifts
        else
          closureSet.shifts = true
          closureSet.inadequate = closureSet.reductions.length > 0

      set = itemQueue
      break if itemQueue.length is 0

    closureSet

  gotoOperation: (itemSet, symbol) ->
    gotoSet = new ItemSet()

    itemSet.forEach (item, n) ->
      if item.markedSymbol is symbol
        gotoSet.push new Item item.production, item.dotPosition + 1, item.follows, n

    if gotoSet.length is 0 then gotoSet else @closureOperation gotoSet

  canonicalCollection: ->
    item1 = new Item @productions[0], 0, [@EOF]
    firstState = @closureOperation new ItemSet item1
    states = [firstState]
    stateMap = {}
    stateMap[firstState.valueOf()] = 0

    for state, i in states
      for symbol in @symbols
        g = @gotoOperation state, symbol
        if g.length
          gv = g.valueOf()
          if stateMap[gv] is undefined
            stateMap[gv] = states.length
            states.push g
          state.goes[symbol] = stateMap[gv]

    states

  canonicalCollectionInsert: (symbol, itemSet, states, stateNum) ->
    g = @gotoOperation itemSet, symbol
    unless g.predecessors
      g.predecessors = {}
    g.predecessors[symbol] = [stateNum]

    i = states.length
    for state, j in states
      if state.valueOf() is g.valueOf()
        i = j
        break

    if i is states.length
      states.push g
      g.inadequate = false
      for item in g._items
        if item.dotPosition is 0 and item.production.symbol isnt @startSymbol
          g.inadequate = true
          break
    else
      g.predecessors[symbol] = g.predecessors[symbol].concat states[i].predecessors[symbol]

    states[i]

  parseTable: (itemSets) ->
    states = []
    nonterminals = @nonterminals
    operators = @operators
    conflictedStates = {}
    NONASSOC = 0

    for itemSet, i in itemSets
      state = states[i] = {}
      resolutions = []

      itemSet.forEach (item) =>
        symbol = item.markedSymbol
        if symbol
          if @nonterminals[symbol]
            # non-terminal
            state[symbol] = ['go', itemSet.goes[symbol]]
          else
            # terminal
            state[symbol] = ['shift', itemSet.goes[symbol]]
        else
          # reduction
          lookaheads = @lookAheads itemSet, item
          for j in lookaheads
            if state[j]
              action = @resolveConflict item.production, operators[j], state[j], ['reduce', item.production.id]
              resolutions.push [j, action]
              if action[0] is 'reduce'
                state[j] = action
            else
              state[j] = ['reduce', item.production.id]

      for resolution in resolutions
        @resolutions.push [@conflicts, resolution[0], resolution[1]]
        @conflicts++

    states

  resolveConflict: (production, op, reduce, shift) ->
    if shift[0] is 'reduce'
      if production.precedence < shift[1]
        return shift
      else if production.precedence > shift[1]
        return reduce
      else if production.precedence is shift[1]
        if op and op.assoc is 'right'
          return reduce
        else if op and op.assoc is 'left'
          return shift
        else if op and op.assoc is 'nonassoc'
          return reduce
    return reduce

  findDefaults: (states) ->
    defaults = {}
    for state, i in states
      reductions = []
      for symbol, action of state
        if action[0] is 'reduce'
          reductions.push action
      if reductions.length
        defaults[i] = reductions[0]
    defaults

  lookAheads: (state, item) ->
    if @onDemandLookahead and not state.inadequate
      @terminals
    else
      item.follows

  go: (p, w) ->
    p = parseInt p
    for symbol in w
      p = @states[p].goes[symbol] or ''
    p

  goPath: (p, w) ->
    path = []
    for symbol in w
      t = @states[p].goes[symbol]
      if not t
        path.push symbol
        break
      path.push [symbol, t]
      p = t
    path

  buildNewGrammar: ->
    newg = @newg

    for state, i in @states
      for item in state._items
        if item.dotPosition is 0 and item.production.symbol isnt @startSymbol
          newg.nonterminals[i + ':' + item.production.symbol] = true
          newg.productions.push [i + ':' + item.production.symbol, item.production.handle.slice()]

  unionLookaheads: ->
    newg = @newg

    for production in newg.productions
      lookaheads = []
      for state, i in @states
        for item in state._items
          if item.production.symbol is production[0].split(':')[1] and item.dotPosition is 0
            union lookaheads, @lookAheads state, item
      production.push lookaheads

  generate: (opt) ->
    opt = Object.assign {}, @options, opt
    code = ""

    if opt.moduleType is 'commonjs'
      code = @generateCommonJSModule opt
    else if opt.moduleType is 'amd'
      code = @generateAMDModule opt
    else
      code = @generateModule opt

    code

  generateCommonJSModule: (opt) ->
    opt = Object.assign {}, @options, opt
    moduleName = opt.moduleName or "parser"
    out = @generateModule opt
    out += "\nif (typeof require !== 'undefined' && typeof exports !== 'undefined') {\n"
    out += "exports.parser = #{moduleName};\n"
    out += "exports.Parser = #{moduleName}.Parser;\n"
    out += "exports.parse = function () { return #{moduleName}.parse.apply(#{moduleName}, arguments); };\n"
    out += "exports.main = #{@generateMain()};\n"
    out += "if (typeof module !== 'undefined' && require.main === module) {\n"
    out += "  exports.main(process.argv.slice(1));\n"
    out += "}\n"
    out += "}\n"
    out

  generateModule: (opt) ->
    opt = Object.assign {}, @options, opt
    moduleName = opt.moduleName or "parser"
    now = new Date().toISOString()
    out = "/* parser generated by jison #{version} on #{now} */\n"
    out += @generateModuleExpr()
    out

  generateModuleExpr: ->
    out = ''
    module = @generateModule_()

    out += "var #{module.moduleName} = "
    out += "(function(){\n"
    out += module.commonCode
    out += "\nreturn #{module.moduleCode};\n"
    out += "})();\n"

    if @options.moduleMain
      out += @generateMain()

    out

  generateModule_: ->
    parseFn = String @parse

    # Token stack support removed
    parseFn = parseFn.replace /\\\\n/g, '\\n'
    parseFn = parseFn.replace /\\\\r/g, '\\r'
    parseFn = parseFn.replace /\\\\t/g, '\\t'

    out = """
      var parser = {trace: function trace() { },
      yy: {},
      symbols_: #{JSON.stringify @symbols},
      terminals_: #{JSON.stringify @terminals},
      productions_: #{JSON.stringify @productions},
      performAction: #{@performAction or 'function anonymous(yytext, yyleng, yylineno, yy, yystate, $$, _$) { }'},
      table: #{@generateTableCode @table},
      defaultActions: #{JSON.stringify @defaultActions},
      parseError: #{@parseError or @parseError},
      parse: #{parseFn}};
      """

    if @lexer
      out += "if (typeof require !== 'undefined' && typeof exports !== 'undefined') {\n"
      out += "exports.lexer = #{JSON.stringify @lexer};\n"
      out += "}\n"
      out += "parser.lexer = #{JSON.stringify @lexer};\n"

    out += "function Parser () {\n  this.yy = {};\n}\n"
    out += "Parser.prototype = parser;\n"
    out += "parser.Parser = Parser;\n"
    out += "return new Parser;\n"

    moduleName: "parser"
    commonCode: out
    moduleCode: "parser"

  generateTableCode: (table) ->
    moduleCode = JSON.stringify table
    variables = [@createObjectCode]
    moduleCode = moduleCode.replace /"([0-9]+)"(?=:)/g, "$1"
    moduleCode = moduleCode.replace /\{"([0-9]+)":/g, "{$1:"

    moduleCode

  createObjectCode: 'o=function(k,v,o,l){for(o=o||{},l=k.length;l--;o[k[l]]=v);return o},'

  createVariable: ->
    "@V#{@nextVariableId++}"

  nextVariableId: 0

  parseError: (str, hash) ->
    if hash.recoverable
      @trace str
    else
      throw new Error str

  parse: (input) ->
    self = this
    stack = [0]
    tstack = []
    vstack = [null]
    lstack = []
    table = @table
    yytext = ''
    yylineno = 0
    yyleng = 0
    recovering = 0
    TERROR = 2
    EOF = 1

    lexer = Object.create @lexer
    sharedState = yy: @yy
    lexer.setInput input, sharedState.yy
    sharedState.yy.lexer = lexer
    sharedState.yy.parser = this

    if typeof sharedState.yy.parseError is 'function'
      @parseError = sharedState.yy.parseError
    else
      @parseError = Object.getPrototypeOf(this).parseError

    lex = ->
      token = lexer.next()
      token = if typeof token isnt 'undefined' then token else EOF
      if typeof token isnt 'number' and typeof token isnt 'string'
        token = self.symbols_[token] or token
      token

    symbol = null
    preErrorSymbol = null
    state = null
    action = null
    a = null
    r = null
    yyval = {}
    p = null
    len = null
    newState = null
    expected = null
    token = null
    ranges = lexer.options and lexer.options.ranges

    if typeof sharedState.yy.yylloc is 'undefined'
      sharedState.yy.yylloc = {}
    yyloc = sharedState.yy.yylloc

    lstack.push yyloc

    if lexer.options and lexer.options.ranges
      yyloc.range = [lexer.offset, lexer.offset]

    _token_stack = []

    hash = recoverable: (msg) ->
      return @parseError(msg, {
        text: lexer.match,
        token: self.terminals_[symbol] or symbol,
        line: lexer.yylineno,
        loc: yyloc,
        expected: expected
      })

    loop
      state = stack[stack.length - 1]

      if @defaultActions[state]
        action = @defaultActions[state]
      else
        if symbol is null or typeof symbol is 'undefined'
          symbol = lex()

        action = table[state] and table[state][symbol]

      unless action or action is 0
        expected = []
        for p of table[state]
          if @terminals_[p] and p > TERROR
            expected.push "'#{@terminals_[p]}'"

        if lexer.showPosition
          errStr = "Parse error on line #{yylineno + 1}:\n#{lexer.showPosition()}\nExpecting #{expected.join(', ')}, got '#{@terminals_[symbol] or symbol}'"
        else
          errStr = "Parse error on line #{yylineno + 1}: Unexpected #{if symbol is EOF then 'end of input' else "'" + (@terminals_[symbol] or symbol) + "'"}"

        @parseError errStr, {
          text: lexer.match,
          token: @terminals_[symbol] or symbol,
          line: lexer.yylineno,
          loc: yyloc,
          expected: expected
        }

      if action[0] instanceof Array and action.length > 1
        throw new Error "Parse Error: multiple actions possible at state: #{state}, token: #{symbol}"

      switch action[0]
        when 1 # shift
          stack.push symbol
          vstack.push lexer.yytext
          lstack.push lexer.yylloc
          stack.push action[1]
          symbol = null
          if not preErrorSymbol
            yyleng = lexer.yyleng
            yytext = lexer.yytext
            yylineno = lexer.yylineno
            yyloc = lexer.yylloc
            recovering-- if recovering > 0
          else
            symbol = preErrorSymbol
            preErrorSymbol = null

        when 2 # reduce
          len = @productions_[action[1]][1]
          yyval.$ = vstack[vstack.length - len]
          yyval._$ = {
            first_line: lstack[lstack.length - (len or 1)].first_line,
            last_line: lstack[lstack.length - 1].last_line,
            first_column: lstack[lstack.length - (len or 1)].first_column,
            last_column: lstack[lstack.length - 1].last_column
          }
          if ranges
            yyval._$.range = [lstack[lstack.length - (len or 1)].range[0],
                              lstack[lstack.length - 1].range[1]]
          r = @performAction.apply yyval, [yytext, yyleng, yylineno, sharedState.yy,
                                           action[1], vstack, lstack]

          return r if typeof r isnt 'undefined'

          if len
            stack = stack.slice(0, -1 * len * 2)
            vstack = vstack.slice(0, -1 * len)
            lstack = lstack.slice(0, -1 * len)

          stack.push @productions_[action[1]][0]
          vstack.push yyval.$
          lstack.push yyval._$
          newState = table[stack[stack.length - 2]][stack[stack.length - 1]]
          stack.push newState

        when 3 # accept
          return true

  trace: ->

  createParser: ->
    p = eval @generateModuleExpr()
    p.productions = @productions

    bind = (method) =>
      =>
        @lexer = p.lexer
        @[method].apply this, arguments

    p.lexer = @lexer
    p.generate = bind 'generate'
    p.generateModule = bind 'generateModule'
    p.generateCommonJSModule = bind 'generateCommonJSModule'

    p

# Exports
Jison.Parser = (grammar, options) ->
  gen = new LALRGenerator grammar, options
  gen.createParser()

exports.LALRGenerator = LALRGenerator

Jison.Generator = (g, options) ->
  opt = Object.assign {}, g.options, options
  new LALRGenerator g, opt

return (g, options) ->
  gen = Jison.Generator g, options
  gen.createParser()