# LALR(1) Parser Generator - DeRemer-Pennello Algorithm Implementation
#
# This implementation uses canonical naming conventions from established literature to
# serve as a reference implementation for computer science education and research.
# Canonical naming conventions based on established literature:
#
# - "Compilers: Principles, Techniques, and Tools" (Dragon Book)
# - "Efficient Computation of LALR(1) Look-Ahead Sets" (DeRemer & Pennello, 1982)
# - "LR Parsing: Theory and Practice" (Knuth, 1965)
#
# Function Reference:
#
# Utility Functions:
# - union(a, b) - Merge array b into array a, avoiding duplicates
#
# Constructor Functions:
# - Nonterminal(symbol) - Represents a nonterminal symbol in the grammar
# - Production(symbol, handle, id) - Represents a production rule in the grammar
# - Item(production, dot, lookaheadSet, predecessor) - Represents an LR(0) item [A → α•β] with lookahead
# - LRState() - Represents a set of LR items (parser state)
# - LALRGenerator(grammar, options) - Unified LALR(1) parser generator class
#
# LRState Methods:
# - concat(set) - Merge another LRState or array into this LRState
# - push(item) - Add an item to this LRState
# - contains(item) - Check if this LRState contains a specific item
# - valueOf() - Generate unique string representation for ItemSet comparison
#
# LALRGenerator Core Methods:
# - gotoEncoded(stateId, symbolSequence) - Specialized GOTO method for lookahead computation
# - processGrammar(grammar) - Process and validate the input grammar specification
# - processOperators(ops) - Process operator precedence and associativity declarations
# - augmentGrammar(grammar) - Add augmented start production for parser generation
# - buildProductions(bnf, productions, nonterminals, symbols, operators) - Build production rules from BNF grammar
#
# Lookahead Computation:
# - computeLookaheads() - Compute LALR(1) lookaheads using DeRemer-Pennello algorithm
# - computeNullableSets() - Compute NULLABLE sets for all nonterminals
# - isNullable(symbol) - Check if a symbol or symbol sequence is nullable
# - computeFirstSets() - Compute FIRST sets for all nonterminals
# - first(symbol) - Get FIRST set for a symbol or symbol sequence
# - computeFollowSets() - Compute FOLLOW sets for all nonterminals
#
# LR Automaton Construction:
# - closure(itemSet) - Compute closure of an item set (add all implied items)
# - goto(itemSet, symbol) - Compute goto operation (items after shifting a symbol)
# - buildLRAutomaton() - Generate canonical collection of LR(0) item sets
# - insertLRState(symbol, itemSet, states, stateNum) - Insert or merge item set into canonical collection
#
# Parse Table Generation:
# - buildParseTable(itemSets) - Generate LALR(1) parsing table from item sets
# - resolveConflict(production, op, reduce, shift) - Resolve shift/reduce conflicts using operator precedence
# - computeDefaultActions(states) - Find default actions for parser states to reduce table size
# - getLookaheadSet(state, item) - Get lookahead symbols for an item in a state
#
# Navigation and State Management:
# - gotoState(startState, symbolSequence) - Navigate through parser states following a symbol sequence
# - gotoStateWithPath(startState, symbolSequence) - Navigate through parser states and record the path taken
# - buildAugmentedGrammar() - Build augmented grammar for lookahead computation
# - unionLookaheads() - Propagate lookaheads from augmented grammar back to original states
#
# Code Generation:
# - generate(opt) - Generate parser code with specified options
# - generateCommonJSModule(opt) - Generate CommonJS module wrapper for parser
# - generateModule(opt) - Generate module wrapper for parser
# - generateModuleExpr() - Generate self-executing module expression
# - generateModule_() - Generate core parser module code
# - generateTableCode(table) - Generate optimized parsing table code
#
# Parser Runtime:
# - parseError(str, hash) - Handle parsing errors with context information
# - parse(input) - Parse input string using generated LALR(1) parser
# - trace() - Debug tracing function (no-op by default)
# - createParser() - Create executable parser instance from generated code
#
# Export Functions:
# - Jison.Parser(grammar, options) - Create parser from grammar
# - Jison.Generator(g, options) - Create generator instance
# - Parser(g, options) - Main parser factory function
#
# Original implementation by Jison team
# https://github.com/zaach/jison/blob/master/lib/jison.js
Jison = exports.Jison = exports
version = require('../package.json').version
# Merge another LRState or array into this LRState
# Merge array b into array a, avoiding duplicates

union = (a, b) ->
  s = Object.create(null)
  i = undefined
  len = undefined
  i = 0
  len = a.length
  while i < len
    s[a[i]] = 1
    i++
  i = 0
  len = b.length
  while i < len
    if !s[b[i]]
      a.push b[i]
    i++
  a

# Represents a nonterminal symbol in the grammar

Nonterminal = (symbol) ->
  @symbol = symbol
  @productions = []
  @first = []
  @follows = []
  @nullable = false
  return

# Represents a production rule in the grammar

Production = (symbol, handle, id) ->
  @symbol = symbol
  @handle = handle
  @id = id
  @nullable = false
  @first = []
  @precedence = 0
  return

# Represents an LR(0) item [A → α•β] with lookahead (canonical: LR item)

Item = (production, dot, lookaheadSet, predecessor) ->
  @production = production
  @dot = dot or 0
  # Position of • in production
  @follows = lookaheadSet or []
  # LALR(1) lookahead symbols
  @predecessor = predecessor
  @nextSymbol = @production.handle[@dot]
  # Symbol after •
  @id = parseInt(production.id + 'a' + @dot, 36)
  return

# Represents a set of LR items (parser state) - canonical: LR state

LRState = ->
  @list = []
  @length = 0
  @reductions = []
  # Reductions in this state
  @handleToSymbols = {}
  # Maps production handles to generating symbols
  @transitions = {}
  # State transitions
  @hasShifts = false
  # Has shift actions
  @hasConflicts = false
  # Has SR/RR conflicts
  @keys = {}
  if arguments.length
    @list = Array::slice.call(arguments)
    @length = @list.length
    i = @length - 1
    while i >= 0
      @keys[@list[i].id] = true
      i--
  return

# Unified LALR(1) parser generator class (canonical: LALRGenerator)

LALRGenerator = (grammar, options) ->
  options = Object.assign({}, grammar.options, options)
  @terminals = {}
  # Terminal symbols
  @operators = {}
  @productions = []
  @conflicts = 0
  @resolutions = []
  @options = options
  @parseParams = grammar.parseParams
  @yy = {}
  if grammar.actionInclude
    if typeof grammar.actionInclude == 'function'
      grammar.actionInclude = String(grammar.actionInclude).replace(/^\s*function \(\) \{/, '').replace(/\}\s*$/, '')
    @actionInclude = grammar.actionInclude
  @moduleInclude = grammar.moduleInclude or ''
  console.time 'processGrammar'
  @processGrammar grammar
  console.timeEnd 'processGrammar'
  console.time 'buildLRAutomaton'
  @states = @buildLRAutomaton()
  console.timeEnd 'buildLRAutomaton'
  @terminalMap = {}
  # Maps symbols to terminal representations
  # Initialize lookahead state (replaces newg creation)
  @lookahead =
    nonterminalMap: {}
    nonterminals: {}
    productions: []
  @conflictStates = []
  # States with conflicts
  @onDemandLookahead = options.onDemandLookahead or false
  console.time 'buildAugmentedGrammar'
  @buildAugmentedGrammar()
  console.timeEnd 'buildAugmentedGrammar'
  # Compute lookaheads in lookahead context (replaces newg.computeLookaheads())
  savedNonterminals = @nonterminals
  savedProductions = @productions
  @nonterminals = @lookahead.nonterminals
  @productions = @lookahead.productions
  console.time 'computeLookaheads'
  @computeLookaheads()
  console.timeEnd 'computeLookaheads'
  @nonterminals = savedNonterminals
  @productions = savedProductions
  console.time 'unionLookaheads'
  @unionLookaheads()
  console.timeEnd 'unionLookaheads'
  console.time 'buildParseTable'
  @stateTable = @buildParseTable(@states)
  console.timeEnd 'buildParseTable'
  console.time 'computeDefaultActions'
  @defaultActions = @computeDefaultActions(@stateTable)
  console.timeEnd 'computeDefaultActions'
  return

LRState::concat = (set) ->
  a = set.list or set
  i = a.length - 1
  while i >= 0
    @keys[a[i].id] = true
    i--
  @list.push.apply @list, a
  @length = @list.length
  this

# Add an item to this LRState

LRState::push = (item) ->
  @keys[item.id] = true
  @list.push item
  @length = @list.length
  @length

# Check if this LRState contains a specific item

LRState::contains = (item) ->
  @keys[item.id]

# Generate unique string representation for ItemSet comparison

LRState::valueOf = ->
  v = @list.map((a) ->
    a.id
  ).sort().join('|')

  @valueOf = ->
    v

  v

# Specialized GOTO method for lookahead computation (DeRemer-Pennello algorithm)

LALRGenerator::gotoEncoded = (stateId, symbolSequence) ->
  stateId = stateId.split(':')[0]
  symbolSequence = symbolSequence.map((s) ->
    s.slice s.indexOf(':') + 1
  )
  @gotoState stateId, symbolSequence

# Process and validate the input grammar specification

LALRGenerator::processGrammar = (grammar) ->
  bnf = grammar.bnf
  tokens = grammar.tokens
  nonterminals = @nonterminals = {}
  productions = @productions
  symbols = @symbols = []
  operators = @operators = @processOperators(grammar.operators)
  if tokens
    tokens = if typeof tokens == 'string' then tokens.trim().split(' ') else tokens.slice(0)
  @buildProductions bnf, productions, nonterminals, symbols, operators
  if tokens and @terminals.length != tokens.length
    @trace 'Warning: declared tokens differ from tokens found in rules.'
  @augmentGrammar grammar
  return

# Process operator precedence and associativity declarations

LALRGenerator::processOperators = (ops) ->
  if !ops
    return {}
  operators = {}
  i = 0
  prec = undefined
  while prec = ops[i]
    k = 1
    while k < prec.length
      operators[prec[k]] =
        precedence: i + 1
        assoc: prec[0]
      k++
    i++
  operators

# Add augmented start production for parser generation

LALRGenerator::augmentGrammar = (grammar) ->
  if @productions.length == 0
    throw new Error('Grammar error: must have at least one rule.')
  @startSymbol = grammar.start or grammar.startSymbol or @productions[0].symbol
  if !@nonterminals[@startSymbol]
    throw new Error('Grammar error: startSymbol must be a non-terminal found in your grammar.')
  @EOF = '$end'
  acceptProduction = new Production('$accept', [
    @startSymbol
    '$end'
  ], 0)
  @productions.unshift acceptProduction
  @symbols.unshift '$accept', @EOF
  @symbolMap.$accept = 0
  @symbolMap[@EOF] = 1
  @terminals.unshift @EOF
  @nonterminals.$accept = new Nonterminal('$accept')
  @nonterminals.$accept.productions.push acceptProduction
  @nonterminals[@startSymbol].follows.push @EOF
  return

# Build production rules from BNF grammar specification

LALRGenerator::buildProductions = (bnf, productions, nonterminals, symbols, operators) ->
  actions = [
    '/* this == yyval */'
    @actionInclude or ''
    'var $0 = $$.length - 1;'
    'switch (yystate) {'
  ]
  actionGroups = {}
  productionTable = [ 0 ]
  symbolId = 1
  symbolMap = {}

  addSymbol = (s) ->
    if s and !symbolMap[s]
      symbolMap[s] = ++symbolId
      symbols.push s
    return

  addSymbol 'error'
  for symbol of bnf
    if !bnf.hasOwnProperty(symbol)
      k++
      continue
    addSymbol symbol
    nonterminals[symbol] = new Nonterminal(symbol)
    prods = if typeof bnf[symbol] == 'string' then bnf[symbol].split(/\s*\|\s*/g) else bnf[symbol].slice(0)
    prods.forEach (handle) ->
      r = undefined
      rhs = undefined
      i = undefined
      if handle.constructor == Array
        rhs = if typeof handle[0] == 'string' then handle[0].trim().split(' ') else handle[0].slice(0)
        i = 0
        while i < rhs.length
          addSymbol rhs[i]
          i++
        if typeof handle[1] == 'string' or handle.length == 3
          label = 'case ' + productions.length + 1 + ':'
          action = handle[1]
          # Process named semantic values
          if action.match(/[$@][a-zA-Z][a-zA-Z0-9_]*/)
            count = {}
            names = {}
            i = 0
            while i < rhs.length
              rhs_i = rhs[i].match(/\[[a-zA-Z][a-zA-Z0-9_-]*\]/)
              if rhs_i
                rhs_i = rhs_i[0].substr(1, rhs_i[0].length - 2)
                rhs[i] = rhs[i].substr(0, rhs[i].indexOf('['))
              else
                rhs_i = rhs[i]
              if names[rhs_i]
                names[rhs_i + ++count[rhs_i]] = i + 1
              else
                names[rhs_i] = i + 1
                names[rhs_i + '1'] = i + 1
                count[rhs_i] = 1
              i++
            action = action.replace(/\$([a-zA-Z][a-zA-Z0-9_]*)/g, (str, pl) ->
              if names[pl] then '$' + names[pl] else str
            ).replace(/@([a-zA-Z][a-zA-Z0-9_]*)/g, (str, pl) ->
              if names[pl] then '@' + names[pl] else str
            )
          action = action.replace(/([^'"])\$\$|^\$\$/g, '$1this.$').replace(/@[0$]/g, 'this._$').replace(/\$(-?\d+)/g, (_, n) ->
            '$$[$0' + (parseInt(n, 10) - (rhs.length) or '') + ']'
          ).replace(/@(-?\d+)/g, (_, n) ->
            '_$[$0' + (n - (rhs.length) or '') + ']'
          )
          if actionGroups[action]
            actionGroups[action].push label
          else
            actionGroups[action] = [ label ]
          rhs = rhs.map((e) ->
            e.replace /\[[a-zA-Z_][a-zA-Z0-9_-]*\]/g, ''
          )
          r = new Production(symbol, rhs, productions.length + 1)
          if handle[2] and operators[handle[2].prec]
            r.precedence = operators[handle[2].prec].precedence
        else
          rhs = rhs.map((e) ->
            e.replace /\[[a-zA-Z_][a-zA-Z0-9_-]*\]/g, ''
          )
          r = new Production(symbol, rhs, productions.length + 1)
          if operators[handle[1].prec]
            r.precedence = operators[handle[1].prec].precedence
      else
        handle = handle.replace(/\[[a-zA-Z_][a-zA-Z0-9_-]*\]/g, '')
        rhs = handle.trim().split(' ')
        i = 0
        while i < rhs.length
          addSymbol rhs[i]
          i++
        r = new Production(symbol, rhs, productions.length + 1)
      if r.precedence == 0
        i = r.handle.length - 1
        while i >= 0
          if !(r.handle[i] of nonterminals) and r.handle[i] of operators
            r.precedence = operators[r.handle[i]].precedence
            break
          i--
      productions.push r
      productionTable.push [
        symbolMap[r.symbol]
        if r.handle[0] == '' then 0 else r.handle.length
      ]
      nonterminals[symbol].productions.push r
      return
  for action of actionGroups
    actions.push actionGroups[action].join(' '), action, 'break;'
  terms = []
  terms_ = {}
  for sym of symbolMap
    id = symbolMap[sym]
    if !nonterminals[sym]
      terms.push sym
      terms_[id] = sym
  @terminals = terms
  @terminals_ = terms_
  @symbolMap = symbolMap
  @productionTable = productionTable
  actions.push '}'
  actionsCode = actions.join('\n').replace(/YYABORT/g, 'return false').replace(/YYACCEPT/g, 'return true')
  parameters = 'yytext, yyleng, yylineno, yy, yystate, $$, _$'
  if @parseParams
    parameters += ', ' + @parseParams.join(', ')
  @performAction = 'function anonymous(' + parameters + ') {\n' + actionsCode + '\n}'
  return

# Lookahead computation
# Compute LALR(1) lookaheads using DeRemer-Pennello algorithm

LALRGenerator::computeLookaheads = ->

  @computeLookaheads = ->

  @computeNullableSets()
  @computeFirstSets()
  @computeFollowSets()
  return

# Compute NULLABLE sets for all nonterminals (canonical: NULLABLE computation)

LALRGenerator::computeNullableSets = ->
  nonterminals = @nonterminals
  self = this
  cont = true
  while cont
    cont = false
    @productions.forEach (production) ->
      if !production.nullable
        n = 0
        i = 0
        t = undefined
        while t = production.handle[i]
          if self.isNullable(t)
            n++
          ++i
        if n == i
          production.nullable = cont = true
      return
    for symbol of nonterminals
      if !@isNullable(symbol)
        i = 0
        production = undefined
        while production = nonterminals[symbol].productions[i]
          if production.nullable
            nonterminals[symbol].nullable = cont = true
            break
          i++
  return

# Check if a symbol or symbol sequence is nullable (canonical: NULLABLE predicate)

LALRGenerator::isNullable = (symbol) ->
  if symbol == ''
    return true
  if symbol instanceof Array
    i = 0
    t = undefined
    while t = symbol[i]
      if !@isNullable(t)
        return false
      ++i
    return true
  if !@nonterminals[symbol] then false else @nonterminals[symbol].nullable

# Compute FIRST sets for all nonterminals (canonical: FIRST computation)

LALRGenerator::computeFirstSets = ->
  productions = @productions
  nonterminals = @nonterminals
  self = this
  cont = true
  while cont
    cont = false
    productions.forEach (production) ->
      firsts = self.first(production.handle)
      if firsts.length != production.first.length
        production.first = firsts
        cont = true
      return
    for symbol of nonterminals
      firsts = []
      nonterminals[symbol].productions.forEach (production) ->
        union firsts, production.first
        return
      if firsts.length != nonterminals[symbol].first.length
        nonterminals[symbol].first = firsts
        cont = true
  return

# Get FIRST set for a symbol or symbol sequence

LALRGenerator::first = (symbol) ->
  if symbol == ''
    return []
  if symbol instanceof Array
    firsts = []
    i = 0
    t = undefined
    while t = symbol[i]
      if !@nonterminals[t]
        if firsts.indexOf(t) == -1
          firsts.push t
      else
        union firsts, @nonterminals[t].first
      if !@isNullable(t)
        break
      ++i
    return firsts
  if !@nonterminals[symbol] then [ symbol ] else @nonterminals[symbol].first

# Compute FOLLOW sets for all nonterminals

LALRGenerator::computeFollowSets = ->
  productions = @productions
  nonterminals = @nonterminals
  self = this
  cont = true
  while cont
    cont = false
    productions.forEach (production) ->
      q = ! !self.go_
      ctx = q
      i = 0
      t = undefined
      while t = production.handle[i]
        if !nonterminals[t]
          ++i
          continue
        if ctx
          q = self.gotoEncoded(production.symbol, production.handle.slice(0, i))
        bool = !ctx or q == parseInt(self.lookahead.nonterminalMap[t], 10)
        set = undefined
        if i == production.handle.length - 1 and bool
          set = nonterminals[production.symbol].follows
        else
          part = production.handle.slice(i + 1)
          set = self.first(part)
          if self.isNullable(part) and bool
            set.push.apply set, nonterminals[production.symbol].follows
        oldcount = nonterminals[t].follows.length
        union nonterminals[t].follows, set
        if oldcount != nonterminals[t].follows.length
          cont = true
        ++i
      return
  return

# Compute closure of an item set (add all implied items)

LALRGenerator::closure = (itemSet) ->
  closureSet = new LRState
  self = this
  set = itemSet
  itemQueue = undefined
  syms = {}
  loop
    itemQueue = []
    closureSet.concat set
    (set.list or set).forEach (item) ->
      symbol = item.nextSymbol
      if symbol and self.nonterminals[symbol]
        if !syms[symbol]
          self.nonterminals[symbol].productions.forEach (production) ->
            newItem = new Item(production, 0)
            if !closureSet.contains(newItem)
              itemQueue.push newItem
            return
          syms[symbol] = true
      else if !symbol
        closureSet.reductions.push item
        closureSet.hasConflicts = closureSet.reductions.length > 1 or closureSet.hasShifts
      else
        closureSet.hasShifts = true
        closureSet.hasConflicts = closureSet.reductions.length > 0
      return
    set = itemQueue
    unless itemQueue.length > 0
      break
  closureSet

# Compute goto operation (items after shifting a symbol)

LALRGenerator::goto = (itemSet, symbol) ->
  gotoSet = new LRState
  self = this
  itemSet.list.forEach (item, n) ->
    if item.nextSymbol == symbol
      gotoSet.push new Item(item.production, item.dot + 1, item.follows, n)
    return
  if gotoSet.length == 0 then gotoSet else @closure(gotoSet)

# Generate canonical collection of LR(0) item sets

LALRGenerator::buildLRAutomaton = ->
  item1 = new Item(@productions[0], 0, [ @EOF ])
  firstState = @closure(new LRState(item1))
  states = [ firstState ]
  marked = 0
  self = this
  states.has = {}
  states.has[firstState] = 0
  while marked != states.length
    itemSet = states[marked]
    marked++
    itemSet.list.forEach (item) ->
      if item.nextSymbol and item.nextSymbol != self.EOF
        self.insertLRState item.nextSymbol, itemSet, states, marked - 1
      return
  states

# Insert or merge item set into canonical collection

LALRGenerator::insertLRState = (symbol, itemSet, states, stateNum) ->
  g = @goto(itemSet, symbol)
  if !g.predecessors
    g.predecessors = {}
  if g.length > 0
    gv = g.valueOf()
    i = states.has[gv]
    if i == -1 or typeof i == 'undefined'
      states.has[gv] = states.length
      itemSet.transitions[symbol] = states.length
      states.push g
      g.predecessors[symbol] = [ stateNum ]
    else
      itemSet.transitions[symbol] = i
      states[i].predecessors[symbol].push stateNum
  return

# Parse table generation
# Generate LALR(1) parsing table from item sets

LALRGenerator::buildParseTable = (itemSets) ->
  states = []
  nonterminals = @nonterminals
  operators = @operators
  conflictedStates = {}
  self = this
  s = 1
  r = 2
  a = 3
  NONASSOC = 0
  itemSets.forEach (itemSet, k) ->
    state = states[k] = {}
    # Set shift and goto actions
    for stackSymbol of itemSet.transitions
      itemSet.list.forEach (item) ->
        if item.nextSymbol == stackSymbol
          gotoState = itemSet.transitions[stackSymbol]
          if nonterminals[stackSymbol]
            state[self.symbolMap[stackSymbol]] = gotoState
          else
            state[self.symbolMap[stackSymbol]] = [
              s
              gotoState
            ]
        return
    # Set accept action
    itemSet.list.forEach (item) ->
      if item.nextSymbol == self.EOF
        state[self.symbolMap[self.EOF]] = [ a ]
      return
    allterms = if self.getLookaheadSet then false else self.terminals
    # Set reductions
    itemSet.reductions.forEach (item) ->
      terminals = allterms or self.getLookaheadSet(itemSet, item)
      terminals.forEach (stackSymbol) ->
        action = state[self.symbolMap[stackSymbol]]
        op = operators[stackSymbol]
        if action or action and action.length
          sol = self.resolveConflict(item.production, op, [
            r
            item.production.id
          ], if action[0] instanceof Array then action[0] else action)
          self.resolutions.push [
            k
            stackSymbol
            sol
          ]
          if sol.bydefault
            self.conflicts++
            conflictedStates[k] = true
            if self.options.noDefaultResolve
              if !(action[0] instanceof Array)
                action = [ action ]
              action.push sol.r
          else
            action = sol.action
        else
          action = [
            r
            item.production.id
          ]
        if action and action.length
          state[self.symbolMap[stackSymbol]] = action
        else if action == NONASSOC
          state[self.symbolMap[stackSymbol]] = undefined
        return
      return
    return
  states

# Resolve shift/reduce conflicts using operator precedence

LALRGenerator::resolveConflict = (production, op, reduce, shift) ->
  sln =
    production: production
    operator: op
    r: reduce
    s: shift
  s = 1
  r = 2
  NONASSOC = 0
  if shift[0] == r
    sln.action = if shift[1] < reduce[1] then shift else reduce
    if shift[1] != reduce[1]
      sln.bydefault = true
    return sln
  if production.precedence == 0 or !op
    sln.bydefault = true
    sln.action = shift
  else if production.precedence < op.precedence
    sln.action = shift
  else if production.precedence == op.precedence
    if op.assoc == 'right'
      sln.action = shift
    else if op.assoc == 'left'
      sln.action = reduce
    else if op.assoc == 'nonassoc'
      sln.action = NONASSOC
  else
    sln.action = reduce
  sln

# Find default actions for parser states to reduce table size

LALRGenerator::computeDefaultActions = (states) ->
  defaults = {}
  states.forEach (state, k) ->
    i = 0
    act = undefined
    for act of state
      `act = act`
      if {}.hasOwnProperty.call(state, act)
        i++
    if i == 1 and state[act][0] == 2
      defaults[k] = state[act]
    return
  defaults

# LALR-specific methods
# Get lookahead symbols for an item in a state

LALRGenerator::getLookaheadSet = (state, item) ->
  if ! !@onDemandLookahead and !state.hasConflicts then @terminals else item.follows

# Navigate through parser states following a symbol sequence

LALRGenerator::gotoState = (startState, symbolSequence) ->
  currentState = parseInt(startState, 10)
  i = 0
  while i < symbolSequence.length
    currentState = @states[currentState].transitions[symbolSequence[i]] or currentState
    i++
  currentState

# Navigate through parser states and record the path taken

LALRGenerator::gotoStateWithPath = (startState, symbolSequence) ->
  currentState = parseInt(startState, 10)
  path = []
  i = 0
  while i < symbolSequence.length
    transition = if symbolSequence[i] then currentState + ':' + symbolSequence[i] else ''
    if transition
      @lookahead.nonterminalMap[transition] = currentState
    path.push transition
    currentState = @states[currentState].transitions[symbolSequence[i]] or currentState
    @terminalMap[transition] = symbolSequence[i]
    i++
  {
    path: path
    endState: currentState
  }

# Build augmented grammar for lookahead computation

LALRGenerator::buildAugmentedGrammar = ->
  self = this
  newg = @lookahead
  @states.forEach (state, i) ->
    state.list.forEach (item) ->
      if item.dot == 0
        symbol = i + ':' + item.production.symbol
        self.terminalMap[symbol] = item.production.symbol
        newg.nonterminalMap[symbol] = i
        if !newg.nonterminals[symbol]
          newg.nonterminals[symbol] = new Nonterminal(symbol)
        pathInfo = self.gotoStateWithPath(i, item.production.handle)
        p = new Production(symbol, pathInfo.path, newg.productions.length)
        newg.productions.push p
        newg.nonterminals[symbol].productions.push p
        handle = item.production.handle.join(' ')
        handleToSymbols = self.states[pathInfo.endState].handleToSymbols
        if !handleToSymbols[handle]
          handleToSymbols[handle] = []
        handleToSymbols[handle].push symbol
      return
    if state.hasConflicts
      self.conflictStates.push i
    return
  return

# Propagate lookaheads from augmented grammar back to original states

LALRGenerator::unionLookaheads = ->
  self = this
  newg = @lookahead
  states = if ! !@onDemandLookahead then @conflictStates else @states
  states.forEach (i) ->
    state = if typeof i == 'number' then self.states[i] else i
    if state.reductions.length
      state.reductions.forEach (item) ->
        follows = {}
        k = 0
        while k < item.follows.length
          follows[item.follows[k]] = true
          k++
        state.handleToSymbols[item.production.handle.join(' ')].forEach (symbol) ->
          newg.nonterminals[symbol].follows.forEach (symbol) ->
            terminal = self.terminalMap[symbol]
            if !follows[terminal]
              follows[terminal] = true
              item.follows.push terminal
            return
          return
        return
    return
  return

# Code generation
# Generate parser code with specified options

LALRGenerator::generate = (opt) ->
  opt = Object.assign({}, @options, opt)
  moduleName = opt.moduleName or 'parser'
  if !moduleName.match(/^[A-Za-z_$][A-Za-z0-9_$]*$/)
    moduleName = 'parser'
  @generateCommonJSModule opt

# Generate CommonJS module wrapper for parser

LALRGenerator::generateCommonJSModule = (opt) ->
  opt = Object.assign({}, @options, opt)
  moduleName = opt.moduleName or 'parser'
  out = @generateModule(opt) + '\n\n\nif (typeof require !== \'undefined\' && typeof exports !== \'undefined\') {' + '\nexports.parser = ' + moduleName + ';' + '\nexports.Parser = ' + moduleName + '.Parser;' + '\nexports.parse = function () { return ' + moduleName + '.parse.apply(' + moduleName + ', arguments); };' + '\nexports.main = function() {};' + '\nif (typeof module !== \'undefined\' && require.main === module) {\n' + '  exports.main(process.argv.slice(1));\n}' + '\n}'
  out

# Generate module wrapper for parser

LALRGenerator::generateModule = (opt) ->
  opt = Object.assign({}, @options, opt)
  moduleName = opt.moduleName or 'parser'
  out = '/* parser generated by jison ' + version + ' */\n'
  out += (if moduleName.match(/\./) then moduleName else 'var ' + moduleName) + ' = ' + @generateModuleExpr()
  out

# Generate self-executing module expression

LALRGenerator::generateModuleExpr = ->
  module = @generateModule_()
  out = '(function(){\n'
  out += module.commonCode
  out += '\nvar parser = ' + module.moduleCode
  out += '\n' + @moduleInclude
  out += '\nfunction Parser () {\n  this.yy = {};\n}\n' + 'Parser.prototype = parser;' + 'parser.Parser = Parser;' + '\nreturn new Parser;\n})();'
  out

# Generate core parser module code

LALRGenerator::generateModule_ = ->
  tableCode = @generateTableCode(@stateTable)
  moduleCode = '{'
  moduleCode += [
    'trace: function trace() {}'
    'yy: {}'
    'symbolMap: ' + JSON.stringify(@symbolMap)
    'terminals_: ' + JSON.stringify(@terminals_).replace(/"([0-9]+)":/g, '$1:')
    'productionTable: ' + JSON.stringify(@productionTable)
    'stateTable: ' + tableCode.moduleCode
    'defaultActions: ' + JSON.stringify(@defaultActions).replace(/"([0-9]+)":/g, '$1:')
    'performAction: ' + String(@performAction)
    'parseError: ' + String(@parseError)
    'parse: ' + String(@parse)
  ].join(',\n')
  moduleCode += '};'
  {
    commonCode: tableCode.commonCode
    moduleCode: moduleCode
  }

# Generate optimized parsing table code

LALRGenerator::generateTableCode = (stateTable) ->
  # Generate compact JSON without spaces and with unquoted numeric keys
  moduleCode = JSON.stringify(stateTable, null, 0)
  # Remove quotes around numeric object keys
  moduleCode = moduleCode.replace(/"([0-9]+)"(?=:)/g, '$1')
  {
    commonCode: ''
    moduleCode: moduleCode
  }

# Handle parsing errors with context information

LALRGenerator::parseError = (str, hash) ->
  if hash.recoverable
    @trace str
  else
    error = new Error(str)
    error.hash = hash
    throw error
  return

# Parse input string using generated LALR(1) parser

LALRGenerator::parse = (input) ->
  self = this
  stk = [ 0 ]
  val = [ null ]
  loc = []
  stateTable = @stateTable
  yytext = ''
  yylineno = 0
  yyleng = 0
  recovering = 0
  TERROR = 2
  EOF = 1
  lexer = Object.create(@lexer)
  sharedState = yy: {}
  for k of @yy
    if Object::hasOwnProperty.call(@yy, k)
      sharedState.yy[k] = @yy[k]
  lexer.setInput input, sharedState.yy
  sharedState.yy.lexer = lexer
  sharedState.yy.parser = this
  if typeof lexer.yylloc == 'undefined'
    lexer.yylloc = {}
  yyloc = lexer.yylloc
  loc.push yyloc
  ranges = lexer.options and lexer.options.ranges
  if typeof sharedState.yy.parseError == 'function'
    @parseError = sharedState.yy.parseError
  else
    @parseError = Object.getPrototypeOf(this).parseError

  lex = ->
    token = lexer.lex() or EOF
    if typeof token != 'number'
      token = self.symbolMap[token] or token
    token

  symbol = undefined
  preErrorSymbol = undefined
  state = undefined
  action = undefined
  r = undefined
  yyval = {}
  p = undefined
  len = undefined
  newState = undefined
  expected = undefined
  loop
    stkLen = stk.length
    state = stk[stkLen - 1]
    if @defaultActions[state]
      action = @defaultActions[state]
    else
      if symbol == null or typeof symbol == 'undefined'
        symbol = lex()
      action = stateTable[state] and stateTable[state][symbol]
    if typeof action == 'undefined' or !action.length or !action[0]
      errStr = ''
      if !recovering
        expected = []
        if @terminals_[p] and p > TERROR
          expected.push '\'' + @terminals_[p] + '\''
          for p of stateTable[state]
            `p = p`
        if lexer.showPosition
          errStr = 'Parse error on line ' + yylineno + 1 + ':\n' + lexer.showPosition() + '\nExpecting ' + expected.join(', ') + ', got \'' + (@terminals_[symbol] or symbol) + '\''
        else
          errStr = 'Parse error on line ' + yylineno + 1 + ': Unexpected ' + (if symbol == EOF then 'end of input' else '\'' + (@terminals_[symbol] or symbol) + '\'')
        @parseError errStr,
          text: lexer.match
          token: @terminals_[symbol] or symbol
          line: lexer.yylineno
          loc: yyloc
          expected: expected
      throw new Error(errStr)
    if action[0] instanceof Array and action.length > 1
      throw new Error('Parse Error: multiple actions possible at state: ' + state + ', token: ' + symbol)
    switch action[0]
      when 1
        # shift
        stk.push symbol
        val.push lexer.yytext
        loc.push lexer.yylloc
        stk.push action[1]
        symbol = null
        if !preErrorSymbol
          yyleng = lexer.yyleng
          yytext = lexer.yytext
          yylineno = lexer.yylineno
          yyloc = lexer.yylloc
          if recovering > 0
            recovering--
        else
          symbol = preErrorSymbol
          preErrorSymbol = null
      when 2
        # reduce
        len = @productionTable[action[1]][1]
        valLen = val.length
        locLen = loc.length
        yyval.$ = val[valLen - len]
        locFirst = loc[locLen - (len or 1)]
        locLast = loc[locLen - 1]
        yyval._$ =
          first_line: locFirst.first_line
          last_line: locLast.last_line
          first_column: locFirst.first_column
          last_column: locLast.last_column
        if ranges
          yyval._$.range = [
            locFirst.range[0]
            locLast.range[1]
          ]
        r = @performAction.apply(yyval, [
          yytext
          yyleng
          yylineno
          sharedState.yy
          action[1]
          val
          loc
        ])
        if typeof r != 'undefined'
          return r
        if len
          stk.length = stk.length - (len * 2)
          val.length = val.length - len
          loc.length = loc.length - len
        stk.push @productionTable[action[1]][0]
        val.push yyval.$
        loc.push yyval._$
        stkLen = stk.length
        newState = stateTable[stk[stkLen - 2]][stk[stkLen - 1]]
        stk.push newState
      when 3
        # accept
        return true
  return

# Debug tracing function (no-op by default)

LALRGenerator::trace = ->

# Create executable parser instance from generated code

LALRGenerator::createParser = ->
  p = eval(@generateModuleExpr())

  bind = (method) ->
    ->
      self.lexer = p.lexer
      self[method].apply self, arguments

  p.productions = @productions
  self = this
  p.lexer = @lexer
  p.generate = bind('generate')
  p.generateModule = bind('generateModule')
  p.generateCommonJSModule = bind('generateCommonJSModule')
  p

# Exports

Jison.Parser = (grammar, options) ->
  gen = new LALRGenerator(grammar, options)
  gen.createParser()

exports.LALRGenerator = LALRGenerator

Jison.Generator = (g, options) ->
  opt = Object.assign({}, g.options, options)
  new LALRGenerator(g, opt)
