# ==============================================================================
# rip.grammar — Rip Language Lexer and Parser Grammar
# ==============================================================================
#
# Defines the lexer and parser for Rip. Processed by src/grammar.zig to
# generate src/parser.zig.
#
# Usage: grammar rip.grammar src/parser.zig
#
# Rip is a high-performance systems language with elegant syntax that
# compiles to Zig. This grammar defines the v0 bootstrap subset.
# ==============================================================================

@lang = "rip"

@lexer

# ==============================================================================
# STATE VARIABLES
# ==============================================================================

state
    beg   = 1       # beginning of line
    paren = 0       # parenthesis depth
    brace = 0       # brace depth

after
    beg = 0         # cleared after each token

# ==============================================================================
# TOKEN TYPES
# ==============================================================================

tokens
    # Literals
    ident           # Identifier: variable, function, type name
    integer         # Integer: 0, 1, 42, 1000
    real            # Decimal: 3.14, .5, 2.0
    string_sq       # Single-quoted string: 'hello world'
    string_dq       # Double-quoted string: "hello #{name}"
    true            # true
    false           # false

    # Operators — arithmetic
    plus            # +
    minus           # -
    star            # *
    slash           # /
    percent         # %
    power           # **

    # Operators — comparison
    eq              # ==
    ne              # !=
    lt              # <
    gt              # >
    le              # <=
    ge              # >=

    # Operators — logical
    and_sym         # &&
    or_sym          # ||
    not_sym         # !

    # Operators — assignment
    assign          # =
    const_assign    # =!
    plus_assign     # +=
    minus_assign    # -=
    star_assign     # *=
    slash_assign    # /=

    # Punctuation
    lparen          # (
    rparen          # )
    lbrace          # {
    rbrace          # }
    lbracket        # [
    rbracket        # ]
    comma           # ,
    colon           # :
    arrow           # ->
    fat_arrow       # =>
    dot             # .
    dotdot          # ..
    pipe            # |>

    # Whitespace and structure
    indent          # Indentation increase
    outdent         # Indentation decrease
    newline         # Line terminator
    comment         # # through end of line
    eof             # End of input
    err             # Lexer error

# ==============================================================================
# COMMENTS
# ==============================================================================

'#' [^\n]*                                  → comment

# ==============================================================================
# NEWLINES AND LINE CONTINUATION
# ==============================================================================

"\\\n"                                      → skip         # line continuation
"\r\n"                                      → newline, {beg = 1}
'\n'                                        → newline, {beg = 1}
'\r'                                        → newline, {beg = 1}

# ==============================================================================
# STRINGS
# ==============================================================================

'"' ([^"\\$\n] | '\\' . | '$')* '"'         → string_dq
"'" ([^'\n] | "''")* "'"                    → string_sq

# ==============================================================================
# NUMBERS
# ==============================================================================

[0-9]* '.' [0-9]+                           → real
[0-9]+                                      → integer

# ==============================================================================
# MULTI-CHARACTER OPERATORS (longer patterns first)
# ==============================================================================

"**"                                        → power
"=="                                        → eq
"!="                                        → ne
"<="                                        → le
">="                                        → ge
"&&"                                        → and_sym
"||"                                        → or_sym
"=!"                                        → const_assign
"+="                                        → plus_assign
"-="                                        → minus_assign
"*="                                        → star_assign
"/="                                        → slash_assign
"->"                                        → arrow
"=>"                                        → fat_arrow
"|>"                                        → pipe
".."                                        → dotdot

# ==============================================================================
# SINGLE-CHARACTER OPERATORS AND PUNCTUATION
# ==============================================================================

'+'                                         → plus
'-'                                         → minus
'*'                                         → star
'/'                                         → slash
'%'                                         → percent
'<'                                         → lt
'>'                                         → gt
'!'                                         → not_sym
'='                                         → assign
'('                                         → lparen, {paren++}
')'                                         → rparen, {paren--}
'{'                                         → lbrace, {brace++}
'}'                                         → rbrace, {brace--}
'['                                         → lbracket
']'                                         → rbracket
','                                         → comma
':'                                         → colon
'.'                                         → dot

# ==============================================================================
# IDENTIFIERS
# ==============================================================================

[a-zA-Z_][a-zA-Z0-9_]* '?'?                 → ident

# ==============================================================================
# FALLBACK
# ==============================================================================

.                                           → err

# ==============================================================================
# PARSER
# ==============================================================================

@parser

@conflicts = 0

@as = [ident, keyword]

# ==============================================================================
# PROGRAM STRUCTURE
# ==============================================================================

name = IDENT

program! = body                             → (module ...1)
expr!    = expr                             → 1

body     = stmt                             → (1)
         | body NEWLINE stmt                → (...1 3)
         | body NEWLINE                     → 1

stmt     = use
         | fun
         | sub
         | expr

block    = INDENT body OUTDENT              → (block ...2)
         | INDENT OUTDENT                   → (block)

# ==============================================================================
# DECLARATIONS
# ==============================================================================

fun      = FUN name params block            → (fun 2 params:3 body:4)
         | FUN name block                   → (fun 2 body:3)

sub      = SUB name params block            → (sub 2 params:3 body:4)
         | SUB name block                   → (sub 2 body:3)

use      = USE name                         → (use 2)

params   = L(name)                          → (...1)

# ==============================================================================
# EXPRESSIONS
# ==============================================================================

expr     = if
         | return
         | assign
         | const
         | @infix

if       = IF expr block ELSE if            → (if 2 3 5)
         | IF expr block ELSE block         → (if 2 3 5)
         | IF expr block                    → (if 2 3)

return   = RETURN expr                      → (return 2)
         | RETURN                           → (return)

assign   = name "=" expr                    → (= 1 3)
const    = name "=!" expr                   → (const 1 3)

# ==============================================================================
# CALLS AND ATOMS
# ==============================================================================

unary    = "!" unary                        → (not 2)
         | "-" unary                        → (neg 2)
         | call

call     = call "!" atom                    → (await 1 3)
         | call L(atom)                     → (call 1 ...2)
         | call "(" args ")"                → (call 1 ...3)
         | atom

args     = L(expr)                          → (...1)
         |                                  → ()

atom     = name
         | INTEGER
         | REAL
         | STRING_SQ
         | STRING_DQ
         | TRUE
         | FALSE
         | "(" expr ")"                     → 2

# ==============================================================================
# INFIX OPERATORS
# ==============================================================================

@infix unary
    "||"  left
    "&&"  left
    "=="  none, "!=" none, "<" none, ">" none, "<=" none, ">=" none
    "+"   left, "-"  left
    "*"   left, "/"  left, "%"  left
    "**"  right
