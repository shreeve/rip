{
  "name": "rip",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Zero-build, full-stack language for reactive UI, schemas, ORM, and server logic.",
  "scripts": {
    "parser": "bun src/grammar/solar.rip -o src/parser.js src/grammar/grammar.rip",
    "corpus-expected": "bun scripts/corpus-expected.mjs",
    "test": "bun test --timeout 15000",
    "test:rip": "bun test test/battery.test.js --timeout 15000",
    "test:all": "RIP_EXTENDED=1 RIP_REQUIRE_TSC=1 bun test --timeout 15000",
    "ext": "bun scripts/install-ext.mjs",
    "type-audit": "bun test/type-audit/runner.js"
  },
  "bin": {
    "rip": "bin/rip"
  }
}
