# The file-based task queue, exercised directly (no workers): init(),
# todo() payload forms, every retry() branch, and the main-thread value
# of _getPerform(). Prints one line per observation for exact matching.
import { init, todo, retry, _getPerform } from '@rip-lang/swarm'
import { readFileSync, readdirSync, renameSync } from 'fs'

init()
todo('empty')
todo('str', 'hello')
todo('obj', { a: 1, b: [2, 3] })
todo(42)
todo(0)

console.log JSON.stringify(readdirSync('.swarm/todo').sort())
console.log JSON.stringify(readFileSync('.swarm/todo/empty', 'utf8'))
console.log JSON.stringify(readFileSync('.swarm/todo/str', 'utf8'))
console.log JSON.stringify(readFileSync('.swarm/todo/obj', 'utf8'))

# died empty, todo non-empty -> true (work is already queued)
console.log 'retry-with-todo:', retry()

# move everything to died, then retry moves it all back
for f in readdirSync('.swarm/todo')
  renameSync ".swarm/todo/#{f}", ".swarm/died/#{f}"
console.log 'retry-moves:', retry()
console.log JSON.stringify(readdirSync('.swarm/todo').sort())
console.log JSON.stringify(readdirSync('.swarm/died').sort())

# both empty -> false
init()
console.log 'retry-empty:', retry()

# init() clears any existing queue
todo('x')
init()
console.log 'after-reinit:', JSON.stringify(readdirSync('.swarm/todo'))

# no perform is registered in the main thread
console.log 'getPerform:', _getPerform()
process.exit(0)
