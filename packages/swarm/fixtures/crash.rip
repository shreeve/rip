# Worker-crash recovery: task 5 kills its whole worker thread with a
# bare exit. The main thread must count the in-flight task as died,
# respawn the worker, and still finish the batch cleanly.

import { swarm, init, retry, todo } from '@rip-lang/swarm'

setup = ->
  unless retry()
    init()
    todo i for i in [1..6]
  null

perform = (task, ctx) ->
  exit 7 if task.split('/').pop() is '5'

swarm { setup, perform }
