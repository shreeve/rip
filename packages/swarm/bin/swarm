#!/usr/bin/env bun
//
// swarm — run a swarm job script. The script itself calls swarm(), so
// this wrapper just runs it under the repository's `rip` CLI (the .rip
// loader), forwarding the argv and exit status untouched.
import { execFileSync } from 'node:child_process';
import { fileURLToPath } from 'node:url';
import { dirname, join } from 'node:path';

const script = process.argv[2];
if (!script) {
  console.error('usage: swarm [options] <script.rip>');
  process.exit(1);
}

const here = dirname(fileURLToPath(import.meta.url));
const rip = join(here, '..', '..', '..', 'bin', 'rip');

try {
  execFileSync(process.execPath, [rip, script, ...process.argv.slice(3)], { stdio: 'inherit' });
} catch (e) {
  process.exit(e.status ?? 1);
}
