#!/usr/bin/env bun
//
// rip-ai — the MCP stdio server for @rip-lang/ai. The server logic lives
// in ../mcp.rip behind its `import.meta.main` guard, so this wrapper runs
// the module as a main script under the repository's .rip loader and
// forwards the argv and exit status untouched.
import { execFileSync } from 'node:child_process';
import { fileURLToPath } from 'node:url';
import { dirname, join } from 'node:path';

const here = dirname(fileURLToPath(import.meta.url));
const mcpRip = join(here, '..', 'mcp.rip');
const loader = join(here, '..', '..', '..', 'src', 'loader.js');

try {
  execFileSync(process.execPath, ['--preload', loader, mcpRip, ...process.argv.slice(2)], { stdio: 'inherit' });
} catch (e) {
  process.exit(e.status ?? 1);
}
